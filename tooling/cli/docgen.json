{
  "$schema": "../../tooling/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts", "src/**/*.test.ts", "src/**/*.spec.ts"],
  "enforceDescriptions": true,
  "enforceVersion": true,
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/tooling/cli/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/repo-cli": ["../../tooling/cli/src/index.ts"],
      "@beep/repo-cli/*": ["../../tooling/cli/src/*.ts"],
      "@beep/chalk": ["../../packages/common/chalk/src/index.ts"],
      "@beep/chalk/*": ["../../packages/common/chalk/src/*.ts"],
      "@beep/docgen": ["../../tooling/docgen/src/index.ts"],
      "@beep/docgen/*": ["../../tooling/docgen/src/*.ts"],
      "@beep/docgen/schema.json": ["../../tooling/docgen/schema.json"],
      "@beep/ffmpeg": ["../../packages/drivers/ffmpeg/src/index.ts"],
      "@beep/ffmpeg/*": ["../../packages/drivers/ffmpeg/src/*.ts"],
      "@beep/identity": ["../../packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["../../packages/common/identity/src/*.ts"],
      "@beep/identity/packages": [
        "../../packages/common/identity/src/packages.ts"
      ],
      "@beep/observability": [
        "../../packages/common/observability/src/index.ts"
      ],
      "@beep/observability/*": ["../../packages/common/observability/src/*.ts"],
      "@beep/observability/experimental/server": [
        "../../packages/common/observability/src/experimental/server/index.ts"
      ],
      "@beep/observability/server": [
        "../../packages/common/observability/src/server/index.ts"
      ],
      "@beep/observability/web": [
        "../../packages/common/observability/src/web/index.ts"
      ],
      "@beep/repo-configs": ["../../tooling/configs/src/index.ts"],
      "@beep/repo-configs/*": ["../../tooling/configs/src/*.ts"],
      "@beep/repo-utils": ["../../tooling/repo-utils/src/index.ts"],
      "@beep/repo-utils/*": ["../../tooling/repo-utils/src/*.ts"],
      "@beep/schema": ["../../packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["../../packages/common/schema/src/*.ts"],
      "@beep/test-utils": ["../../tooling/test-utils/src/index.ts"],
      "@beep/test-utils/*": ["../../tooling/test-utils/src/*.ts"]
    }
  }
}
