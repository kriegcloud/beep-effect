{
  "name": "@beep/repo-cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "description": "CLI tool for creating and managing packages in the beep-effect monorepo following Effect v4 standards",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/tooling/cli",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "tooling/cli"
  },
  "sideEffects": [],
  "bin": {
    "beep-cli": "./src/bin.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./commands/*": "./src/commands/*.ts",
    "./internal/*": null,
    "./bin": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/commands/CreatePackage/templates/**/*.hbs"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "bin": {
      "beep-cli": "./dist/bin.js"
    },
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./commands/*": "./dist/commands/*.js",
      "./internal/*": null,
      "./bin": null
    }
  },
  "scripts": {
    "codegen": "echo 'codegen will be implemented by this package'",
    "build": "tsc -b tsconfig.json && bun run babel && node scripts/copy-create-package-templates.mjs",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest --coverage",
    "docgen": "bunx @effect/docgen",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "@beep/chalk": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/repo-utils": "workspace:^",
    "@beep/schema": "workspace:^",
    "@effect/markdown-toc": "catalog:",
    "@effect/platform-node": "catalog:",
    "d3-dsv": "catalog:",
    "doctrine": "catalog:",
    "effect": "catalog:",
    "fast-xml-parser": "catalog:",
    "handlebars": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/doctrine": "catalog:",
    "@types/babel__code-frame": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
