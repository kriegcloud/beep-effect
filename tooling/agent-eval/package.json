{
  "name": "@beep/agent-eval",
  "version": "0.0.0",
  "description": "Benchmarking and reliability tooling for Codex+Claude agent workflows in beep-effect",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "tsc -b tsconfig.json && bun run babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest --coverage",
    "docgen": "bunx @effect/docgen",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "@beep/ai-sdk": "workspace:^",
    "effect": "catalog:",
    "@openai/codex-sdk": "catalog:",
    "@effect/platform-node": "catalog:",
    "@beep/identity": "workspace:^",
    "@beep/repo-utils": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@effect/vitest": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./bin": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "tooling/agent-eval"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/tooling/agent-eval",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./bin": null
    }
  }
}
