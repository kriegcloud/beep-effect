{
  "extends": "./tsconfig.json",
  "include": ["src", "test"],
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "plugins": []
  }
}
