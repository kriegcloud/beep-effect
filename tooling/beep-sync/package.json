{
  "name": "@beep/beep-sync",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Scaffold for unified AI tooling sync runtime and POC fixtures",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/tooling/beep-sync",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "tooling/beep-sync"
  },
  "sideEffects": [],
  "bin": {
    "beep-sync": "./src/bin.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./bin": null,
    "./internal/*": null
  },
  "scripts": {
    "codegen": "echo 'no codegen for @beep/beep-sync scaffold'",
    "build": "tsc -b tsconfig.json",
    "build:tsgo": "tsgo -b tsconfig.json",
    "check": "tsc -b tsconfig.json",
    "test": "bun run test:unit && bun run test:fixtures && bun run test:integration",
    "test:unit": "bash scripts/test-unit.sh",
    "test:fixtures": "bash scripts/test-fixtures.sh",
    "test:integration": "bash scripts/test-integration.sh",
    "test:coverage": "bash scripts/test-coverage.sh",
    "poc:preflight": "bash scripts/poc-preflight.sh",
    "agents:audit": "bash scripts/audit-package-agents.sh",
    "agents:scaffold": "bash scripts/scaffold-package-agents.sh",
    "docgen": "echo 'docgen not enabled for scaffold'",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "effect": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
