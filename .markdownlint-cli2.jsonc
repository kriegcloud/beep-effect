{
  "config": {
    // Disable line length (docs have long code blocks)
    "MD013": false,
    // Allow inline HTML (used in markdown tables and badges)
    "MD033": false,
    // Don't require first line to be h1 (many files have frontmatter)
    "MD041": false,
    // Allow multiple top-level headings (generated docs use this)
    "MD025": false,
    // Allow emphasis as heading (generated docs use *Example* / *Signature*)
    "MD036": false,
    // Disable table column style (compact tables are fine)
    "MD060": false,
    // Allow mixed heading styles (atx preferred, setext in some generated files)
    "MD003": false
  },
  "ignores": [
    "node_modules/**",
    ".repos/**",
    ".next/**",
    "dist/**",
    "coverage/**",
    "storybook-static/**",
    ".beep/**",
    "**/docs/**",
    ".agents/**",
    ".claude/**",
    "specs/**",
    "**/AGENTS.md",
    "**/CLAUDE.md"
  ]
}
