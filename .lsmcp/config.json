{
  "preset": "typescript",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.git/**",
    "**/.repos/**",
    "**/specs/**",
    "**/.turbo/**",
    "**/.sst/**",
    "**/dist/**",
    "**/build/**"
  ],
  "settings": {
    "autoIndex": true,
    "indexConcurrency": 8,
    "enableWatchers": true
  },
  "serverCharacteristics": {
    "documentOpenDelay": 1000,
    "readinessCheckTimeout": 1000,
    "initialDiagnosticsTimeout": 10000,
    "operationTimeout": 60000
  }
}
