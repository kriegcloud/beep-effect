{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [
    {
      "path": "tsconfig.packages.json"
    }
  ],
  "include": [
    "**/vitest.*.ts",
    // All vitest config files across all packages
    "./apps/**/test/**/*.ts",
    "./apps/**/test/**/*.tsx",
    "./apps/**/test/**/*.json",
    "./packages/**/test/**/*.ts",
    "./packages/**/test/**/*.tsx",
    "./packages/**/test/**/*.json",
    "./packages/**/dtslint/**/*.ts",
    "./packages/**/dtslint/**/*.tsx",
    "./tooling/**/test/**/*.ts",
    "./tooling/**/test/**/*.tsx",
    "./tooling/**/test/**/*.json",
    "./tooling/**/dtslint/**/*.ts",
    "./tooling/**/dtslint/**/*.tsx",
    "./syncpack.config.ts",
    "./.claude/*.ts",
    "./.claude/*.json"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tmp/**",
    "**/test/fixtures/**",
    // Desktop owns its own test/vitest typecheck through apps/desktop/tsconfig.test.json.
    "./apps/desktop/test/**/*.ts",
    "./apps/desktop/test/**/*.tsx",
    "./apps/desktop/test/**/*.json",
    // Editor app owns its own test typecheck through apps/editor-app/tsconfig.json.
    "./apps/editor-app/test/**/*.ts",
    "./apps/editor-app/test/**/*.tsx",
    "./apps/editor-app/test/**/*.json",
    // V2T owns its own test typecheck through apps/V2T/tsconfig.json.
    "./apps/V2T/test/**/*.ts",
    "./apps/V2T/test/**/*.tsx",
    "./apps/V2T/test/**/*.json"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.root.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "rewriteRelativeImportExtensions": false,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": [
      "node",
      "bun"
    ],
    "paths": {
      // Path aliases allow loading internal modules in tests and using workspace packages
      // These will be populated as packages are created
      "@beep/repo-cli": [
        "./tooling/cli/src/index.ts"
      ],
      "@beep/repo-cli/*": [
        "./tooling/cli/src/*"
      ],
      "@beep/repo-cli/commands/*": [
        "./tooling/cli/src/commands/*"
      ],
      "@beep/repo-cli/test/*": [
        "./tooling/cli/test/*.ts"
      ],
      "@beep/repo-utils": [
        "./tooling/repo-utils/src/index.ts"
      ],
      "@beep/repo-utils/*": [
        "./tooling/repo-utils/src/*"
      ],
      "@beep/repo-utils/test/*": [
        "./tooling/utils/test/*.ts"
      ],
      "@beep/types": [
        "./packages/common/types/src/index.ts"
      ],
      "@beep/types/*": [
        "./packages/common/types/src/*"
      ],
      "@beep/utils": [
        "./packages/common/utils/src/index.ts"
      ],
      "@beep/utils/*": [
        "./packages/common/utils/src/*"
      ],
      "@beep/identity": [
        "./packages/common/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "./packages/common/identity/src/*"
      ],
      "@beep/schema": [
        "./packages/common/schema/src/index.ts"
      ],
      "@beep/schema/*": [
        "./packages/common/schema/src/*"
      ],
      "@beep/schema/test/*": [
        "./packages/common/schema/test/*"
      ],
      "@beep/messages": [
        "./packages/common/messages/src/index.ts"
      ],
      "@beep/messages/*": [
        "./packages/common/messages/src/*"
      ],
      "@beep/data": [
        "./packages/common/data/src/index.ts"
      ],
      "@beep/data/*": [
        "./packages/common/data/src/*"
      ],
      "@beep/shared-domain": [
        "./packages/shared/domain/src/index.ts"
      ],
      "@beep/shared-domain/*": [
        "./packages/shared/domain/src/*"
      ],
      "@beep/shared-env": [
        "./packages/shared/env/src/index.ts"
      ],
      "@beep/shared-env/*": [
        "./packages/shared/env/src/*"
      ],
      "@beep/ui": [
        "./packages/common/ui/src/index.ts"
      ],
      "@beep/ui/*": [
        "./packages/common/ui/src/*"
      ],
      "@beep/shared-ui": [
        "./packages/shared/ui/src/index.ts"
      ],
      "@beep/shared-ui/*": [
        "./packages/shared/ui/src/*"
      ],
      "@beep/shared-tables": [
        "./packages/shared/tables/src/index.ts"
      ],
      "@beep/shared-tables/*": [
        "./packages/shared/tables/src/*"
      ],
      "@beep/shared-server": [
        "./packages/shared/server/src/index.ts"
      ],
      "@beep/shared-server/*": [
        "./packages/shared/server/src/*"
      ],
      "@beep/shared-client": [
        "./packages/shared/client/src/index.ts"
      ],
      "@beep/shared-client/*": [
        "./packages/shared/client/src/*"
      ],
      "@beep/runtime-protocol": [
        "./packages/runtime/protocol/src/index.ts"
      ],
      "@beep/runtime-protocol/*": [
        "./packages/runtime/protocol/src/*"
      ],
      "@beep/runtime-server": [
        "./packages/runtime/server/src/index.ts"
      ],
      "@beep/runtime-server/internal/*": [
        "./packages/runtime/server/src/internal/*.ts"
      ],
      "@beep/runtime-server/*": [
        "./packages/runtime/server/src/*"
      ],
      "@beep/repo-memory-model": [
        "./packages/repo-memory/model/src/index.ts"
      ],
      "@beep/repo-memory-model/*": [
        "./packages/repo-memory/model/src/*"
      ],
      "@beep/repo-memory-runtime": [
        "./packages/repo-memory/runtime/src/index.ts"
      ],
      "@beep/repo-memory-runtime/internal/*": [
        "./packages/repo-memory/runtime/src/internal/*.ts"
      ],
      "@beep/repo-memory-runtime/*": [
        "./packages/repo-memory/runtime/src/*"
      ],
      "@beep/repo-memory-client": [
        "./packages/repo-memory/client/src/index.ts"
      ],
      "@beep/repo-memory-client/*": [
        "./packages/repo-memory/client/src/*"
      ],
      "@beep/repo-memory-store": [
        "./packages/repo-memory/store/src/index.ts"
      ],
      "@beep/repo-memory-store/*": [
        "./packages/repo-memory/store/src/*"
      ],
      "@beep/repo-memory-sqlite": [
        "./packages/repo-memory/sqlite/src/index.ts"
      ],
      "@beep/repo-memory-sqlite/*": [
        "./packages/repo-memory/sqlite/src/*"
      ],
      "@beep/repo-configs": [
        "./tooling/configs/src/index.ts"
      ],
      "@beep/repo-configs/*": [
        "./tooling/configs/src/*"
      ],
      "@beep/repo-configs/internal/*": [
        "./tooling/configs/src/internal/*"
      ],
      "@beep/test-utils": [
        "./tooling/test-utils/src/index.ts"
      ],
      "@beep/test-utils/*": [
        "./tooling/test-utils/src/*"
      ],
      "@beep/db-admin": [
        "./packages/_internal/db-admin/src/index.ts"
      ],
      "@beep/db-admin/*": [
        "./packages/_internal/db-admin/src/*"
      ],
      "@beep/semantic-web": [
        "./packages/common/semantic-web/src/index.ts"
      ],
      "@beep/semantic-web/*": [
        "./packages/common/semantic-web/src/*"
      ],
      "@beep/nlp": [
        "./packages/common/nlp/src/index.ts"
      ],
      "@beep/nlp/*": [
        "./packages/common/nlp/src/*"
      ],
      "@beep/editor": [
        "./packages/editor/core/src/index.ts"
      ],
      "@beep/editor/*": [
        "./packages/editor/core/src/*"
      ],
      "@beep/observability": [
        "./packages/common/observability/src/index.ts"
      ],
      "@beep/observability/*": [
        "./packages/common/observability/src/*"
      ],
      "@beep/colors": [
        "./packages/common/colors/src/index.ts"
      ],
      "@beep/colors/*": [
        "./packages/common/colors/src/*"
      ],
      "@beep/chalk": [
        "./packages/common/chalk/src/index.ts"
      ],
      "@beep/chalk/*": [
        "./packages/common/chalk/src/*"
      ],
      "@beep/docgen": [
        "./tooling/docgen/src/index.ts"
      ],
      "@beep/docgen/*": [
        "./tooling/docgen/src/*"
      ],
      "@beep/editor-lexical": [
        "./packages/editor/lexical/src/index.ts"
      ],
      "@beep/editor-lexical/*": [
        "./packages/editor/lexical/src/*"
      ],
      "@beep/editor-protocol": [
        "./packages/editor/protocol/src/index.ts"
      ],
      "@beep/editor-protocol/*": [
        "./packages/editor/protocol/src/*"
      ],
      "@beep/editor-client": [
        "./packages/editor/client/src/index.ts"
      ],
      "@beep/editor-client/*": [
        "./packages/editor/client/src/*"
      ],
      "@beep/editor-runtime": [
        "./packages/editor/runtime/src/index.ts"
      ],
      "@beep/editor-runtime/*": [
        "./packages/editor/runtime/src/*"
      ],
      "@beep/v2t-sidecar": [
        "./packages/v2t-sidecar/src/index.ts"
      ],
      "@beep/v2t-sidecar/*": [
        "./packages/v2t-sidecar/src/*"
      ],
      "@beep/infra": [
        "./infra/src/index.ts"
      ],
      "@beep/infra/*": [
        "./infra/src/*"
      ],
      "@beep/knowledge-graph": [
        "./packages/common/knowledge-graph/src/index.ts"
      ],
      "@beep/knowledge-graph/*": [
        "./packages/common/knowledge-graph/src/*"
      ],
      "@beep/firecrawl": [
        "./packages/shared/providers/firecrawl/src/index.ts"
      ],
      "@beep/firecrawl/*": [
        "./packages/shared/providers/firecrawl/src/*"
      ]
    }
  }
}
