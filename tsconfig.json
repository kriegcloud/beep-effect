{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [
    {
      "path": "tsconfig.packages.json"
    }
  ],
  "include": [
    "**/vitest.*.ts",
    // All vitest config files across all packages
    "./apps/**/test/**/*.ts",
    "./apps/**/test/**/*.tsx",
    "./apps/**/test/**/*.json",
    "./packages/**/test/**/*.ts",
    "./packages/**/test/**/*.tsx",
    "./packages/**/test/**/*.json",
    "./packages/**/dtslint/**/*.ts",
    "./packages/**/dtslint/**/*.tsx",
    "./tooling/**/test/**/*.ts",
    "./tooling/**/test/**/*.tsx",
    "./tooling/**/test/**/*.json",
    "./tooling/**/dtslint/**/*.ts",
    "./tooling/**/dtslint/**/*.tsx",
    "./syncpack.config.ts",
    "./.claude/*.ts",
    "./.claude/*.json"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tmp/**",
    "**/test/fixtures/**",
    // Desktop owns its own test/vitest typecheck through apps/desktop/tsconfig.test.json.
    "./apps/desktop/test/**/*.ts",
    "./apps/desktop/test/**/*.tsx",
    "./apps/desktop/test/**/*.json",
    // Editor app owns its own test typecheck through apps/editor-app/tsconfig.json.
    "./apps/editor-app/test/**/*.ts",
    "./apps/editor-app/test/**/*.tsx",
    "./apps/editor-app/test/**/*.json"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.root.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "rewriteRelativeImportExtensions": false,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": ["node", "bun"],
    "paths": {
      // Path aliases allow loading internal modules in tests and using workspace packages
      // These will be populated as packages are created
      "@beep/repo-cli": ["./tooling/cli/src/index.ts"],
      "@beep/repo-cli/*": ["./tooling/cli/src/*"],
      "@beep/repo-utils": ["./tooling/repo-utils/src/index.ts"],
      "@beep/repo-utils/*": ["./tooling/repo-utils/src/*"],
      "@beep/types": ["./packages/common/types/src/index.ts"],
      "@beep/types/*": ["./packages/common/types/src/*"],
      "@beep/utils": ["./packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["./packages/common/utils/src/*"],
      "@beep/identity": ["./packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["./packages/common/identity/src/*"],
      "@beep/schema": ["./packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["./packages/common/schema/src/*"],
      "@beep/messages": ["./packages/common/messages/src/index.ts"],
      "@beep/messages/*": ["./packages/common/messages/src/*"],
      "@beep/data": ["./packages/common/data/src/index.ts"],
      "@beep/data/*": ["./packages/common/data/src/*"],
      "@beep/shared-domain": ["./packages/shared/domain/src/index.ts"],
      "@beep/shared-domain/*": ["./packages/shared/domain/src/*"],
      "@beep/shared-config": ["./packages/shared/config/src/index.ts"],
      "@beep/shared-config/*": ["./packages/shared/config/src/*"],
      "@beep/ui": ["./packages/common/ui/src/index.ts"],
      "@beep/ui/*": ["./packages/common/ui/src/*"],
      "@beep/shared-ui": ["./packages/shared/ui/src/index.ts"],
      "@beep/shared-ui/*": ["./packages/shared/ui/src/*"],
      "@beep/shared-tables": ["./packages/shared/tables/src/index.ts"],
      "@beep/shared-tables/*": ["./packages/shared/tables/src/*"],
      "@beep/shared-server": ["./packages/shared/server/src/index.ts"],
      "@beep/shared-server/*": ["./packages/shared/server/src/*"],
