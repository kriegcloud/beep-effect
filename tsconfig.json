{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [{ "path": "tsconfig.packages.json" }],
  "include": [
    "**/vitest.*.ts", // All vitest config files across all packages
    "./syncpack.config.ts",
    "./packages/*/*/test/**/*.ts",
    "./packages/*/*/test/**/*.json",
    "./packages/*/*/dtslint/**/*.ts",
    "./packages/*/*/benchmark/**/*.ts",
    "./tooling/*/test/**/*.ts",
    "./tooling/*/test/**/*.json",
    "./tooling/*/dtslint/**/*.ts",
    "./apps/*/test/**/*.ts",
    "./apps/*/test/**/*.json",
    "./.claude/*.ts",
    "./.claude/*.json"
  ],
  "exclude": [
    "./tooling/*/test/fixtures/**/*.ts",
    "./apps/*/test/**/*.ts",
    "./apps/*/test/**/*.json",
    "./apps/*/vitest.*.ts",
    "./**/dtslint/**/*.tst.*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./dist/tsconfig.root.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": ["node", "bun"],
    "paths": {
      // Path aliases allow loading internal modules in tests and using workspace packages
      // These will be populated as packages are created
      "@beep/repo-cli": ["./tooling/cli/src/index.ts"],
      "@beep/repo-cli/*": ["./tooling/cli/src/*.ts"],
      "@beep/repo-cli/test/*": ["./tooling/cli/test/*.ts"],
      "@beep/repo-utils": ["./tooling/repo-utils/src/index.ts"],
      "@beep/repo-utils/*": ["./tooling/repo-utils/src/*.ts"],
      "@beep/repo-utils/test/*": ["./tooling/utils/test/*.ts"],
      "@beep/types": ["./packages/common/types/src/index.ts"],
      "@beep/types/*": ["./packages/common/types/src/*.ts"],
      "@beep/utils": ["./packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["./packages/common/utils/src/*.ts"],
      "@beep/identity": ["./packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["./packages/common/identity/src/*.ts"],
      "@beep/schema": ["./packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["./packages/common/schema/src/*.ts"],
      "@beep/messages": ["./packages/common/messages/src/index.ts"],
      "@beep/messages/*": ["./packages/common/messages/src/*.ts"],
      "@beep/ontology": ["./packages/common/ontology/src/index.ts"],
      "@beep/ontology/*": ["./packages/common/ontology/src/*.ts"],
      "@beep/data": ["./packages/common/data/src/index.ts"],
      "@beep/data/*": ["./packages/common/data/src/*.ts"],
      "@beep/shared-domain": ["./packages/shared/domain/src/index.ts"],
      "@beep/shared-domain/*": ["./packages/shared/domain/src/*.ts"],
      "@beep/shared-env": ["./packages/shared/env/src/index.ts"],
      "@beep/shared-env/*": ["./packages/shared/env/src/*.ts"],
      "@beep/ui": ["./packages/ui/ui/src/index.ts"],
      "@beep/ui/*": ["./packages/ui/ui/src/*.ts"]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@beep/*"]
      }
    ]
  }
}
