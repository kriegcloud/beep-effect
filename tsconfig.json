{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [{ "path": "tsconfig.packages.json" }],
  "include": [
    "**/vitest.*.ts", // All vitest config files across all packages
    "./syncpack.config.ts",
    "./.claude/*.ts",
    "./.claude/*.json"
  ],
  "exclude": [
    "./tooling/*/test/fixtures/**/*.ts",
    "./apps/*/test/**/*.ts",
    "./apps/*/test/**/*.json"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./dist/tsconfig.root.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "rewriteRelativeImportExtensions": false,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": ["node", "bun"],
    "paths": {
      // Path aliases allow loading internal modules in tests and using workspace packages
      // These will be populated as packages are created
      "@beep/repo-cli": ["./tooling/cli/src/index.ts"],
      "@beep/repo-cli/*": ["./tooling/cli/src/*.ts"],
      "@beep/repo-cli/test/*": ["./tooling/cli/test/*.ts"],
      "@beep/repo-utils": ["./tooling/repo-utils/src/index.ts"],
      "@beep/repo-utils/*": ["./tooling/repo-utils/src/*.ts"],
      "@beep/repo-utils/test/*": ["./tooling/utils/test/*.ts"],
      "@beep/types": ["./packages/common/types/src/index.ts"],
      "@beep/types/*": ["./packages/common/types/src/*.ts"],
      "@beep/utils": ["./packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["./packages/common/utils/src/*.ts"],
      "@beep/identity": ["./packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["./packages/common/identity/src/*.ts"],
      "@beep/schema": ["./packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["./packages/common/schema/src/*.ts"],
      "@beep/schema/test/*": ["./packages/common/schema/test/*"],
      "@beep/messages": ["./packages/common/messages/src/index.ts"],
      "@beep/messages/*": ["./packages/common/messages/src/*.ts"],
      "@beep/data": ["./packages/common/data/src/index.ts"],
      "@beep/data/*": ["./packages/common/data/src/*.ts"],
      "@beep/ai-sdk/internal/*": ["./packages/ai/sdk/src/core/internal/*.ts"],
      "@beep/shared-domain": ["./packages/shared/domain/src/index.ts"],
      "@beep/shared-domain/*": ["./packages/shared/domain/src/*.ts"],
      "@beep/shared-env": ["./packages/shared/env/src/index.ts"],
      "@beep/shared-env/*": ["./packages/shared/env/src/*.ts"],
      "@beep/ui": ["./packages/common/ui/src/index.ts"],
      "@beep/ui/*": ["./packages/common/ui/src/*.ts"],
      "@beep/shared-ui": ["./packages/shared/ui/src/index.ts"],
      "@beep/shared-ui/*": ["./packages/shared/ui/src/*.ts"],
      "@beep/shared-tables": ["./packages/shared/tables/src/index.ts"],
      "@beep/shared-tables/*": ["./packages/shared/tables/src/*.ts"],
      "@beep/shared-server": ["./packages/shared/server/src/index.ts"],
      "@beep/shared-server/*": ["./packages/shared/server/src/*.ts"],
      "@beep/shared-client": ["./packages/shared/client/src/index.ts"],
      "@beep/shared-client/*": ["./packages/shared/client/src/*.ts"],
      "@beep/runtime-protocol": ["./packages/runtime/protocol/src/index.ts"],
      "@beep/runtime-protocol/*": ["./packages/runtime/protocol/src/*.ts"],
      "@beep/runtime-server": ["./packages/runtime/server/src/index.ts"],
      "@beep/runtime-server/*": ["./packages/runtime/server/src/*.ts"],
      "@beep/repo-memory-domain": ["./packages/repo-memory/domain/src/index.ts"],
      "@beep/repo-memory-domain/*": ["./packages/repo-memory/domain/src/*.ts"],
      "@beep/repo-memory-server": ["./packages/repo-memory/server/src/index.ts"],
      "@beep/repo-memory-server/*": ["./packages/repo-memory/server/src/*.ts"],
      "@beep/repo-memory-client": ["./packages/repo-memory/client/src/index.ts"],
      "@beep/repo-memory-client/*": ["./packages/repo-memory/client/src/*.ts"],
      "@beep/repo-memory-drivers-local": ["./packages/repo-memory/drivers-local/src/index.ts"],
      "@beep/repo-memory-drivers-local/*": ["./packages/repo-memory/drivers-local/src/*.ts"],
      "@beep/repo-configs": ["./tooling/configs/src/index.ts"],
      "@beep/repo-configs/*": [
        "./tooling/configs/src/*.ts"
      ]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@beep/*"],
        "ignoreEffectSuggestionsInTscExitCode": false
      }
    ]
  }
}
