      "@beep/semantic-web": ["./packages/common/semantic-web/src/index.ts"],
      "@beep/semantic-web/*": ["./packages/common/semantic-web/src/*"],
      "@beep/nlp": ["./packages/common/nlp/src/index.ts"],
