{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [{ "path": "tsconfig.packages.json" }],
  "include": [
    "**/vitest.*.ts", // All vitest config files across all packages
    "./syncpack.config.ts",
    "./knip.config.ts",
    "./packages/*/test/**/*.ts",
    "./packages/*/test/**/*.json",
    "./packages/*/dtslint/**/*.ts",
    "./packages/*/benchmark/**/*.ts",
    "./packages/*/*/test/**/*.ts",
    "./packages/*/*/test/**/*.json",
    "./packages/*/*/dtslint/**/*.ts",
    "./packages/*/*/benchmark/**/*.ts",
    "./tooling/*/test/**/*.ts",
    "./tooling/*/test/**/*.json",
    "./tooling/*/dtslint/**/*.ts",
    "./apps/*/test/**/*.ts",
    "./apps/*/test/**/*.json",
    "./groking-effect-v4/src/**/*.ts"
  ],
  "exclude": ["./tooling/*/test/fixtures/**/*.ts"],
  "compilerOptions": {
    "tsBuildInfoFile": "./dist/tsconfig.root.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": ["node", "bun"],
    "paths": {
      // Path aliases allow loading internal modules in tests and using workspace packages
      // These will be populated as packages are created
      "@beep/repo-cli": ["./tooling/cli/src/index.ts"],
      "@beep/repo-cli/*": ["./tooling/cli/src/*.ts"],
      "@beep/repo-cli/test/*": ["./tooling/cli/test/*.ts"],
      "@beep/repo-utils": ["./tooling/utils/src/index.ts"],
      "@beep/repo-utils/*": ["./tooling/utils/src/*.ts"],
      "@beep/repo-utils/test/*": ["./tooling/utils/test/*.ts"],
      "@beep/codebase-search": ["./tooling/codebase-search/src/index.ts"],
      "@beep/codebase-search/*": ["./tooling/codebase-search/src/*.ts"],
      "@beep/codebase-search/test/*": ["./tooling/codebase-search/test/*.ts"],
      "@beep/_test-idempotent-1771557733674": [
        "./tooling/_test-idempotent-1771557733674/src/index.ts"
      ],
      "@beep/_test-idempotent-1771557733674/*": [
        "./tooling/_test-idempotent-1771557733674/src/*.ts"
      ],
      "@beep/types": ["./packages/common/types/src/index.ts"],
      "@beep/types/*": ["./packages/common/types/src/*.ts"],
      "@beep/utils": ["./packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["./packages/common/utils/src/*.ts"],
      "@beep/_test-pkg-1771560352063": [
        "./tooling/_test-pkg-1771560352063/src/index.ts"
      ],
      "@beep/_test-pkg-1771560352063/*": [
        "./tooling/_test-pkg-1771560352063/src/*.ts"
      ],
      "@beep/_test-idempotent-1771560353205": [
        "./tooling/_test-idempotent-1771560353205/src/index.ts"
      ],
      "@beep/_test-idempotent-1771560353205/*": [
        "./tooling/_test-idempotent-1771560353205/src/*.ts"
      ],
      "@beep/_test-license-1771561808031": [
        "./tooling/_test-license-1771561808031/src/index.ts"
      ],
      "@beep/_test-license-1771561808031/*": [
        "./tooling/_test-license-1771561808031/src/*.ts"
      ]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@beep/*"]
      }
    ]
  }
}
