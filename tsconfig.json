{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "references": [
    {
      "path": "tsconfig.packages.json"
    }
  ],
  "include": [
    "**/vitest.*.ts",
    // All vitest config files across all packages
    "./apps/**/test/**/*.ts",
    "./apps/**/test/**/*.tsx",
    "./apps/**/test/**/*.json",
    "./packages/**/test/**/*.ts",
    "./packages/**/test/**/*.tsx",
    "./packages/**/test/**/*.json",
    "./packages/**/dtslint/**/*.ts",
    "./packages/**/dtslint/**/*.tsx",
    "./syncpack.config.ts",
    "./*.ts",
    "./*.json"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tmp/**",
    "**/test/fixtures/**"
  ],
