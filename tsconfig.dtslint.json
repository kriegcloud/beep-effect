{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "references": [],
  "include": [
    "./apps/**/dtslint/**/*.ts",
    "./apps/**/dtslint/**/*.tsx",
    "./packages/**/dtslint/**/*.ts",
    "./packages/**/dtslint/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tmp/**"
  ],
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": "."
  }
}
