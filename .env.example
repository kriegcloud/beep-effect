# beep-effect environment example
#
# Copy to .env only when you need local environment overrides.
# Most keys are commented so empty values do not override Effect Config defaults.
# Uncomment the keys needed for the lane you are running and fill values locally.
# Use `bun run op -- <command>` to run commands through 1Password references in .env.
#
# Tracked examples must stay commit-safe:
# - no raw secret values
# - no 1Password secret references
# - no shell interpolation

# -----------------------------------------------------------------------------
# Local repo and app runtime
# -----------------------------------------------------------------------------
# APP_NAME=
# APP_ENV=
# APP_LOG_LEVEL=
# APP_LOG_FORMAT=
# APP_API_URL=
# APP_CLIENT_URL=
# APP_AUTH_PATH=
# APP_ADMINS_EMAILS=
# APP_ADMIN_USER_IDS=
# ALLOWED_EMAILS=
# SECURITY_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# Public browser-safe app values
