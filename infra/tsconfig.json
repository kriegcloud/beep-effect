{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist-types",
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "references": [
    {
      "path": "../packages/common/identity/tsconfig.json"
    },
    {
      "path": "../packages/common/schema/tsconfig.json"
    },
    {
      "path": "../packages/common/types/tsconfig.json"
    },
    {
      "path": "../packages/common/utils/tsconfig.json"
    }
  ]
}
