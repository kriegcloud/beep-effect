{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist-types",
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
