{
  "name": "@beep/infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pulumi infrastructure workspace for beep-effect",
  "main": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./V2T": "./src/V2T.ts"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "infra"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/infra",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "check": "beep-cli check",
    "docgen": "bun run ../tooling/docgen/src/bin.ts",
    "lint": "beep-cli lint",
    "lint:fix": "beep-cli lint --fix",
    "pulumi:login:local": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi login",
    "stack:init:local": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi stack init local",
    "preview": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi preview",
    "up": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi up",
    "destroy": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi destroy",
    "refresh": "PULUMI_BACKEND_URL=${PULUMI_BACKEND_URL:-file://$PWD/../.pulumi-local/v2t-workstation} pulumi refresh",
    "test": "beep-cli test",
    "build": "beep-cli build",
    "beep:check": "tsgo -b tsconfig.json test/tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check src/ test/ dtslint/",
    "beep:lint:fix": "biome check src/ test/ dtslint/ --write",
    "audit": "beep-cli audit"
  },
  "dependencies": {
    "@1password/connect": "catalog:",
    "@beep/identity": "workspace:^",
    "@pulumi/command": "catalog:",
    "@pulumi/github": "catalog:",
    "@pulumi/kubernetes": "catalog:",
    "@pulumi/pulumi": "catalog:",
    "@pulumi/std": "catalog:",
    "@pulumi/tls": "catalog:",
    "@pulumiverse/unifi": "catalog:",
    "protobufjs": "7.5.5"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
