{
  "name": "@beep/infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pulumi infrastructure workspace for beep-effect",
  "main": "src/entry.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "infra"
  },
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "check": "tsc -b tsconfig.json",
    "docgen": "bun run ../tooling/docgen/src/bin.ts",
    "lint": "biome check src/ test/ dtslint/",
    "lint:fix": "biome check src/ test/ dtslint/ --write",
    "preview": "pulumi preview",
    "up": "pulumi up",
    "destroy": "pulumi destroy",
    "refresh": "pulumi refresh"
  },
  "dependencies": {
    "@1password/connect": "catalog:",
    "@pulumi/command": "catalog:",
    "@pulumi/github": "catalog:",
    "jsondiffpatch": "^0.7.3",
    "@pulumi/kubernetes": "catalog:",
    "@pulumi/std": "catalog:",
    "@pulumi/tls": "catalog:",
    "@pulumiverse/unifi": "catalog:",
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "@pulumi/pulumi": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
