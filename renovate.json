{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":separateMajorReleases",
    ":automergeMinor",
    ":automergeDigest",
    "schedule:weekends"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "bun": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group Effect ecosystem updates",
      "matchPackagePatterns": ["^effect", "^@effect/"],
      "groupName": "Effect ecosystem",
      "automerge": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": true
    },
    {
      "description": "Group Biome updates",
      "matchPackagePatterns": ["^@biomejs/"],
      "groupName": "Biome",
      "automerge": true
    },
    {
      "description": "Group test tooling updates",
      "matchPackageNames": [
        "vitest",
        "@vitest/coverage-v8",
        "tstyche",
        "@effect/vitest"
      ],
      "groupName": "Test tooling",
      "automerge": false
    },
    {
      "description": "Auto-merge type definition updates",
      "matchPackagePatterns": ["^@types/"],
      "automerge": true
    }
  ],
  "ignorePaths": [".repos/**"]
}
