{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "infra/**/*.ts"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/tmp/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/generated/**",
    "**/vendor/**",
    "**/*.gen.*",
    "**/*.d.ts"
  ],
  "compilerOptions": {
    "composite": false,
    "incremental": false,
    "noEmit": true,
    "rootDir": ".",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.eslint-deprecated.tsbuildinfo"
  }
}
