{
  "name": "@beep/workspace-domain",
  "version": "0.0.2",
  "description": "Workspace domain models for artifacts, candidate tasks, drafts, approvals, and context packets.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/workspace/domain",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/workspace/domain"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./entities": "./src/entities/index.ts",
    "./entities/ApprovalGate": "./src/entities/ApprovalGate/index.ts",
    "./entities/CandidateDraft": "./src/entities/CandidateDraft/index.ts",
    "./entities/CandidateProject": "./src/entities/CandidateProject/index.ts",
    "./entities/CandidateTask": "./src/entities/CandidateTask/index.ts",
    "./entities/ContextPacket": "./src/entities/ContextPacket/index.ts",
    "./entities/EmailArtifact": "./src/entities/EmailArtifact/index.ts",
    "./entities/Message": "./src/entities/Message/index.ts",
    "./entities/Thread": "./src/entities/Thread/index.ts",
    "./entities/Turn": "./src/entities/Turn/index.ts",
    "./entities/Workspace": "./src/entities/Workspace/index.ts",
    "./values": "./src/values/index.ts",
    "./values/ApprovalDecision": "./src/values/ApprovalDecision/index.ts",
    "./values/CandidateLifecycle": "./src/values/CandidateLifecycle/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/md": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/shared-domain": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
