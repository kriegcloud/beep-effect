{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../../tsconfig.json",
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/tsconfig.test.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@beep/repo-memory-drivers-local/*": ["../src/*"],
      "@beep/repo-memory-drivers-local": ["../src"]
    }
  },
  "references": [
    {
      "path": "./tsconfig.json"
    },
    {
      "path": "../domain/tsconfig.json"
    },
    {
      "path": "../../runtime/protocol/tsconfig.json"
    },
    {
      "path": "../../../tooling/test-utils/tsconfig.json"
    }
  ]
}
