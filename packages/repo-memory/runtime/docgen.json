{
  "$schema": "../../../node_modules/@effect/docgen/schema.json",
  "exclude": [
    "src/index.ts",
    "src/indexing/IndexedTypeScriptArtifacts.ts",
    "src/indexing/TypeScriptIndexRequest.ts",
    "src/retrieval/GroundedQueryResult.ts",
    "src/retrieval/QueryInterpretation.ts",
    "src/run/RepoRunService.ts",
    "src/run/RepoRunWorkflows.ts",
    "src/run/RunProjector.ts",
    "src/run/RunStateMachine.ts"
  ],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/repo-memory/runtime/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/repo-memory-runtime": [
        "../../../packages/repo-memory/runtime/src/index.ts"
      ],
      "@beep/repo-memory-runtime/*": [
        "../../../packages/repo-memory/runtime/src/*.ts"
      ],
      "@beep/identity": ["../../../packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["../../../packages/common/identity/src/*.ts"],
      "@beep/nlp": ["../../../packages/common/nlp/src/index.ts"],
      "@beep/nlp/*": ["../../../packages/common/nlp/src/*.ts"],
      "@beep/repo-memory-model": [
        "../../../packages/repo-memory/model/src/index.ts"
      ],
      "@beep/repo-memory-model/*": [
        "../../../packages/repo-memory/model/src/*.ts"
      ],
      "@beep/repo-memory-sqlite": [
        "../../../packages/repo-memory/sqlite/src/index.ts"
      ],
      "@beep/repo-memory-sqlite/*": [
        "../../../packages/repo-memory/sqlite/src/*.ts"
      ],
      "@beep/repo-memory-store": [
        "../../../packages/repo-memory/store/src/index.ts"
      ],
      "@beep/repo-memory-store/*": [
        "../../../packages/repo-memory/store/src/*.ts"
      ],
      "@beep/schema": ["../../../packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["../../../packages/common/schema/src/*.ts"],
      "@beep/semantic-web": [
        "../../../packages/common/semantic-web/src/index.ts"
      ],
      "@beep/semantic-web/*": [
        "../../../packages/common/semantic-web/src/*.ts"
      ],
      "@beep/test-utils": ["../../../tooling/test-utils/src/index.ts"],
      "@beep/test-utils/*": ["../../../tooling/test-utils/src/*.ts"],
      "@beep/types": ["../../../packages/common/types/src/index.ts"],
      "@beep/types/*": ["../../../packages/common/types/src/*.ts"],
      "@beep/utils": ["../../../packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["../../../packages/common/utils/src/*.ts"]
    }
  }
}
