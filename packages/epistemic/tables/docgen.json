      ],
      "@beep/drizzle": ["../../../packages/drivers/drizzle/src/index.ts"],
      "@beep/epistemic-domain": [
        "../../../packages/epistemic/domain/src/index.ts"
      ],
      "@beep/epistemic-domain/entities": [
        "../../../packages/epistemic/domain/src/entities/index.ts"
