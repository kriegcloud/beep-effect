{
  "name": "@beep/ai-sdk",
  "version": "0.0.0",
  "description": "The shared agent sdk library for coding harness abstractions",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "tsc -b tsconfig.json && bun run babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsc -b tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest run",
    "coverage": "vitest --coverage",
    "docgen": "bun run ../../../tooling/docgen/docgen/src/bin.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "catalog:",
    "@beep/data": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/observability": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "@cloudflare/sandbox": "catalog:",
    "@effect/ai-anthropic": "catalog:",
    "@effect/ai-openai": "catalog:",
    "@openai/codex-sdk": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/claude/index.ts",
    "./*": "./src/claude/*.ts",
    "./internal/*": "./src/claude/internal/*.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/ai/sdk"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/ai/sdk",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/claude/index.js",
      "./*": "./dist/claude/*.js",
      "./internal/*": null
    }
  }
}
