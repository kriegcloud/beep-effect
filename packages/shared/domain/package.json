{
  "name": "@beep/shared-domain",
  "version": "0.0.2",
  "description": "Shared-kernel domain language for cross-slice product concepts, values, schemas, and pure behavior.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/shared/domain",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/shared/domain"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./aggregates": "./src/aggregates.ts",
    "./entities": "./src/entities.ts",
    "./entities/Membership": "./src/entities/Membership/index.ts",
    "./entities/Organization": "./src/entities/Organization/index.ts",
    "./entities/User": "./src/entities/User/index.ts",
    "./entity": "./src/entity.ts",
    "./entity/BaseEntity": "./src/entity/BaseEntity.ts",
    "./entity/EntityId": "./src/entity/EntityId.ts",
    "./entity/EntityRef": "./src/entity/EntityRef.ts",
    "./entity/Principal": "./src/entity/Principal.ts",
    "./entity/SourceKind": "./src/entity/SourceKind.ts",
    "./entity/primitives": "./src/entity/primitives.ts",
    "./identity": "./src/identity.ts",
    "./identity/Agents": "./src/identity/Agents.ts",
    "./identity/Epistemic": "./src/identity/Epistemic.ts",
    "./identity/LawPractice": "./src/identity/LawPractice.ts",
    "./identity/Shared": "./src/identity/Shared.ts",
    "./identity/Workspace": "./src/identity/Workspace.ts",
    "./values": "./src/values.ts",
    "./values/ClaimLifecycle": "./src/values/ClaimLifecycle/index.ts",
    "./values/LocalDate": "./src/values/LocalDate/index.ts",
    "./values/OnePasswordReference": "./src/values/OnePasswordReference/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./aggregates": "./dist/aggregates.js",
      "./entities": "./dist/entities.js",
      "./entities/Membership": "./dist/entities/Membership/index.js",
      "./entities/Organization": "./dist/entities/Organization/index.js",
      "./entities/User": "./dist/entities/User/index.js",
      "./entity": "./dist/entity.js",
      "./entity/BaseEntity": "./dist/entity/BaseEntity.js",
      "./entity/EntityId": "./dist/entity/EntityId.js",
      "./entity/EntityRef": "./dist/entity/EntityRef.js",
      "./entity/Principal": "./dist/entity/Principal.js",
      "./entity/SourceKind": "./dist/entity/SourceKind.js",
      "./entity/primitives": "./dist/entity/primitives.js",
      "./identity": "./dist/identity.js",
      "./identity/Agents": "./dist/identity/Agents.js",
      "./identity/Epistemic": "./dist/identity/Epistemic.js",
      "./identity/LawPractice": "./dist/identity/LawPractice.js",
      "./identity/Shared": "./dist/identity/Shared.js",
      "./identity/Workspace": "./dist/identity/Workspace.js",
      "./values": "./dist/values.js",
      "./values/ClaimLifecycle": "./dist/values/ClaimLifecycle/index.js",
      "./values/LocalDate": "./dist/values/LocalDate/index.js",
      "./values/OnePasswordReference": "./dist/values/OnePasswordReference/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
