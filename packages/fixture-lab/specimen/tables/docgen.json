{
  "$schema": "../../../../tooling/docgen/schema.json",
  "exclude": [
    "src/internal/**/*.ts",
    "src/**/index.ts",
    "src/ReadModels.ts",
    "src/Tables.ts"
  ],
  "examplesCompilerOptions": {
    "types": ["node"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "jsx": "react-jsx",
    "paths": {
      "@beep/fixture-lab-specimen-tables": [
        "../../../../packages/fixture-lab/specimen/tables/src/index.ts"
      ],
      "@beep/fixture-lab-specimen-tables/*": [
        "../../../../packages/fixture-lab/specimen/tables/src/*.ts"
      ],
      "@beep/fixture-lab-specimen-tables/read-models": [
        "../../../../packages/fixture-lab/specimen/tables/src/ReadModels.ts"
      ],
      "@beep/fixture-lab-specimen-tables/tables": [
        "../../../../packages/fixture-lab/specimen/tables/src/Tables.ts"
      ],
      "@beep/fixture-lab-specimen-domain": [
        "../../../../packages/fixture-lab/specimen/domain/src/index.ts"
      ],
      "@beep/fixture-lab-specimen-domain/*": [
        "../../../../packages/fixture-lab/specimen/domain/src/*.ts"
      ],
      "@beep/fixture-lab-specimen-domain/entities/Specimen": [
        "../../../../packages/fixture-lab/specimen/domain/src/entities/Specimen/index.ts"
      ],
      "@beep/identity": ["../../../../packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["../../../../packages/common/identity/src/*.ts"],
      "@beep/identity/packages": [
        "../../../../packages/common/identity/src/packages.ts"
      ]
    }
  },
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/fixture-lab/specimen/tables/src/"
}
