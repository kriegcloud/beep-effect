      ],
      "@beep/fixture-lab-specimen-domain/*": [
        "../../../../packages/fixture-lab/specimen/domain/src/*.ts"
      ],
      "@beep/fixture-lab-specimen-domain/entities/Specimen": [
        "../../../../packages/fixture-lab/specimen/domain/src/entities/Specimen/index.ts"
      ],
      "@beep/fixture-lab-specimen-use-cases": [
        "../../../../packages/fixture-lab/specimen/use-cases/src/index.ts"
      ],
      "@beep/fixture-lab-specimen-use-cases/*": [
