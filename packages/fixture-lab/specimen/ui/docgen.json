{
  "$schema": "../../../../tooling/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts", "src/**/index.ts", "src/index.tsx"],
  "examplesCompilerOptions": {
    "types": ["node", "react", "react-dom"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "jsx": "react-jsx",
    "paths": {
      "@beep/fixture-lab-specimen-ui": [
        "../../../../packages/fixture-lab/specimen/ui/src/index.tsx"
      ],
      "@beep/fixture-lab-specimen-ui/*": [
        "../../../../packages/fixture-lab/specimen/ui/src/*"
      ],
      "@beep/fixture-lab-specimen-ui/entities/Specimen": [
        "../../../../packages/fixture-lab/specimen/ui/src/entities/Specimen/index.ts"
      ],
      "@beep/fixture-lab-specimen-domain": [
        "../../../../packages/fixture-lab/specimen/domain/src/index.ts"
      ],
      "@beep/fixture-lab-specimen-domain/*": [
        "../../../../packages/fixture-lab/specimen/domain/src/*.ts"
      ],
      "@beep/fixture-lab-specimen-domain/entities/Specimen": [
        "../../../../packages/fixture-lab/specimen/domain/src/entities/Specimen/index.ts"
      ]
    }
  },
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/fixture-lab/specimen/ui/src/"
}
