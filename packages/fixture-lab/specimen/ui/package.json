{
  "name": "@beep/fixture-lab-specimen-ui",
  "version": "0.0.0",
  "description": "Synthetic UI package for the Specimen architecture automation slice.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/fixture-lab/specimen/ui",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/fixture-lab/specimen/ui"
  },
  "scripts": {
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "codegen": "echo 'no codegen needed'",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../../tooling/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.tsx",
    "./entities/Specimen": "./src/entities/Specimen/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "dependencies": {
    "@beep/fixture-lab-specimen-domain": "workspace:^",
    "react": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react-dom": "catalog:"
  }
}
