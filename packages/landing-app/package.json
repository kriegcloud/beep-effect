{
    "name": "@blueprintjs/landing-app",
    "version": "6.5.1",
    "description": "Blueprint landing page",
    "private": true,
    "scripts": {
        "bundle": "webpack",
        "clean": "rm -rf dist/* || true",
        "dev": "webpack-dev-server",
        "dist": "NODE_ENV=production pnpm bundle",
        "lint": "run-p lint:scss lint:es",
        "lint:scss": "sass-lint",
        "lint:es": "es-lint",
        "lint-fix": "es-lint --fix && sass-lint --fix",
        "test": "exit 0",
        "verify": "run-p dist lint"
    },
    "dependencies": {
        "@blueprintjs/colors": "workspace:^",
        "@blueprintjs/core": "workspace:^",
        "@blueprintjs/icons": "workspace:^",
        "classnames": "catalog:",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@blueprintjs/node-build-scripts": "workspace:^",
        "@blueprintjs/stylelint-plugin": "workspace:^",
        "@blueprintjs/webpack-build-scripts": "workspace:^",
        "copy-webpack-plugin": "^12.0.2",
        "npm-run-all": "^4.1.5",
        "raw-loader": "^4.0.2",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^4.15.1"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:palantir/blueprint.git",
        "directory": "packages/landing-app"
    },
    "keywords": [
        "blueprint",
        "landing page"
    ],
    "author": "Palantir Technologies",
    "license": "Apache-2.0"
}
