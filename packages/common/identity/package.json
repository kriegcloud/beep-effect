{
  "name": "@beep/identity",
  "version": "0.0.0",
  "description": "Effect v4 identity package",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "bun run ../../../tooling/cli/src/bin.ts -- codegen --package .",
    "build": "bun run beep:build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "bun run beep:check",
    "test": "bun run beep:test",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../tooling/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "type-fest": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./packages": "./src/packages.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/common/identity"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/common/identity",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  }
}
