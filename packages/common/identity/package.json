{
  "name": "@beep/identity",
  "version": "0.0.0",
  "description": "Effect v4 identity package",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "bun run ../../../tooling/cli/src/bin.ts -- codegen --package .",
    "build": "tsc -b tsconfig.json && bun run babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "docgen": "bunx @effect/docgen",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "type-fest": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./packages": "./src/packages.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/common/identity"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/common/identity",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  }
}
