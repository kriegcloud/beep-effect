{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../../../../tsconfig.base.json",
  "include": ["experimental-server-safe.ts", "../../src/**/*.ts"],
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "rootDir": "../..",
    "sourceMap": false,
    "types": ["node"]
  }
}
