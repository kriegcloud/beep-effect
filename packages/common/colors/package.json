{
  "name": "@beep/colors",
  "version": "0.0.0",
  "description": "terminal output formatting with ANSI colors.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/common/colors",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/common/colors"
  },
  "scripts": {
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "build": "tsc -b tsconfig.json && bun run babel",
    "check": "tsc -b tsconfig.json",
    "codegen": "echo 'no codegen needed'",
    "coverage": "vitest --coverage",
    "docgen": "bun run ../../../tooling/docgen/docgen/src/bin.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "browser": {
    "./src/index.ts": "./src/Colors.browser.ts",
    "./src/Colors.ts": "./src/Colors.browser.ts",
    "./dist/index.js": "./dist/Colors.browser.js",
    "./dist/Colors.js": "./dist/Colors.browser.js"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "keywords": [
    "terminal",
    "colors",
    "formatting",
    "cli",
    "console"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
