{
  "$schema": "../../../tooling/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/common/nlp/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/nlp": ["../../../packages/common/nlp/src/index.ts"],
      "@beep/nlp/*": ["../../../packages/common/nlp/src/*.ts"],
      "@beep/nlp/Core": ["../../../packages/common/nlp/src/Core/index.ts"],
      "@beep/nlp/IdentifierText": [
        "../../../packages/common/nlp/src/IdentifierText.ts"
      ],
      "@beep/nlp/Layers": ["../../../packages/common/nlp/src/Layers/index.ts"],
      "@beep/nlp/PathText": ["../../../packages/common/nlp/src/PathText.ts"],
      "@beep/nlp/QueryText": ["../../../packages/common/nlp/src/QueryText.ts"],
      "@beep/nlp/Tools": ["../../../packages/common/nlp/src/Tools/index.ts"],
      "@beep/nlp/VariantText": [
        "../../../packages/common/nlp/src/VariantText.ts"
      ],
      "@beep/nlp/Wink": ["../../../packages/common/nlp/src/Wink/index.ts"],
      "@beep/identity": ["../../../packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["../../../packages/common/identity/src/*.ts"],
      "@beep/identity/packages": [
        "../../../packages/common/identity/src/packages.ts"
      ],
      "@beep/schema": ["../../../packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["../../../packages/common/schema/src/*.ts"],
      "@beep/types": ["../../../packages/common/types/src/index.ts"],
      "@beep/types/*": ["../../../packages/common/types/src/*.ts"],
      "@beep/utils": ["../../../packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["../../../packages/common/utils/src/*.ts"]
    }
  }
}
