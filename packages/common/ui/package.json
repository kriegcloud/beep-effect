{
  "name": "@beep/ui",
  "version": "0.0.0",
  "description": "Shared UI component library with shadcn, Tailwind v4 theme, and Storybook",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check": "tsc -b tsconfig.json",
    "test": "bunx --bun vitest run",
    "coverage": "vitest --coverage",
    "docgen": "bun run ../../../tooling/docgen/src/bin.ts",
    "lint": "biome check src/ .storybook/",
    "lint:fix": "biome check src/ .storybook/ --write",
    "test:storybook": "playwright install --only-shell chromium && vitest --config vitest.storybook.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@effect/atom-react": "catalog:",
    "@emotion/cache": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@lexical/react": "catalog:",
    "@lexical/rich-text": "catalog:",
    "@mui/material": "catalog:",
    "@mui/material-pigment-css": "catalog:",
    "@mui/x-charts": "catalog:",
    "@mui/x-data-grid": "catalog:",
    "@mui/x-date-pickers": "catalog:",
    "@mui/x-date-pickers-pro": "catalog:",
    "@mui/x-tree-view": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@pigment-css/react": "catalog:",
    "@react-three/drei": "catalog:",
    "@react-three/fiber": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "ai": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "d3": "catalog:",
    "lexical": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss-jun-layout": "catalog:",
    "tw-animate-css": "catalog:",
    "use-stick-to-bottom": "catalog:"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/d3": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "shadcn": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./themes": "./src/themes/index.ts",
    "./themes/*": "./src/themes/*.ts",
    "./styles/globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": "./src/components/*.tsx",
    "./components/blocks/editor-00/editor": "./src/components/blocks/editor-00/editor.tsx",
    "./components/editor/editor-ui/content-editable": "./src/components/editor/editor-ui/content-editable.tsx",
    "./components/editor/themes/editor-theme": "./src/components/editor/themes/editor-theme.ts",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/ui/ui"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/ui/ui",
  "sideEffects": [
    "**/*.css"
  ]
}
