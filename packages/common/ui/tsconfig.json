{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../../tsconfig.base.json",
  "include": ["src"],
  "exclude": [
    "src/components/calendar.tsx",
    "src/components/carousel.tsx",
    "src/components/command.tsx",
    "src/components/drawer.tsx",
    "src/components/field.tsx",
    "src/components/input-otp.tsx",
    "src/components/orb.tsx",
    "src/components/resizable.tsx",
    "src/components/sonner.tsx",
    "src/components/speech-input.tsx",
    "src/components/toaster.tsx",
    "src/components/tour.tsx"
  ],
  "compilerOptions": {
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "plugins": [
      {
        "name": "@effect/language-service",
        "transform": "@effect/language-service/transform",
        "namespaceImportPackages": ["effect", "@effect/*", "@beep/*"],
        "ignoreEffectSuggestionsInTscExitCode": false,
        "ignoreEffectWarningsInTscExitCode": false,
        "ignoreEffectErrorsInTscExitCode": false,
        "includeSuggestionsInTsc": true,
        "skipDisabledOptimization": false,
        "effectFn": ["span", "inferred-span", "suggested-span"],
        "importAliases": {
          "Array": "A",
          "Option": "O",
          "Predicate": "P",
          "Record": "R",
          "Schema": "S",
          "Equal": "Eq"
        },
        "diagnosticSeverity": {
          "effectFnOpportunity": "error",
          "strictBooleanExpressions": "off"
        }
      }
    ],
    "paths": {
      "@beep/ui": ["./src/index.ts"],
      "@beep/ui/*": ["./src/*"],
      "@beep/ui/lib": ["./src/lib/index.ts"],
      "@beep/ui/lib/*": ["./src/lib/*"]
    }
  }
}
