{
  "name": "@beep/editor",
  "version": "0.0.0",
  "description": "An library containing a rich text editor component built with lexical",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/editor",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/editor"
  },
  "scripts": {
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "build": "tsc -b tsconfig.json && bun run babel",
    "check": "tsc -b tsconfig.json",
    "codegen": "echo 'no codegen needed'",
    "coverage": "vitest --coverage",
    "docgen": "bunx @effect/docgen",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@beep/data": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/messages": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/ui": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/atom-react": "catalog:",
    "@lexical/code": "catalog:",
    "@lexical/headless": "catalog:",
    "@lexical/link": "catalog:",
    "@lexical/list": "catalog:",
    "@lexical/markdown": "catalog:",
    "@lexical/overflow": "catalog:",
    "@lexical/react": "catalog:",
    "@lexical/rich-text": "catalog:",
    "@lexical/selection": "catalog:",
    "@lexical/table": "catalog:",
    "@lexical/utils": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cytoscape": "catalog:",
    "effect": "catalog:",
    "lexical": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "shadcn": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:"
  }
}
