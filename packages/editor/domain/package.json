{
  "name": "@beep/editor-domain",
  "version": "0.0.0",
  "description": "Canonical editor document model and shared transforms for the local-first editor app",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/editor/domain",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/editor/domain"
  },
  "scripts": {
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "build": "beep-cli build",
    "check": "beep-cli check",
    "codegen": "echo 'no codegen needed'",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../tooling/docgen/src/bin.ts",
    "lint": "beep-cli lint",
    "lint:fix": "beep-cli lint --fix",
    "test": "beep-cli test",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "audit": "beep-cli audit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:",
    "lexical": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
