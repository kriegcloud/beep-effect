{
  "$schema": "../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/beep-effect/beep-effect/tree/main/packages/architecture-lab/config/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/architecture-lab-config": [
        "../../../packages/architecture-lab/config/src/index.ts"
      ],
      "@beep/architecture-lab-config/public": [
        "../../../packages/architecture-lab/config/src/public.ts"
      ],
      "@beep/architecture-lab-config/server": [
        "../../../packages/architecture-lab/config/src/server.ts"
      ],
      "@beep/architecture-lab-config/secrets": [
        "../../../packages/architecture-lab/config/src/secrets.ts"
      ],
      "@beep/architecture-lab-config/layer": [
        "../../../packages/architecture-lab/config/src/layer.ts"
      ],
      "@beep/architecture-lab-config/test": [
        "../../../packages/architecture-lab/config/src/test.ts"
      ],
      "@beep/architecture-lab-config/aggregates/WorkItem": [
        "../../../packages/architecture-lab/config/src/aggregates/WorkItem/index.ts"
      ],
      "@beep/identity": [
        "../../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "../../../packages/foundation/modeling/identity/src/*.ts"
      ],
      "@beep/identity/packages": [
        "../../../packages/foundation/modeling/identity/src/packages.ts"
      ]
    }
  }
}
