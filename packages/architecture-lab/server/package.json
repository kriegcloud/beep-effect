{
  "name": "@beep/architecture-lab-server",
  "version": "0.0.2",
  "description": "Architecture-lab server adapter package for WorkItem repositories, handlers, and Layers.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/architecture-lab/server",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/architecture-lab/server"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    ".": "./src/index.ts",
    "./layer": "./src/Layer.ts",
    "./test": "./src/test.ts",
    "./aggregates/WorkItem": "./src/aggregates/WorkItem/index.ts",
    "./entities/Worker": "./src/entities/Worker/index.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.ts",
      "./layer": "./dist/Layer.js",
      "./test": "./dist/test.js",
      "./aggregates/WorkItem": "./dist/aggregates/WorkItem/index.js",
      "./entities/Worker": "./dist/entities/Worker/index.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/architecture-lab-config": "workspace:^",
    "@beep/architecture-lab-domain": "workspace:^",
    "@beep/architecture-lab-tables": "workspace:^",
    "@beep/architecture-lab-use-cases": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/postgres": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "drizzle-orm": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/test-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
