{
  "name": "@beep/postgres",
  "version": "0.0.2",
  "description": "Driver-level Postgres runtime, diagnostics, and Drizzle Effect composition.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/drivers/postgres",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/drivers/postgres"
  },
  "beep": {
    "family": "drivers"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run type-test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "TESTCONTAINERS_RYUK_DISABLED=true bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "TESTCONTAINERS_RYUK_DISABLED=true bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "dtslint": "bunx tstyche --config ../../../tstyche.json --root ../../.. packages/drivers/postgres/dtslint/Postgres.tst.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration",
    "type-test": "bun run dtslint"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/PostgresClient.service.ts",
    "./drizzle": "./src/PostgresDrizzle.service.ts",
    "./errors": "./src/Postgres.errors.ts",
    "./format": "./src/PostgresDiagnostics.service.ts",
    "./interop": "./src/PostgresInterop.models.ts",
    "./sqlstate": "./src/PostgresSqlState.models.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./client": "./dist/PostgresClient.service.js",
      "./drizzle": "./dist/PostgresDrizzle.service.js",
      "./errors": "./dist/Postgres.errors.js",
      "./format": "./dist/PostgresDiagnostics.service.js",
      "./interop": "./dist/PostgresInterop.models.js",
      "./sqlstate": "./dist/PostgresSqlState.models.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/colors": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/sql-pg": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "sql-formatter": "catalog:"
  },
  "devDependencies": {
    "@beep/test-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
