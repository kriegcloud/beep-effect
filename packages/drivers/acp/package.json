{
  "name": "@beep/acp",
  "version": "0.0.3",
  "description": "Effect-native Agent Client Protocol driver",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/drivers/acp",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/drivers/acp"
  },
  "beep": {
    "family": "drivers"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:check:tests && bun run beep:test && bun run beep:test:integration && bun run type-test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json && tsgo -p tsconfig.scripts.json --noEmit",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "codegen": "bun run generate",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "dtslint": "bunx tstyche --config ../../../tstyche.json --root ../../.. packages/drivers/acp/dtslint/Acp.tst.ts",
    "generate": "bun run scripts/generate.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration",
    "type-test": "bun run dtslint"
  },
  "exports": {
    ".": "./src/index.ts",
    "./agent": "./src/AcpAgent.service.ts",
    "./client": "./src/AcpClient.service.ts",
    "./errors": "./src/Acp.errors.ts",
    "./protocol": "./src/AcpProtocol.service.ts",
    "./rpc": "./src/AcpRpc.models.ts",
    "./schema": "./src/Acp.models.ts",
    "./terminal": "./src/AcpTerminal.models.ts",
    "./_generated/*": null,
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./agent": "./dist/AcpAgent.service.js",
      "./client": "./dist/AcpClient.service.js",
      "./errors": "./dist/Acp.errors.js",
      "./protocol": "./dist/AcpProtocol.service.js",
      "./rpc": "./dist/AcpRpc.models.js",
      "./schema": "./dist/Acp.models.js",
      "./terminal": "./dist/AcpTerminal.models.js",
      "./_generated/*": null,
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/openapi-generator": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "catalog:"
  }
}
