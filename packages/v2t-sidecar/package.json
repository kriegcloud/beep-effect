  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/runtime-protocol": "workspace:^",
    "@beep/schema": "workspace:^",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/types": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
