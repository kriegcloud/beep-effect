{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@beep/ui": ["./src/index.ts"],
      "@beep/ui/*": ["./src/*"],
      "@beep/ui/lib": ["./src/lib/index.ts"],
      "@beep/ui/lib/*": ["./src/lib/*"]
    }
  },
  "references": [
    {
      "path": "../../modeling/schema/tsconfig.json"
    },
    {
      "path": "../../modeling/utils/tsconfig.json"
    }
  ]
}
