{
  "name": "@beep/ui",
  "version": "0.1.2",
  "description": "Shared UI component library with shadcn primitives and the Tailwind v4 theme",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "test": "bun run beep:test",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:stories",
    "beep:check:stories": "tsc -p tsconfig.stories.json --noEmit",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check src/",
    "beep:lint:fix": "biome check src/ --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@beep/utils": "workspace:^",
    "@effect/atom-react": "catalog:",
    "@elevenlabs/client": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@lexical/react": "catalog:",
    "@lexical/rich-text": "catalog:",
    "@mui/material": "catalog:",
    "@mui/x-data-grid": "catalog:",
    "@mui/x-date-pickers": "catalog:",
    "@mui/x-date-pickers-pro": "catalog:",
    "@mui/x-tree-view": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@pigment-css/react": "catalog:",
    "@react-three/drei": "catalog:",
    "@react-three/fiber": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "d3": "catalog:",
    "effect": "catalog:",
    "embla-carousel-react": "catalog:",
    "framer-motion": "catalog:",
    "input-otp": "catalog:",
    "lexical": "catalog:",
    "next-themes": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss-jun-layout": "catalog:",
    "three": "catalog:",
    "tw-animate-css": "catalog:",
    "use-stick-to-bottom": "catalog:",
    "vaul": "catalog:"
  },
  "devDependencies": {
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/d3": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "^19",
    "react-dom": "^19"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./themes": "./src/themes/index.ts",
    "./themes/theme-init-script": "./src/themes/theme-init-script.tsx",
    "./themes/*": "./src/themes/*.ts",
    "./styles/globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": "./src/components/*.tsx",
    "./components/blocks/editor-00/editor": "./src/components/blocks/editor-00/editor.tsx",
    "./components/blocks/editor-00/nodes": "./src/components/blocks/editor-00/nodes.ts",
    "./components/editor/editor-ui/content-editable": "./src/components/editor/editor-ui/content-editable.tsx",
    "./components/editor/themes/editor-theme": "./src/components/editor/themes/editor-theme.ts",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/foundation/ui-system/ui"
  },
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/foundation/ui-system/ui",
  "beep": {
    "family": "foundation",
    "kind": "ui-system"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
