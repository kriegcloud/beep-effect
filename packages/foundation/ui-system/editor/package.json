{
  "name": "@beep/editor",
  "version": "0.0.0",
  "description": "React editor kit on Lexical for schema-first rich text",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/foundation/ui-system/editor",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/foundation/ui-system/editor"
  },
  "beep": {
    "family": "foundation",
    "kind": "ui-system"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:tests && bun run beep:check:stories",
    "beep:check:stories": "tsc -p tsconfig.stories.json --noEmit",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    ".": "./src/index.ts",
    "./artifact-ref-node": "./src/artifact-ref-node.tsx",
    "./chat": "./src/chat/index.ts",
    "./composer": "./src/composer.tsx",
    "./mermaid-code-decorator-plugin": "./src/mermaid-code-decorator-plugin.tsx",
    "./mermaid-view": "./src/mermaid-view.tsx",
    "./nodes": "./src/nodes.ts",
    "./theme": "./src/theme.ts",
    "./viewer": "./src/viewer.tsx",
    "./youtube-embed": "./src/youtube-embed.tsx",
    "./youtube-node": "./src/youtube-node.tsx",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./artifact-ref-node": "./dist/artifact-ref-node.js",
      "./chat": "./dist/chat/index.js",
      "./composer": "./dist/composer.js",
      "./mermaid-code-decorator-plugin": "./dist/mermaid-code-decorator-plugin.js",
      "./mermaid-view": "./dist/mermaid-view.js",
      "./nodes": "./dist/nodes.js",
      "./theme": "./dist/theme.js",
      "./viewer": "./dist/viewer.js",
      "./youtube-embed": "./dist/youtube-embed.js",
      "./youtube-node": "./dist/youtube-node.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/lexical-schema": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/ui": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/atom-react": "catalog:",
    "@lexical/code": "catalog:",
    "@lexical/link": "catalog:",
    "@lexical/list": "catalog:",
    "@lexical/markdown": "catalog:",
    "@lexical/react": "catalog:",
    "@lexical/rich-text": "catalog:",
    "@lexical/selection": "catalog:",
    "@lexical/table": "catalog:",
    "@lexical/utils": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "effect": "catalog:",
    "lexical": "catalog:",
    "mermaid": "catalog:"
  },
  "devDependencies": {
    "@beep/md": "workspace:^",
    "@effect/vitest": "catalog:",
    "@lexical/headless": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "storybook": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
