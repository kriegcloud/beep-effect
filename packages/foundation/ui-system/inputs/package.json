{
  "name": "@beep/inputs",
  "version": "0.0.0",
  "description": "Input components and primitives for Beep UI surfaces",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/foundation/ui-system/inputs",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/foundation/ui-system/inputs"
  },
  "beep": {
    "family": "foundation",
    "kind": "ui-system"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:tests && bun run beep:check:stories",
    "beep:check:stories": "tsc -p tsconfig.stories.json --noEmit",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "repo-exports:shard": "beep-cli quality repo-exports-catalog --package-shard",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@tanstack/react-form": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@tanstack/react-form-devtools": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
