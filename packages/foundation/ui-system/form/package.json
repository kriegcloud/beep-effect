{
  "name": "@beep/form",
  "version": "0.0.0",
  "description": "Schema-first, effect-first form substrate on @tanstack/react-form bound to @beep/ui primitives",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/foundation/ui-system/form",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/foundation/ui-system/form"
  },
  "beep": {
    "family": "foundation",
    "kind": "ui-system"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:tests && bun run beep:check:stories",
    "beep:check:stories": "tsc -p tsconfig.stories.json --noEmit",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "repo-exports:shard": "beep-cli quality repo-exports-catalog --package-shard",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./core/*": "./src/core/*.ts",
    "./fields/*": "./src/fields/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.tsx",
    "./internal/*": null
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "sideEffects": [],
  "dependencies": {
    "@beep/schema": "workspace:^",
    "@beep/ui": "workspace:^",
    "@tanstack/react-form": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "storybook": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
