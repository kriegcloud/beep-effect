{
  "name": "@beep/nlp",
  "version": "0.0.1",
  "description": "An library containing utilities, schemas & services for natural language processing",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/foundation/capability/nlp",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/foundation/capability/nlp"
  },
  "scripts": {
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "codegen": "echo 'no codegen needed'",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./Algebra": "./src/Algebra/index.ts",
    "./Algebra/*": "./src/Algebra/*.ts",
    "./Backend": "./src/Backend/index.ts",
    "./Backend/*": "./src/Backend/*.ts",
    "./Core": "./src/Core/index.ts",
    "./Core/*": "./src/Core/*.ts",
    "./Graph": "./src/Graph/index.ts",
    "./Graph/GraphOperations": "./src/Graph/GraphOperations/index.ts",
    "./Graph/*": "./src/Graph/*.ts",
    "./Handoff": "./src/Handoff/index.ts",
    "./Handoff/*": "./src/Handoff/*.ts",
    "./IdentifierText": "./src/IdentifierText.ts",
    "./internal/*": null,
    "./Layers": "./src/Layers/index.ts",
    "./Layers/*": "./src/Layers/*.ts",
    "./NLPService": "./src/NLPService.ts",
    "./Ontology": "./src/Ontology/index.ts",
    "./Ontology/*": "./src/Ontology/*.ts",
    "./Operations": "./src/Operations/index.ts",
    "./Operations/*": "./src/Operations/*.ts",
    "./package.json": "./package.json",
    "./PathText": "./src/PathText.ts",
    "./QueryText": "./src/QueryText.ts",
    "./Tools": "./src/Tools/index.ts",
    "./Tools/*": "./src/Tools/*.ts",
    "./VariantText": "./src/VariantText.ts",
    "./Wink": "./src/Wink/index.ts",
    "./Wink/*": "./src/Wink/*.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.ts",
      "./Algebra": "./dist/Algebra/index.js",
      "./Algebra/*": "./dist/Algebra/*.js",
      "./Backend": "./dist/Backend/index.js",
      "./Backend/*": "./dist/Backend/*.js",
      "./Core": "./dist/Core/index.js",
      "./Core/*": "./dist/Core/*.js",
      "./Graph": "./dist/Graph/index.js",
      "./Graph/GraphOperations": "./dist/Graph/GraphOperations/index.js",
      "./Graph/*": "./dist/Graph/*.js",
      "./Handoff": "./dist/Handoff/index.js",
      "./Handoff/*": "./dist/Handoff/*.js",
      "./IdentifierText": "./dist/IdentifierText.js",
      "./internal/*": null,
      "./Layers": "./dist/Layers/index.js",
      "./Layers/*": "./dist/Layers/*.js",
      "./NLPService": "./dist/NLPService.js",
      "./Ontology": "./dist/Ontology/index.js",
      "./Ontology/*": "./dist/Ontology/*.js",
      "./Operations": "./dist/Operations/index.js",
      "./Operations/*": "./dist/Operations/*.js",
      "./package.json": "./package.json",
      "./PathText": "./dist/PathText.js",
      "./QueryText": "./dist/QueryText.js",
      "./Tools": "./dist/Tools/index.js",
      "./Tools/*": "./dist/Tools/*.js",
      "./VariantText": "./dist/VariantText.js",
      "./Wink": "./dist/Wink/index.js",
      "./Wink/*": "./dist/Wink/*.js"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:",
    "wink-eng-lite-web-model": "catalog:",
    "wink-nlp": "catalog:",
    "wink-nlp-utils": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "beep": {
    "family": "foundation",
    "kind": "capability"
  }
}
