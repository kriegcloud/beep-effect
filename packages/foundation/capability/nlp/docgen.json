{
  "$schema": "../../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/foundation/capability/nlp/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/nlp": [
        "../../../../packages/foundation/capability/nlp/src/index.ts"
      ],
      "@beep/nlp/Core": [
        "../../../../packages/foundation/capability/nlp/src/Core/index.ts"
      ],
      "@beep/nlp/IdentifierText": [
        "../../../../packages/foundation/capability/nlp/src/IdentifierText.ts"
      ],
      "@beep/nlp/Layers": [
        "../../../../packages/foundation/capability/nlp/src/Layers/index.ts"
      ],
      "@beep/nlp/PathText": [
        "../../../../packages/foundation/capability/nlp/src/PathText.ts"
      ],
      "@beep/nlp/QueryText": [
        "../../../../packages/foundation/capability/nlp/src/QueryText.ts"
      ],
      "@beep/nlp/Tools": [
        "../../../../packages/foundation/capability/nlp/src/Tools/index.ts"
      ],
      "@beep/nlp/VariantText": [
        "../../../../packages/foundation/capability/nlp/src/VariantText.ts"
      ],
      "@beep/nlp/Wink": [
        "../../../../packages/foundation/capability/nlp/src/Wink/index.ts"
      ],
      "@beep/identity": [
        "../../../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "../../../../packages/foundation/modeling/identity/src/*.ts"
      ],
      "@beep/identity/packages": [
        "../../../../packages/foundation/modeling/identity/src/packages.ts"
      ],
      "@beep/schema": [
        "../../../../packages/foundation/modeling/schema/src/index.ts"
      ],
      "@beep/schema/*": [
        "../../../../packages/foundation/modeling/schema/src/*.ts"
      ],
      "@beep/schema/color": [
        "../../../../packages/foundation/modeling/schema/src/color/index.ts"
      ],
      "@beep/schema/csv/parse": [
        "../../../../packages/foundation/modeling/schema/src/csv/parse/index.ts"
      ],
      "@beep/schema/dom": [
        "../../../../packages/foundation/modeling/schema/src/dom/index.ts"
      ],
      "@beep/schema/internal/markdown": [
        "../../../../packages/foundation/modeling/schema/src/internal/markdown.ts"
      ],
      "@beep/schema/internal/yaml": [
        "../../../../packages/foundation/modeling/schema/src/internal/yaml.ts"
      ],
      "@beep/types": [
        "../../../../packages/foundation/primitive/types/src/index.ts"
      ],
      "@beep/types/*": [
        "../../../../packages/foundation/primitive/types/src/*.ts"
      ],
      "@beep/utils": [
        "../../../../packages/foundation/modeling/utils/src/index.ts"
      ],
      "@beep/utils/*": [
        "../../../../packages/foundation/modeling/utils/src/*.ts"
      ]
    }
  }
}
