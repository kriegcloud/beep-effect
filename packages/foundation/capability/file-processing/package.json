{
  "name": "@beep/file-processing",
  "version": "0.0.0",
  "description": "Runtime-neutral schema-first file processing capability contracts and manifest models",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/foundation/capability/file-processing",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/foundation/capability/file-processing"
  },
  "beep": {
    "family": "foundation",
    "kind": "capability"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:tests",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    ".": "./src/index.ts",
    "./Artifact": "./src/Artifact/index.ts",
    "./Extraction": "./src/Extraction/index.ts",
    "./Operation": "./src/Operation/index.ts",
    "./PathSafety": "./src/PathSafety/index.ts",
    "./Service": "./src/Service/index.ts",
    "./Strategy": "./src/Strategy/index.ts",
    "./test": "./src/test.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./Artifact": "./dist/Artifact/index.js",
      "./Extraction": "./dist/Extraction/index.js",
      "./Operation": "./dist/Operation/index.js",
      "./PathSafety": "./dist/PathSafety/index.js",
      "./Service": "./dist/Service/index.js",
      "./Strategy": "./dist/Strategy/index.js",
      "./test": "./dist/test.js",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
