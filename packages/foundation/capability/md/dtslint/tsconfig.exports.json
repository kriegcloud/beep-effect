{
  "$schema": "http://json.schemastore.org/tsconfig",
  "include": ["./exports.tst.ts"],
  "exclude": [],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": false,
    "incremental": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  }
}
