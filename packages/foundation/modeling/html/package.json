{
  "name": "@beep/html",
  "version": "0.0.0",
  "description": "HTML modeling package",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/foundation/modeling/html",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/foundation/modeling/html"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:test:integration && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json && bun run beep:check:tests && bun run beep:check:scripts",
    "beep:check:scripts": "tsgo -p tsconfig.scripts.json --noEmit",
    "beep:check:tests": "tsgo -p tsconfig.test.json --noEmit",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run --passWithNoTests --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "check:scripts": "bun run beep:check:scripts",
    "coverage": "bunx --bun vitest run --coverage --passWithNoTests --exclude=test/integration/**",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "generate": "bun run scripts/generate.ts && biome check --write src/Html.model.ts src/Html.meta.ts",
    "generate:check": "bun run generate && git diff --exit-code -- src/Html.model.ts src/Html.meta.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "beep": {
    "family": "foundation",
    "kind": "modeling"
  }
}
