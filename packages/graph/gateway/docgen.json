{
  "$schema": "../../../tooling/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/graph/gateway/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/graph-gateway": ["../../../packages/graph/gateway/src/index.ts"],
      "@beep/graph-gateway/*": ["../../../packages/graph/gateway/src/*.ts"],
      "@beep/graph-schema": ["../../../packages/graph/schema/src/index.ts"],
      "@beep/graph-schema/*": ["../../../packages/graph/schema/src/*.ts"],
      "@beep/observability": ["../../../packages/common/observability/src/index.ts"],
      "@beep/observability/*": ["../../../packages/common/observability/src/*.ts"],
      "@beep/observability/server": [
        "../../../packages/common/observability/src/server/index.ts"
      ]
    }
  }
}
