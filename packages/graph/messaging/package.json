{
  "name": "@beep/graph-messaging",
  "version": "0.0.0",
  "description": "Effect-based NATS messaging primitives for Beep Graph (Producer, Consumer, RequestResponse)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "tsc -b tsconfig.json && bun run babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "bunx --bun vitest run",
    "docgen": "bun run ../../../tooling/docgen/src/bin.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "effect": "catalog:",
    "nats": "^2.29.1"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/graph/messaging"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/graph/messaging",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  }
}
