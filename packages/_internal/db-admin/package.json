{
  "name": "@beep/db-admin",
  "version": "0.0.0",
  "description": "The internal db-admin for migrations",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "beep-cli build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "beep-cli check",
    "lint": "beep-cli lint",
    "lint:fix": "beep-cli lint --fix",
    "test": "beep-cli test",
    "coverage": "bunx --bun vitest --coverage",
    "docgen": "bun run ../../../tooling/docgen/src/bin.ts",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "audit": "beep-cli audit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/_internal/db-admin"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/_internal/db-admin",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  }
}
