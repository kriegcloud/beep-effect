{
  "name": "@beep/db-admin",
  "version": "0.0.0",
  "description": "The internal db-admin for migrations",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "bun run beep:build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "bun run beep:check",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:test:integration": "bunx --bun vitest run test/integration --passWithNoTests",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "@beep/architecture-lab-tables": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@beep/postgres": "workspace:^",
    "@beep/test-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "packages/_internal/db-admin"
  },
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/packages/_internal/db-admin",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  }
}
