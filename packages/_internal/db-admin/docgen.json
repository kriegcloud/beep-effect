{
  "$schema": "../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/_internal/db-admin/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/db-admin": ["../../../packages/_internal/db-admin/src/index.ts"],
      "@beep/db-admin/*": ["../../../packages/_internal/db-admin/src/*.ts"],
      "@beep/architecture-lab-tables": [
        "../../../packages/architecture-lab/tables/src/index.ts"
      ],
      "@beep/architecture-lab-tables/tables": [
        "../../../packages/architecture-lab/tables/src/tables.ts"
      ],
      "@beep/architecture-lab-tables/aggregates/WorkItem": [
        "../../../packages/architecture-lab/tables/src/aggregates/WorkItem/index.ts"
      ],
      "@beep/architecture-lab-tables/entities/Worker": [
        "../../../packages/architecture-lab/tables/src/entities/Worker/index.ts"
      ],
      "@beep/postgres": ["../../../packages/drivers/postgres/src/index.ts"],
      "@beep/postgres/client": [
        "../../../packages/drivers/postgres/src/PostgresClient.service.ts"
      ],
      "@beep/postgres/drizzle": [
        "../../../packages/drivers/postgres/src/PostgresDrizzle.service.ts"
      ],
      "@beep/postgres/errors": [
        "../../../packages/drivers/postgres/src/Postgres.errors.ts"
      ],
      "@beep/postgres/format": [
        "../../../packages/drivers/postgres/src/PostgresDiagnostics.service.ts"
      ],
      "@beep/postgres/interop": [
        "../../../packages/drivers/postgres/src/PostgresInterop.models.ts"
      ],
      "@beep/postgres/sqlstate": [
        "../../../packages/drivers/postgres/src/PostgresSqlState.models.ts"
      ],
      "@beep/test-utils": [
        "../../../packages/tooling/test-kit/test-utils/src/index.ts"
      ],
      "@beep/test-utils/*": [
        "../../../packages/tooling/test-kit/test-utils/src/*.ts"
      ],
      "@beep/utils": [
        "../../../packages/foundation/modeling/utils/src/index.ts"
      ],
      "@beep/utils/*": ["../../../packages/foundation/modeling/utils/src/*.ts"]
    }
  }
}
