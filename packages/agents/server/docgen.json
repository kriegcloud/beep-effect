{
  "$schema": "../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/agents/server/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/agents-server": ["../../../packages/agents/server/src/index.ts"],
      "@beep/agents-server/test": [
        "../../../packages/agents/server/src/test.ts"
      ],
      "@beep/agents-server/AssistantTurn": [
        "../../../packages/agents/server/src/AssistantTurn/index.ts"
      ],
      "@beep/agents-server/AnthropicTurnCodec": [
        "../../../packages/agents/server/src/AssistantTurn/AnthropicTurnCodec.ts"
      ],
      "@beep/agents-server/AnthropicTurnKernel": [
        "../../../packages/agents/server/src/AssistantTurn/AnthropicTurnKernel.ts"
      ],
      "@beep/agents-domain": ["../../../packages/agents/domain/src/index.ts"],
      "@beep/agents-domain/entities": [
        "../../../packages/agents/domain/src/entities/index.ts"
      ],
      "@beep/agents-domain/entities/Agent": [
        "../../../packages/agents/domain/src/entities/Agent/index.ts"
      ],
      "@beep/agents-domain/entities/Skill": [
        "../../../packages/agents/domain/src/entities/Skill/index.ts"
      ],
      "@beep/agents-domain/values": [
        "../../../packages/agents/domain/src/values/index.ts"
      ],
      "@beep/agents-domain/values/AssistantContent": [
        "../../../packages/agents/domain/src/values/AssistantContent/index.ts"
      ],
      "@beep/agents-use-cases": [
        "../../../packages/agents/use-cases/src/index.ts"
      ],
      "@beep/agents-use-cases/public": [
        "../../../packages/agents/use-cases/src/public.ts"
      ],
      "@beep/agents-use-cases/server": [
        "../../../packages/agents/use-cases/src/server.ts"
      ],
      "@beep/agents-use-cases/proof": [
        "../../../packages/agents/use-cases/src/proof.ts"
      ],
      "@beep/agents-use-cases/test": [
        "../../../packages/agents/use-cases/src/test.ts"
      ],
      "@beep/anthropic": ["../../../packages/drivers/anthropic/src/index.ts"],
      "@beep/identity": [
        "../../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "../../../packages/foundation/modeling/identity/src/*.ts"
      ],
      "@beep/identity/packages": [
        "../../../packages/foundation/modeling/identity/src/packages.ts"
      ],
      "@beep/test-utils": [
        "../../../packages/tooling/test-kit/test-utils/src/index.ts"
      ],
      "@beep/test-utils/*": [
        "../../../packages/tooling/test-kit/test-utils/src/*.ts"
      ]
    }
  }
}
