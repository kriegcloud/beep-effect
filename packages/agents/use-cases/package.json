{
  "name": "@beep/agents-use-cases",
  "version": "0.0.2",
  "description": "Agents SDK contracts and deterministic proof fixture-runner helpers.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/agents/use-cases",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/agents/use-cases"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "tsc -b tsconfig.json",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./public": "./src/public.ts",
    "./server": "./src/server.ts",
    "./proof": "./src/proof.ts",
    "./test": "./src/test.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "sideEffects": [],
  "dependencies": {
    "@beep/agents-domain": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/md": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/shared-domain": "workspace:^",
    "@beep/utils": "workspace:^",
    "@beep/workspace-domain": "workspace:^",
    "@beep/workspace-use-cases": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
