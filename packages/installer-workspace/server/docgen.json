{
  "$schema": "../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/installer-workspace/server/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/installer-workspace-server": [
        "../../../packages/installer-workspace/server/src/index.ts"
      ],
      "@beep/installer-workspace-server/layer": [
        "../../../packages/installer-workspace/server/src/Layer.ts"
      ],
      "@beep/installer-workspace-server/test": [
        "../../../packages/installer-workspace/server/src/test.ts"
      ],
      "@beep/identity": [
        "../../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "../../../packages/foundation/modeling/identity/src/*.ts"
      ],
      "@beep/identity/packages": [
        "../../../packages/foundation/modeling/identity/src/packages.ts"
      ],
      "@beep/installer-workspace-domain": [
        "../../../packages/installer-workspace/domain/src/index.ts"
      ],
      "@beep/installer-workspace-domain/aggregates": [
        "../../../packages/installer-workspace/domain/src/aggregates/index.ts"
      ],
      "@beep/installer-workspace-domain/entities": [
        "../../../packages/installer-workspace/domain/src/entities/index.ts"
      ],
      "@beep/installer-workspace-domain/identity": [
        "../../../packages/installer-workspace/domain/src/identity/index.ts"
      ],
      "@beep/installer-workspace-domain/values": [
        "../../../packages/installer-workspace/domain/src/values/index.ts"
      ],
      "@beep/installer-workspace-use-cases": [
        "../../../packages/installer-workspace/use-cases/src/index.ts"
      ],
      "@beep/installer-workspace-use-cases/public": [
        "../../../packages/installer-workspace/use-cases/src/public.ts"
      ],
      "@beep/installer-workspace-use-cases/server": [
        "../../../packages/installer-workspace/use-cases/src/server.ts"
      ],
      "@beep/schema": [
        "../../../packages/foundation/modeling/schema/src/index.ts"
      ],
      "@beep/schema/*": [
        "../../../packages/foundation/modeling/schema/src/*.ts"
      ]
    }
  }
}
