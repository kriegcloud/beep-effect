{
  "$schema": "../../../../packages/tooling/tool/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts", "src/**/*.test.ts", "src/**/*.spec.ts"],
  "enforceDescriptions": true,
  "enforceVersion": true,
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/packages/tooling/tool/cli/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/repo-cli": ["../../../../packages/tooling/tool/cli/src/index.ts"],
      "@beep/repo-cli/*": ["../../../../packages/tooling/tool/cli/src/*.ts"],
      "@beep/chalk": [
        "../../../../packages/foundation/capability/chalk/src/index.ts"
      ],
      "@beep/chalk/*": [
        "../../../../packages/foundation/capability/chalk/src/*.ts"
      ],
      "@beep/ffmpeg": ["../../../../packages/drivers/ffmpeg/src/index.ts"],
      "@beep/ffmpeg/*": ["../../../../packages/drivers/ffmpeg/src/*.ts"],
      "@beep/identity": [
        "../../../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": [
        "../../../../packages/foundation/modeling/identity/src/*.ts"
      ],
      "@beep/identity/packages": [
        "../../../../packages/foundation/modeling/identity/src/packages.ts"
      ],
      "@beep/observability": [
        "../../../../packages/foundation/capability/observability/src/index.ts"
      ],
      "@beep/observability/experimental/server": [
        "../../../../packages/foundation/capability/observability/src/experimental/server/index.ts"
      ],
      "@beep/observability/server": [
        "../../../../packages/foundation/capability/observability/src/server/index.ts"
      ],
      "@beep/observability/web": [
        "../../../../packages/foundation/capability/observability/src/web/index.ts"
      ],
      "@beep/repo-ai-metrics": [
        "../../../../packages/tooling/library/ai-metrics/src/index.ts"
      ],
      "@beep/repo-ai-metrics/*": [
        "../../../../packages/tooling/library/ai-metrics/src/*.ts"
      ],
      "@beep/repo-configs": [
        "../../../../packages/tooling/policy-pack/repo-configs/src/index.ts"
      ],
      "@beep/repo-configs/*": [
        "../../../../packages/tooling/policy-pack/repo-configs/src/*.ts"
      ],
      "@beep/repo-configs/next": [
        "../../../../packages/tooling/policy-pack/repo-configs/src/next/index.ts"
      ],
      "@beep/repo-docgen": [
        "../../../../packages/tooling/tool/docgen/src/index.ts"
      ],
      "@beep/repo-docgen/*": [
        "../../../../packages/tooling/tool/docgen/src/*.ts"
      ],
      "@beep/repo-docgen/schema.json": [
        "../../../../packages/tooling/tool/docgen/schema.json"
      ],
      "@beep/repo-utils": [
        "../../../../packages/tooling/library/repo-utils/src/index.ts"
      ],
      "@beep/repo-utils/*": [
        "../../../../packages/tooling/library/repo-utils/src/*.ts"
      ],
      "@beep/repo-utils/JSDoc/models/tag-values": [
        "../../../../packages/tooling/library/repo-utils/src/JSDoc/models/tag-values/index.ts"
      ],
      "@beep/schema": [
        "../../../../packages/foundation/modeling/schema/src/index.ts"
      ],
      "@beep/schema/*": [
        "../../../../packages/foundation/modeling/schema/src/*.ts"
      ],
      "@beep/test-utils": [
        "../../../../packages/tooling/test-kit/test-utils/src/index.ts"
      ],
      "@beep/test-utils/*": [
        "../../../../packages/tooling/test-kit/test-utils/src/*.ts"
      ]
    }
  }
}
