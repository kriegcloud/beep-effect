{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["support/**/*.ts"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "exactOptionalPropertyTypes": false,
    "incremental": false,
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "plugins": [],
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "target": "ES2022",
    "tsBuildInfoFile": "node_modules/.tmp/tsconfig.support.tsbuildinfo",
    "types": ["node", "bun"]
  }
}
