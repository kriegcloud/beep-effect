[package]
name = "{{snakeCase name}}"
version = "0.0.0"
description = "{{description}}"
edition = "2021"

[lib]
name = "{{snakeCase name}}_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tauri = { version = "2", features = [] }
