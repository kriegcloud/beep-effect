{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "{{rootRelative}}tsconfig.base.json",
  "include": [
    "next-env.d.ts",
    "src",
    "test",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "next.config.ts",
    "vitest.config.ts",
    "{{rootRelative}}vitest.shared.ts"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node"],
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist",
    "rootDir": "../.."
  }
}
