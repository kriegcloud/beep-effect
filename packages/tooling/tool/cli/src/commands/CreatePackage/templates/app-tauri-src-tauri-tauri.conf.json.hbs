{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{name}}",
  "version": "0.0.0",
  "identifier": "dev.beep.{{kebabCase name}}",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "{{scopedName}}",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
