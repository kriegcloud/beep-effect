{
  "name": "@beep/repo-cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "description": "CLI tool for creating and managing packages in the beep-effect monorepo following Effect v4 standards",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/tooling/tool/cli",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/tooling/tool/cli"
  },
  "beep": {
    "family": "tooling",
    "kind": "tool"
  },
  "sideEffects": [],
  "bin": {
    "beep-cli": "./src/bin.ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./commands/AgentEffectiveness": "./src/commands/AgentEffectiveness/index.ts",
    "./commands/AIMetrics": "./src/commands/AIMetrics/index.ts",
    "./commands/Architecture": "./src/commands/Architecture/index.ts",
    "./commands/Ci": "./src/commands/Ci/index.ts",
    "./commands/Codegen": "./src/commands/Codegen/index.ts",
    "./commands/Codex": "./src/commands/Codex/index.ts",
    "./commands/Corpus": "./src/commands/Corpus/index.ts",
    "./commands/CreatePackage": "./src/commands/CreatePackage/index.ts",
    "./commands/Docgen": "./src/commands/Docgen/index.ts",
    "./commands/Docs": "./src/commands/Docs/index.ts",
    "./commands/Fallow": "./src/commands/Fallow/index.ts",
    "./commands/Files": "./src/commands/Files/index.ts",
    "./commands/Graphiti": "./src/commands/Graphiti/index.ts",
    "./commands/Image": "./src/commands/Image/index.ts",
    "./commands/Laws": "./src/commands/Laws/index.ts",
    "./commands/Lint": "./src/commands/Lint/index.ts",
    "./commands/Purge": "./src/commands/Purge/index.ts",
    "./commands/Quality": "./src/commands/Quality/index.ts",
    "./commands/Reuse": "./src/commands/Reuse/index.ts",
    "./commands/Root": "./src/commands/Root.ts",
    "./commands/SyncDataToTs": "./src/commands/SyncDataToTs/index.ts",
    "./commands/TopoSort": "./src/commands/TopoSort/index.ts",
    "./commands/TsconfigSync": "./src/commands/TsconfigSync/index.ts",
    "./commands/VersionSync": "./src/commands/VersionSync/index.ts",
    "./commands/Yeet": "./src/commands/Yeet/index.ts",
    "./commands/Quality/internal/*": null,
    "./commands/Yeet/internal/*": null,
    "./commands/*": "./src/commands/*.ts",
    "./internal/*": null,
    "./test/*": "./src/test/*.test-kit.ts",
    "./bin": null
  },
  "files": [
    "src/**/*.ts",
    "!src/test/**/*.ts",
    "src/commands/CreatePackage/templates/**/*.hbs",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "bin": {
      "beep-cli": "./dist/bin.js"
    },
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./commands/AgentEffectiveness": "./dist/commands/AgentEffectiveness/index.js",
      "./commands/AIMetrics": "./dist/commands/AIMetrics/index.js",
      "./commands/Architecture": "./dist/commands/Architecture/index.js",
      "./commands/Ci": "./dist/commands/Ci/index.js",
      "./commands/Codegen": "./dist/commands/Codegen/index.js",
      "./commands/Codex": "./dist/commands/Codex/index.js",
      "./commands/Corpus": "./dist/commands/Corpus/index.js",
      "./commands/CreatePackage": "./dist/commands/CreatePackage/index.js",
      "./commands/Docgen": "./dist/commands/Docgen/index.js",
      "./commands/Docs": "./dist/commands/Docs/index.js",
      "./commands/Fallow": "./dist/commands/Fallow/index.js",
      "./commands/Files": "./dist/commands/Files/index.js",
      "./commands/Graphiti": "./dist/commands/Graphiti/index.js",
      "./commands/Image": "./dist/commands/Image/index.js",
      "./commands/Laws": "./dist/commands/Laws/index.js",
      "./commands/Lint": "./dist/commands/Lint/index.js",
      "./commands/Purge": "./dist/commands/Purge/index.js",
      "./commands/Quality": "./dist/commands/Quality/index.js",
      "./commands/Reuse": "./dist/commands/Reuse/index.js",
      "./commands/Root": "./dist/commands/Root.js",
      "./commands/SyncDataToTs": "./dist/commands/SyncDataToTs/index.js",
      "./commands/TopoSort": "./dist/commands/TopoSort/index.js",
      "./commands/TsconfigSync": "./dist/commands/TsconfigSync/index.js",
      "./commands/VersionSync": "./dist/commands/VersionSync/index.js",
      "./commands/Yeet": "./dist/commands/Yeet/index.js",
      "./commands/Quality/internal/*": null,
      "./commands/Yeet/internal/*": null,
      "./internal/*": null,
      "./test/*": null,
      "./bin": null
    }
  },
  "scripts": {
    "codegen": "echo 'codegen will be implemented by this package'",
    "build": "bun run beep:build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "bun run beep:check",
    "test": "bun run beep:test",
    "type-test": "cd ../../../.. && bunx tstyche",
    "test:watch": "vitest",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "@beep/chalk": "workspace:^",
    "@beep/colors": "workspace:^",
    "@beep/duckdb": "workspace:^",
    "@beep/face-detection": "workspace:^",
    "@beep/ffmpeg": "workspace:^",
    "@beep/file-processing": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/libpff": "workspace:^",
    "@beep/md": "workspace:^",
    "@beep/observability": "workspace:^",
    "@beep/phoenix": "workspace:^",
    "@beep/repo-ai-metrics": "workspace:^",
    "@beep/repo-configs": "workspace:^",
    "@beep/repo-docgen": "workspace:^",
    "@beep/repo-utils": "workspace:^",
    "@beep/runpod": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/test-utils": "workspace:^",
    "@beep/tika": "workspace:^",
    "@beep/uspto": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@openai/codex-sdk": "catalog:",
    "effect": "catalog:",
    "fast-xml-parser": "catalog:",
    "handlebars": "catalog:",
    "image-size": "catalog:",
    "jsonc-parser": "catalog:",
    "madge": "catalog:",
    "sharp": "catalog:",
    "tar": "catalog:",
    "ts-morph": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
