{
  "name": "@beep/test-utils",
  "version": "0.0.2",
  "description": "An library for re-usable vitest & @effect/vitest testing utilities",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/tooling/test-kit/test-utils",
  "license": "Apache-2.0",
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/tooling/test-kit/test-utils"
  },
  "beep": {
    "family": "tooling",
    "kind": "test-kit"
  },
  "scripts": {
    "codegen": "echo 'no codegen needed'",
    "build": "bun run beep:build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "bun run beep:check",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "beep:build": "tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run --exclude=test/integration/**",
    "beep:test:integration": "TESTCONTAINERS_RYUK_DISABLED=true bunx --bun vitest run test/integration",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/pglite": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/sql-sqlite-node": "catalog:",
    "effect": "catalog:",
    "pg": "^8.20.0",
    "testcontainers": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0"
  },
  "private": true,
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.ts",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  },
  "sideEffects": [],
  "type": "module"
}
