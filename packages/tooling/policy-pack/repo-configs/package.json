{
  "name": "@beep/repo-configs",
  "version": "0.1.1",
  "description": "An library for shared build & tooling configurations",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "bun run ./scripts/GenerateEffectLawsAllowlistSnapshot.ts",
    "build": "bun run beep:build",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "bun run beep:check",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "coverage": "bunx --bun vitest run --coverage",
    "dtslint": "bunx tstyche dtslint/NextConfig.tst.ts",
    "type-test": "bun run dtslint",
    "docgen": "bun run ../../../../packages/tooling/tool/docgen/src/bin.ts",
    "beep:build": "bun run codegen && tsc -b tsconfig.json && bun run babel",
    "beep:check": "tsgo -b tsconfig.json",
    "beep:test": "bunx --bun vitest run",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "audit": "bun run --if-present beep:audit"
  },
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/utils": "workspace:^",
    "@effect/platform-node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "effect": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-jsdoc": "catalog:",
    "eslint-plugin-tsdoc": "catalog:",
    "jsonc-parser": "catalog:"
  },
  "devDependencies": {
    "@beep/test-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@next/bundle-analyzer": "catalog:",
    "@next/mdx": "catalog:",
    "@serwist/next": "catalog:",
    "@types/estree": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "next": "catalog:"
  },
  "peerDependencies": {
    "@next/bundle-analyzer": "catalog:",
    "@next/mdx": "catalog:",
    "@serwist/next": "catalog:",
    "next": "catalog:"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./next": "./src/next/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": "./src/internal/*.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "packages/tooling/policy-pack/repo-configs"
  },
  "beep": {
    "family": "tooling",
    "kind": "policy-pack"
  },
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/packages/tooling/policy-pack/repo-configs",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.ts",
      "./next": "./dist/next/index.js",
      "./*": "./dist/*.js",
      "./internal/*": "./dist/internal/*.js"
    }
  }
}
