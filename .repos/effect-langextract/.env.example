# ─────────────────────────────────────────────────────────────
# effect-langextract environment configuration
# Copy to .env and fill in your values: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Provider Selection ───────────────────────────────────────
# Which provider to use: gemini | openai | anthropic | ollama
# Also auto-detected from MODEL_ID if omitted.
LANGEXTRACT_PROVIDER=gemini

# ── General Extraction Config ────────────────────────────────
MODEL_ID=gemini-2.5-flash
# TEMPERATURE=0
# FORMAT_TYPE=json
# USE_FENCES=true
# USE_SCHEMA_CONSTRAINTS=true
# DEBUG=false

# ── Chunking & Batching ─────────────────────────────────────
# MAX_CHAR_BUFFER=1000
# BATCH_LENGTH=10
# BATCH_CONCURRENCY=1
# PROVIDER_CONCURRENCY=8
# MAX_BATCH_INPUT_TOKENS=
# EXTRACTION_PASSES=1
# CONTEXT_WINDOW_CHARS=

# ── Prompt & Examples ────────────────────────────────────────
# PROMPT_DESCRIPTION=Extract structured entities.
# EXAMPLES_FILE=examples.json

# ── Output ───────────────────────────────────────────────────
# OUTPUT_FORMAT=json
# OUTPUT_PATH=

# ── Primed Cache ─────────────────────────────────────────────
# PRIMED_CACHE_ENABLED=true
# PRIMED_CACHE_DIR=.cache/langextract/primed
# PRIMED_CACHE_NAMESPACE=langextract
# PRIMED_CACHE_TTL_SECONDS=86400
# PRIMED_CACHE_DETERMINISTIC_ONLY=true
# CLEAR_PRIMED_CACHE_ON_START=false

# ── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-2.5-flash
# GEMINI_BASE_URL=
# GEMINI_TEMPERATURE=0
# GEMINI_PROVIDER_CONCURRENCY=8
# GEMINI_FORMAT_TYPE=json
# GEMINI_VERTEXAI=false
# GEMINI_PROJECT=
# GEMINI_LOCATION=
# GEMINI_PRIMED_CACHE_SCOPE=session
# GEMINI_PRIMED_CACHE_NAMESPACE=gemini

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_MODEL_ID=gpt-4o-mini
# OPENAI_BASE_URL=
# OPENAI_ORGANIZATION=
# OPENAI_TEMPERATURE=
# OPENAI_PROVIDER_CONCURRENCY=8
# OPENAI_FORMAT_TYPE=json
# OPENAI_PRIMED_CACHE_SCOPE=session
# OPENAI_PRIMED_CACHE_NAMESPACE=openai

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_ID=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=
# ANTHROPIC_TEMPERATURE=
# ANTHROPIC_PROVIDER_CONCURRENCY=8
# ANTHROPIC_FORMAT_TYPE=json
# ANTHROPIC_PRIMED_CACHE_SCOPE=session
# ANTHROPIC_PRIMED_CACHE_NAMESPACE=anthropic

# ── Ollama ───────────────────────────────────────────────────
# OLLAMA_MODEL_ID=llama3.2:latest
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TEMPERATURE=
# OLLAMA_TIMEOUT=120
# OLLAMA_PROVIDER_CONCURRENCY=8
# OLLAMA_FORMAT_TYPE=json
# OLLAMA_PRIMED_CACHE_SCOPE=session
# OLLAMA_PRIMED_CACHE_NAMESPACE=ollama
