{
    "name": "@blueprintjs/test-commons",
    "version": "4.0.4",
    "private": true,
    "description": "Common utilities for tests in @blueprintjs packages",
    "type": "module",
    "types": "./lib/index.d.ts",
    "typesVersions": {
        "*": {
            "vitest": [
                "./vitest.d.ts"
            ],
            "vitest-utils": [
                "./lib/vitest-utils.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./vitest": {
            "types": "./vitest.d.ts",
            "default": "./lib/vitest.js"
        },
        "./vitest-utils": {
            "types": "./lib/vitest-utils.d.ts",
            "default": "./lib/vitest-utils.js"
        },
        "./bootstrap": "./bootstrap.mjs",
        "./vitest.setup": "./vitest.setup.mts",
        "./vitest-setup-no-enzyme": "./vitest-setup-no-enzyme.mts"
    },
    "scripts": {
        "compile": "tsc -p ./src",
        "clean": "rm -rf lib/* || true",
        "dev": "pnpm compile --watch",
        "lint": "run-p lint:es",
        "lint:es": "es-lint",
        "lint-fix": "es-lint --fix",
        "test": "exit 0"
    },
    "dependencies": {
        "@cfaester/enzyme-adapter-react-18": "^0.8.0",
        "@testing-library/dom": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@testing-library/user-event": "catalog:",
        "@types/chai": "^5.0.0",
        "@vitejs/plugin-react": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "chai": "^5.0.0",
        "enzyme": "catalog:",
        "jsdom": "catalog:",
        "vitest": "catalog:"
    },
    "peerDependencies": {
        "react": ">=16.8",
        "react-dom": ">=16.8"
    },
    "devDependencies": {
        "@blueprintjs/node-build-scripts": "workspace:^",
        "npm-run-all": "^4.1.5",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "~5.3.3"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:palantir/blueprint.git",
        "directory": "packages/test-commons"
    },
    "author": "Palantir Technologies",
    "license": "Apache-2.0"
}
