{
  "extends": "./tsconfig.base.json",
  "include": [
    "./syncpack.config.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "erasableSyntaxOnly": false,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "rootDir": ".",
        "plugins": [{
      "name": "@effect/language-service",
      "namespaceImportPackages": []
    }]
  },
  "references": [
    {
      "path": "packages/orm"
    }
  ]
}
