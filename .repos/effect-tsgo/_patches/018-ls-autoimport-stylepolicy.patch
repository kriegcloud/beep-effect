+// FixTransformer is a function that transforms auto-import fixes based on
+// style preferences. It receives an export and a list of fixes, and returns
+// the (potentially rewritten) list of fixes. A nil return suppresses the fixes.
+type FixTransformer func(export *Export, fixes []*Fix) []*Fix
+
+// autoImportFixTransformerFactory is the registered factory that creates a
+// FixTransformer from user preferences and the compiler program.
+// Set via RegisterAutoImportFixTransformer.
+var autoImportFixTransformerFactory func(prefs modulespecifiers.UserPreferences, program *compiler.Program, importingFile *ast.SourceFile) FixTransformer
+
+// RegisterAutoImportFixTransformer registers a factory function that will be
+// called during NewView to create a FixTransformer from user preferences and
+// the compiler program. Only one factory can be registered; subsequent calls
+// replace the previous one.
+func RegisterAutoImportFixTransformer(factory func(prefs modulespecifiers.UserPreferences, program *compiler.Program, importingFile *ast.SourceFile) FixTransformer) {
+	autoImportFixTransformerFactory = factory
+}
+
+func (v *View) applyStylePolicy(export *Export, fixes []*Fix) []*Fix {
+	if v.fixTransformer == nil || len(fixes) == 0 {
+		return fixes
+	}
+	return v.fixTransformer(export, fixes)
 }
 
