{
  "$schema": "../node_modules/@effect/docgen/schema.json",
  "enforceVersion": false,
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/groking-effect-v4/src/",
  "examplesCompilerOptions": {
    "noCheck": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@beep/groking-effect-v4": ["../groking-effect-v4/src/index.ts"],
      "@beep/groking-effect-v4/*": ["../groking-effect-v4/src/*.ts"],
      "effect": ["../node_modules/effect/dist/dts/index.d.ts"]
    }
  }
}
