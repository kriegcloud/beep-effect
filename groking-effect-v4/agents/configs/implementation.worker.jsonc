{
  // Default configuration for real implementation runs.
  "agent_type": "worker",
  "mode": "implementation",
  "ownership": {
    "scope": "single export file",
    "allow_cross_file_edits": false
  },
  "constraints": {
    "preserve_import_contract": true,
    "preserve_program_shell": true,
    "require_executable_examples": true,
    "minimum_examples_for_non_type_like": 2
  },
  "outputs": {
    "must_modify_target_file": true,
    "must_include_change_notes": true
  }
}
