{
  // Default configuration for dry-run prompt tuning experiments.
  "agent_type": "worker",
  "mode": "dry-run",
  "ownership": {
    "scope": "single export file",
    "allow_cross_file_edits": false
  },
  "constraints": {
    "must_not_modify_target_file": true,
    "must_produce_feedback_report": true,
    "require_blocker_analysis": true,
    "require_patch_sketch": true,
    "require_summary_behavior_alignment": true,
    "require_semantic_risk_analysis": true,
    "require_documented_invocation_for_callable_value_like": true,
    "disallow_zero_arg_probe_when_required_arity_detected": true,
    "require_callable_probe_strategy_declaration": true,
    "fail_on_summary_invocation_mismatch": true,
    "require_contract_note_when_runtime_permissive": true,
    "require_contract_boundary_observation_for_variadic_callable": true,
    "disallow_zero_arg_probe_based_only_on_function_length": true,
    "require_explicit_hard_blocker_status": true,
    "require_alignment_contradiction_callout": true,
    "require_documented_invocation_for_function_like": true,
    "fail_if_invocation_example_only_shows_failure": true,
    "require_domain_semantic_round_trip_for_key_markers": true,
    "semantic_trigger_phrases": ["ServiceMap key", "annotation", "reference"],
    "require_safe_lookup_for_optional_metadata": true,
    "require_synthetic_fixture_disclaimer_when_marker_fixture_used": true,
    "require_explicit_failure_only_risk_callout": true,
    "require_documented_invocation_for_type_like_when_source_example_present": true,
    "fail_when_type_like_source_example_not_executed": true,
    "disallow_undefined_lookup_as_primary_context_example": true,
    "require_runtime_companion_bridge_note_for_type_like": true,
    "require_reflective_only_quality_risk_callout": true,
    "require_source_example_coverage_section": true,
    "require_source_mirroring_invocation_for_function_like_when_source_exists": true,
    "disallow_constructor_probe_as_primary_semantic_example": true,
    "fail_if_all_examples_are_reflective": true
  },
  "outputs": {
    "report_format": "markdown",
    "report_sections": [
      "What Worked",
      "What Didn't",
      "Hard Blockers",
      "Probe Strategy Declaration",
      "Semantic Risks",
      "Source Example Coverage",
      "Proposed Changes",
      "Proposed Patch Sketch",
      "Estimated Real Run Effort"
    ]
  }
}
