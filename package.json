  "scripts": {
    "op": "op run --env-file=.env --",
    "beep": "bun run packages/tooling/tool/cli/src/bin.ts --",
    "topo-sort": "bun run beep topo-sort",
    "codegen": "bun run beep codegen",
    "codex:quality-review-fix-loop": "bun run beep codex quality-review-fix-loop",
    "create-package": "bun run beep create-package",
    "files": "bun run beep files",
    "image": "bun run beep image",
    "config-sync": "bun run beep tsconfig-sync",
    "config-sync:check": "bun run beep tsconfig-sync --check",
    "version-sync": "bun run beep version-sync",
    "purge": "bun run beep purge",
    "dev": "bunx turbo run dev",
    "build": "beep-cli build",
    "check": "beep-cli check",
    "test": "beep-cli test",
    "coverage": "VITEST_COVERAGE_REPORT_ONLY=1 bunx turbo run coverage --cache=local:rw",
    "lint": "beep-cli lint",
    "lint:fix": "beep-cli lint --fix",
    "audit": "beep-cli audit packages",
    "audit:github": "beep-cli audit github",
    "audit:full": "bun run audit && bun run audit:github quality",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:status:since-main": "changeset status --since=origin/main",
    "changeset:version": "changeset version",
    "storybook": "bunx turbo run storybook --filter=@beep/ui",
    "build-storybook": "bunx turbo run build-storybook --filter=@beep/ui",
    "test:storybook": "bunx turbo run test:storybook --filter=@beep/ui",
    "docgen": "bunx turbo run docgen && bun run docs:aggregate",
    "docgen:affected": "bunx turbo run docgen --affected && bun run docs:aggregate",
    "jsdoc:inventory": "bun run beep quality jsdoc-inventory",
    "repo-exports:catalog": "bun run beep quality repo-exports-catalog",
    "repo-exports:catalog:check": "bun run beep quality repo-exports-catalog --check",
    "docs:aggregate": "beep-cli docgen aggregate",
    "ui-add": "bunx --bun shadcn@latest add --cwd packages/foundation/ui-system/ui",
    "release": "bun run build && bun run test && bun run lint && bun run audit:full && changeset publish",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "docker compose up -d",
    "graphiti:proxy": "bun run beep graphiti proxy",
    "graphiti:proxy:ensure": "bun run beep graphiti proxy ensure",
    "kg:proxy": "bun run beep graphiti proxy kg --",
    "graphiti:recover": "bun run beep graphiti recover",
    "graphiti:recover:dry-run": "bun run beep graphiti recover --dry-run",
    "graphiti:proxy:service:install": "bun run beep graphiti proxy service install",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "prepare": "effect-tsgo patch",
    "postinstall": "lefthook install"
  },
  "resolutions#": {
    "@beep/*": "Needed to force PNPM to install local packages"
  },
