{
  "private": true,
  "type": "module",
  "name": "@beep/root",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/common/*",
    "packages/iam/*",
    "packages/_internal/*",
    "packages/runtime/*",
    "packages/shared/*",
    "packages/ui/*",
    "apps/*",
    "tooling/*",
    "packages/knowledge/*"
  ],
  "repository": {
    "repository": {
      "type": "git",
      "url": "git@github.com:kriegcloud/beep-effect.git",
      "directory": "."
    }
  },
  "scripts": {
    "build": "bunx turbo run build",
    "check": "bunx turbo run check",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "bun run dotenvx -- docker compose up -d",
    "lint": "bun run lint:deps && bunx turbo run lint lint:circular",
    "lint:fix": "bunx turbo run lint:fix && bun run lint:deps:fix",
    "test": "turbo run test --ui=stream",
    "coverage": "bunx turbo run coverage",
    "dev": "bun run dotenvx -- bunx turbo run dev --concurrency=36",
    "start": "bun run dotenvx -- bunx turbo run start",
    "dotenvx": "bunx @dotenvx/dotenvx run -f .env --",
    "lint:deps": "bunx syncpack lint --dependency-types='catalog'",
    "lint:deps:fix": "bunx syncpack fix --dependency-types=catalog",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "lint:circular": "bunx turbo run lint:circular"
  },
  "resolutions#": {
    "@beep/*": "Needed to force PNPM to install local packages"
  },
  "devDependencies": {
    "@babel/cli": "catalog:",
    "@babel/core": "catalog:",
    "@babel/plugin-transform-export-namespace-from": "catalog:",
    "@babel/plugin-transform-modules-commonjs": "catalog:",
    "@biomejs/biome": "catalog:",
    "@dotenvx/dotenvx": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "babel-plugin-annotate-pure-calls": "catalog:",
    "babel-plugin-transform-next-use-client": "catalog:",
    "knip": "catalog:",
    "madge": "catalog:",
    "syncpack": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*": [
      "biome check"
    ],
    "**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "biome check"
    ]
  },
  "catalog": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@biomejs/biome": "^2.4.2",
    "@dotenvx/dotenvx": "^1.52.0",
    "@faker-js/faker": "^10.3.0",
    "@tailwindcss/cli": "^4.2.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@total-typescript/ts-reset": "^0.6.1",
    "@turbo/gen": "^2.8.10",
    "@types/bun": "^1.3.9",
    "@types/copyfiles": "^2.4.4",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "babel-loader": "^10.0.0",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "babel-plugin-transform-next-use-client": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "copyfiles": "^2.4.1",
    "knip": "^5.84.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "shadcn": "^3.8.5",
    "pg": "^8.18.0",
    "pg-connection-string": "^2.11.0",
    "pg-cursor": "^2.17.0",
    "pg-types": "^4.1.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "syncpack": "14.0.0-alpha.41",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.2.0",
    "tailwindcss-animate": "^1.0.7",
    "testcontainers": "^11.12.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  }
}
