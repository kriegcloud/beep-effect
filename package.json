{
  "private": true,
  "type": "module",
  "name": "@beep/root",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    ".claude",
    ".codex",
    "apps/desktop",
    "apps/editor-app",
    "apps/V2T",
    "infra",
    "packages/v2t-sidecar",
    "packages/_internal/*",
    "packages/common/*",
    "packages/repo-memory/client",
    "packages/repo-memory/model",
    "packages/repo-memory/runtime",
    "packages/repo-memory/sqlite",
    "packages/repo-memory/store",
    "packages/runtime/*",
    "packages/shared/client",
    "packages/shared/domain",
    "packages/shared/env",
    "packages/shared/server",
    "packages/shared/tables",
    "packages/shared/ui",
    "tooling/cli",
    "tooling/configs",
    "packages/editor/core",
    "tooling/repo-utils",
    "tooling/test-utils",
    "tooling/docgen",
    "packages/editor/lexical",
    "packages/editor/protocol",
    "packages/editor/client",
    "packages/editor/runtime"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "."
  },
  "scripts": {
    "op": "op run --env-file=.env --",
    "beep": "bun run tooling/cli/src/bin.ts --",
    "claude:hook:agent-init": "bun run .claude/hooks/agent-init/run.sh",
    "claude:hook:subagent-init": "bun run .claude/hooks/subagent-init/run.sh",
    "claude:hook:pattern-detector": "bun run .claude/hooks/pattern-detector/run.sh",
    "claude:hook:skill-suggester": "bun run .claude/hooks/skill-suggester/run.sh",
    "claude:hook:stop": "bun run beep claude hook-stop",
    "codex:hook:session-start": "bun run beep codex hook-session-start",
    "topo-sort": "bun run beep topo-sort",
    "codegen": "bun run beep codegen",
    "create-package": "bun run beep create-package",
    "config-sync": "bun run beep tsconfig-sync",
    "version-sync": "bun run beep version-sync",
    "purge": "bun run beep purge",
    "dev": "bunx turbo run dev",
    "dev:desktop": "bunx turbo run dev:desktop --filter=@beep/desktop",
    "dev:v2t": "bunx turbo run dev --filter=@beep/v2t",
    "build": "bun run op turbo run build",
    "build:ci": "bunx turbo run build",
    "check:github": "bash scripts/run-github-checks.sh pre-push",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "check": "bunx turbo run check",
    "check:full": "tsc -p tsconfig.quality.json --noEmit",
    "check:infra": "bunx turbo run check --filter=@beep/infra",
    "test": "bunx turbo run test --concurrency=1 && bun run test:types",
    "test:watch": "vitest",
    "test:types": "tstyche",
    "coverage": "vitest --coverage",
    "check:effect-steering": "(cd .claude && bunx --bun vitest run test/effect-steering-hook.test.ts test/effect-steering-patterns.test.ts) && (cd tooling/cli && bunx --bun vitest run test/codex-session-start-runtime.test.ts) && (cd tooling/configs && bunx --bun vitest run test/effect-steering-guidance.test.ts)",
    "lint:effect-governance:biome": "bunx biome check package.json biome.jsonc standards/effect-laws.allowlist.jsonc standards/schema-first.inventory.jsonc --files-ignore-unknown=true",
    "lint:effect-governance": "bun run lint:effect-governance:biome && bun run check:effect-imports && bun run beep laws native-runtime --check && bun run lint:schema-first && bun run beep laws terse-effect --check && bun run check:effect-steering && bun run check:effect-laws-allowlist",
    "lint": "bunx turbo run lint lint:effect-governance lint:jsdoc lint:spell lint:markdown lint:circular lint:versions && bun run lint:tooling-tagged-errors && bun run lint:typos && bun run lint:repo && bun run lint:ox",
    "check:effect-laws-allowlist": "bun run beep laws allowlist-check",
    "lint:versions": "bun run beep version-sync --skip-network",
    "lint:fix": "bunx turbo run lint:fix",
    "lint:jsdoc": "eslint --config eslint.config.mjs --ignore-pattern 'tooling/_test-*/**' --ignore-pattern '.repos/**' --ignore-pattern 'apps/desktop/scripts/**' --ignore-pattern 'apps/desktop/src-tauri/target/**' --ignore-pattern '**/docs/**'",
    "lint:tooling-tagged-errors": "bun run beep lint tooling-tagged-errors",
    "lint:schema-first": "bun run beep lint schema-first",
    "lint:tooling-schema-first": "bun run beep lint tooling-schema-first",
    "lint:circular": "bash -o pipefail -c 'bun run beep lint circular | cat'",
    "lint:typos": "typos",
    "lint:spell": "cspell lint --no-progress '**/*.{ts,tsx,md}'",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#**/node_modules' '#.repos' '#.next' '#.sst' '#outputs'",
    "lint:repo": "bunx sherif@1.10.0 -r non-existent-packages",
    "lint:ox": "bunx oxlint --ignore-pattern '.repos/**' --ignore-pattern 'specs/**' --ignore-pattern '**/storybook-static/**' --ignore-pattern 'scratchpad/**' --ignore-pattern 'packages/common/schema/src/sqlite/index.ts' .",
    "storybook": "bunx turbo run storybook --filter=@beep/ui",
    "build-storybook": "bunx turbo run build-storybook --filter=@beep/ui",
    "test:storybook": "bunx turbo run test:storybook --filter=@beep/ui",
    "docgen": "bunx turbo run docgen && bun run beep docs aggregate --clean",
    "docgen:affected": "bunx turbo run docgen --filter=...[origin/main] && bun run beep docs aggregate --clean",
    "ui-add": "bunx --bun shadcn@latest add --cwd packages/common/ui",
    "fix:effect-imports": "bun run beep laws effect-imports --write",
    "check:effect-imports": "bun run beep laws effect-imports --check",
    "audit:high:strict": "bun audit --audit-level=high",
    "audit:high": "bash scripts/run-bun-audit.sh",
    "audit:high:ci": "bun run audit:high",
    "release": "bun run build && bun run test && bun run lint && changeset publish",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "docker compose up -d",
    "graphiti:proxy": "bun run beep graphiti proxy",
    "graphiti:proxy:ensure": "bash scripts/graphiti-proxy-ensure.sh",
    "graphiti:proxy:service:install": "bash scripts/graphiti-proxy-service-install.sh",
    "kg:proxy": "bash scripts/kg-with-proxy.sh",
    "kg:graphiti-recover:dry-run": "bash scripts/graphiti-recover.sh --dry-run --skip-republish",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "prepare": "effect-language-service patch && effect-tsgo patch",
    "postinstall": "lefthook install"
  },
  "resolutions#": {
    "@beep/*": "Needed to force PNPM to install local packages"
  },
