{
  "private": true,
  "type": "module",
  "name": "@beep/root",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    ".claude",
    "scratchpad",
    "packages/*",
    "packages/*/*",
    "tooling/*",
    "apps/*"
  ],
  "repository": {
    "repository": {
      "type": "git",
      "url": "git@github.com:kriegcloud/beep-effect.git",
      "directory": "."
    }
  },
  "scripts": {
    "beep": "bun run tooling/cli/src/bin.ts --",
    "topo-sort": "bun run beep topo-sort",
    "codegen": "bun run beep codegen",
    "create-package": "bun run beep create-package",
    "config-sync": "bun run beep tsconfig-sync",
    "version-sync": "bun run beep version-sync",
    "purge": "bun run beep purge",
    "clean": "node scripts/clean.mjs",
    "dev": "bunx turbo run dev",
    "build": "bunx turbo run build",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "build:tsgo": "tsgo -b tsconfig.packages.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:tsgo": "tsgo -b tsconfig.json",
    "test": "vitest run && tstyche",
    "test:watch": "vitest",
    "test:types": "tstyche",
    "test:e2e": "playwright test",
    "coverage": "vitest --coverage",
    "lint": "bunx turbo run lint lint:jsdoc lint:spell lint:markdown lint:circular lint:versions && bun run lint:typos && bun run lint:repo && bun run lint:ox",
    "lint:versions": "bun run beep version-sync --skip-network",
    "lint:fix": "bunx turbo run lint:fix",
    "lint:jsdoc": "eslint --config eslint.config.mjs --ignore-pattern 'tooling/_test-*/**'",
    "lint:circular": "node scripts/circular.mjs",
    "lint:typos": "typos --exclude '.beep/**'",
    "lint:spell": "cspell lint --no-progress '**/*.{ts,tsx,md}' '#.beep'",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#.repos' '#.next' '#.beep'",
    "lint:repo": "bunx sherif -r non-existent-packages",
    "lint:ox": "bunx oxlint --ignore-pattern '.repos/**' --ignore-pattern 'specs/**' --ignore-pattern '.beep/**' --ignore-pattern '**/storybook-static/**' .",
    "storybook": "bunx turbo run storybook --filter=@beep/ui",
    "build-storybook": "bunx turbo run build-storybook --filter=@beep/ui",
    "test:storybook": "bunx turbo run test:storybook --filter=@beep/ui",
    "test:visual": "bunx turbo run test:visual --filter=@beep/ui",
    "docgen": "bunx turbo run docgen && node scripts/docs.mjs",
    "audit:high:strict": "bun audit --audit-level=high",
    "audit:high": "bun audit --audit-level=high --ignore=GHSA-35jh-r3h4-6jhm --ignore=GHSA-3ppc-4f35-3m26",
    "audit:high:ci": "bun run audit:high",
    "release": "bun run build && bun run test && bun run lint && changeset publish",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "bun run dotenvx -- docker compose up -d",
    "dotenvx": "bunx @dotenvx/dotenvx run -f .env --",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "postinstall": "lefthook install"
  },
  "resolutions#": {
    "@beep/*": "Needed to force bun to install local packages"
  },
  "devDependencies": {
    "@1password/sdk": "catalog:",
