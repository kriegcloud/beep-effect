{
  "private": true,
  "type": "module",
  "name": "@beep/root",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    ".claude",
    ".codex",
    "apps/*",
    "scratchpad",
    "packages/_internal/*",
    "packages/ai/*",
    "packages/common/*",
    "packages/repo-memory/client",
    "packages/repo-memory/model",
    "packages/repo-memory/runtime",
    "packages/repo-memory/sqlite",
    "packages/repo-memory/store",
    "packages/runtime/*",
    "packages/shared/*",
    "tooling/*",
    "packages/editor",
    "tooling/docgen/docgen"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "."
  },
  "scripts": {
    "op": "op run --env-file=.env --",
    "beep": "bun run tooling/cli/src/bin.ts --",
    "claude:hook:agent-init": "bun run .claude/hooks/agent-init/run.sh",
    "claude:hook:subagent-init": "bun run .claude/hooks/subagent-init/run.sh",
    "claude:hook:pattern-detector": "bun run .claude/hooks/pattern-detector/run.sh",
    "claude:hook:skill-suggester": "bun run .claude/hooks/skill-suggester/run.sh",
    "claude:hook:stop": "bun run beep claude hook-stop",
    "topo-sort": "bun run beep topo-sort",
    "codegen": "bun run beep codegen",
    "create-package": "bun run beep create-package",
    "config-sync": "bun run beep tsconfig-sync",
    "version-sync": "bun run beep version-sync",
    "purge": "bun run beep purge",
    "dev": "bunx turbo run dev --filter=!scratchpad",
    "dev:desktop": "bunx turbo run dev:desktop --filter=@beep/desktop",
    "build": "bun run op turbo run build --filter=!scratchpad",
    "build:ci": "bunx turbo run build --filter=!scratchpad",
    "check:github": "bash scripts/run-github-checks.sh pre-push",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "check": "bunx turbo run check --filter=!scratchpad",
    "check:full": "tsc -p tsconfig.quality.json --noEmit",
    "check:infra": "tsc -p infra/tsconfig.json --noEmit",
    "test": "bunx turbo run test --filter=!scratchpad --concurrency=1 && bun run test:types",
    "test:watch": "vitest",
    "test:types": "tstyche",
    "test:e2e": "bash scripts/run-e2e.sh",
    "coverage": "vitest --coverage",
    "lint": "bunx turbo run lint lint:effect-laws lint:jsdoc lint:spell lint:markdown lint:circular lint:versions --filter=!scratchpad && bun run check:effect-laws-allowlist && bun run lint:tooling-tagged-errors && bun run lint:schema-first && bun run agents:check && bun run agents:pathless:check && bun run lint:typos && bun run lint:repo && bun run lint:ox",
    "check:effect-laws-allowlist": "bun run beep laws allowlist-check",
    "lint:versions": "bun run beep version-sync --skip-network",
    "lint:fix": "bunx turbo run lint:fix --filter=!scratchpad",
    "lint:jsdoc": "eslint --config eslint.config.mjs --ignore-pattern 'tooling/_test-*/**' --ignore-pattern '.repos/**' --ignore-pattern 'packages/ai/sdk/tmp/**' --ignore-pattern 'apps/desktop/scripts/**' --ignore-pattern 'apps/desktop/src-tauri/target/**' --ignore-pattern '**/docs/**'",
    "lint:effect-laws": "eslint --config eslint.config.mjs --no-error-on-unmatched-pattern \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" \"tooling/**/*.{ts,tsx}\" \"infra/**/*.ts\" \".claude/hooks/**/*.ts\" --ignore-pattern 'packages/ai/sdk/tmp/**' --ignore-pattern '**/docs/**'",
    "lint:tooling-tagged-errors": "bun run beep lint tooling-tagged-errors",
    "lint:schema-first": "bun run beep lint schema-first",
    "lint:tooling-schema-first": "bun run beep lint tooling-schema-first",
    "lint:effect-laws:strict": "bun run lint:effect-laws --max-warnings=0",
    "lint:circular": "bash -o pipefail -c 'bun run beep lint circular | cat'",
    "lint:typos": "typos",
    "lint:spell": "cspell lint --no-progress '**/*.{ts,tsx,md}'",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#.repos' '#.next' '#.sst' '#outputs'",
    "lint:repo": "bunx sherif@1.10.0 -r non-existent-packages --ignore-package scratchpad",
    "lint:ox": "bunx oxlint --ignore-pattern '.repos/**' --ignore-pattern 'specs/**' --ignore-pattern '**/storybook-static/**' --ignore-pattern 'scratchpad/**' --ignore-pattern 'packages/ai/sdk/tmp/**' --ignore-pattern 'packages/common/schema/src/sqlite/index.ts' .",
    "storybook": "bunx turbo run storybook --filter=@beep/ui",
    "build-storybook": "bunx turbo run build-storybook --filter=@beep/ui",
    "test:storybook": "bunx turbo run test:storybook --filter=@beep/ui",
    "test:visual": "bunx turbo run test:visual --filter=@beep/ui",
    "docgen": "bunx turbo run docgen --filter=!scratchpad && bun run beep docs aggregate --clean",
    "docgen:affected": "bunx turbo run docgen --filter=...[origin/main] --filter=!scratchpad && bun run beep docs aggregate --clean",
    "ui-add": "bunx --bun shadcn@latest add --cwd packages/common/ui",
    "fix:effect-imports": "bun run beep laws effect-imports --write",
    "check:effect-imports": "bun run beep laws effect-imports --check",
    "fix:terse-effect": "bun run beep laws terse-effect --write",
    "check:terse-effect": "bun run beep laws terse-effect --check",
    "agents:check": "bun run beep agents check",
    "agents:check:strict": "bun run beep agents check --strict",
    "agents:pathless:check": "bun run beep agents pathless-check",
    "audit:high:strict": "bun audit --audit-level=high",
    "audit:high": "bash scripts/run-bun-audit.sh",
    "audit:high:ci": "bun run audit:high",
    "release": "bun run build && bun run test && bun run lint && changeset publish",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "docker compose up -d",
    "graphiti:proxy": "bun run beep graphiti proxy",
    "graphiti:proxy:ensure": "bash scripts/graphiti-proxy-ensure.sh",
    "graphiti:proxy:service:install": "bash scripts/graphiti-proxy-service-install.sh",
    "kg:proxy": "bash scripts/kg-with-proxy.sh",
    "kg:graphiti-recover:dry-run": "bash scripts/graphiti-recover.sh --dry-run --skip-republish",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "prepare": "effect-language-service patch && effect-tsgo patch",
    "postinstall": "lefthook install"
  },
  "resolutions#": {
    "@beep/*": "Needed to force PNPM to install local packages"
  },
