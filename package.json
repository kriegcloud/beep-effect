{
  "private": true,
  "type": "module",
  "name": "@beep/root",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    ".claude",
    "scratchpad",
    "packages/ai/*",
    "packages/common/*",
    "packages/shared/*",
    "packages/ui/*",
    "tooling/agent-eval",
    "tooling/cli",
    "tooling/repo-utils",
    "apps/*"
  ],
  "repository": {
    "repository": {
      "type": "git",
      "url": "git@github.com:kriegcloud/beep-effect.git",
      "directory": "."
    }
  },
  "scripts": {
    "op": "op run --env-file=.env --",
    "beep": "bun run tooling/cli/src/bin.ts --",
    "agent:bench": "bun run tooling/agent-eval/src/bin.ts bench",
    "agent:bench:report": "bun run tooling/agent-eval/src/bin.ts report",
    "agent:bench:compare": "bun run tooling/agent-eval/src/bin.ts compare",
    "agent:bench:ingest": "bun run tooling/agent-eval/src/bin.ts ingest",
    "claude:hook:agent-init": "bun run .claude/hooks/agent-init/run.sh",
    "claude:hook:subagent-init": "bun run .claude/hooks/subagent-init/run.sh",
    "claude:hook:pattern-detector": "bun run .claude/hooks/pattern-detector/run.sh",
    "claude:hook:skill-suggester": "bun run .claude/hooks/skill-suggester/run.sh",
    "claude:hook:stop": "node scripts/claude-hook-stop.mjs",
    "topo-sort": "bun run beep topo-sort",
    "codegen": "bun run beep codegen",
    "create-package": "bun run beep create-package",
    "config-sync": "bun run beep tsconfig-sync",
    "version-sync": "bun run beep version-sync",
    "purge": "bun run beep purge",
    "clean": "node scripts/clean.mjs",
    "dev": "bunx turbo run dev",
    "build": "bun run op turbo run build",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p packages/ai/sdk/test/tsconfig.json --noEmit && bun run --cwd .claude check",
    "check:infra": "tsc -p infra/tsconfig.json --noEmit",
    "test": "vitest run && tstyche",
    "test:watch": "vitest",
    "test:types": "tstyche",
    "test:e2e": "playwright test",
    "coverage": "vitest --coverage",
    "lint": "bunx turbo run lint lint:jsdoc lint:spell lint:markdown lint:circular lint:versions && bun run lint:effect-laws && bun run lint:tooling-tagged-errors && bun run agents:check && bun run agents:pathless:check && bun run lint:typos && bun run lint:repo && bun run lint:ox",
    "lint:versions": "bun run beep version-sync --skip-network",
    "lint:fix": "bunx turbo run lint:fix",
    "lint:jsdoc": "eslint --config eslint.config.mjs --ignore-pattern 'tooling/_test-*/**' --ignore-pattern '.repos/**'",
    "lint:effect-laws": "eslint --config eslint.config.mjs \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" \"tooling/**/*.{ts,tsx}\" \"infra/**/*.ts\" --ignore-pattern '.repos/**'",
    "lint:tooling-tagged-errors": "node scripts/check-tooling-tagged-errors.mjs",
    "lint:effect-laws:strict": "bun run lint:effect-laws --max-warnings=0",
    "lint:circular": "node scripts/circular.mjs",
    "lint:typos": "typos --exclude '.beep/**'",
    "lint:spell": "cspell lint --no-progress '**/*.{ts,tsx,md}' '#.beep'",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#.repos' '#.next' '#.beep' '#.sst' '#outputs'",
    "lint:repo": "bunx sherif -r non-existent-packages",
    "lint:ox": "bunx oxlint --ignore-pattern '.repos/**' --ignore-pattern 'specs/**' --ignore-pattern '.beep/**' --ignore-pattern '**/storybook-static/**' .",
    "storybook": "bunx turbo run storybook --filter=@beep/ui",
    "build-storybook": "bunx turbo run build-storybook --filter=@beep/ui",
    "test:storybook": "bunx turbo run test:storybook --filter=@beep/ui",
    "test:visual": "bunx turbo run test:visual --filter=@beep/ui",
    "docgen": "bunx turbo run docgen && node scripts/docs.mjs",
    "fix:effect-imports": "node scripts/effect-laws-fix-imports.mjs --write",
    "check:effect-imports": "node scripts/effect-laws-fix-imports.mjs --check",
    "agents:check": "node scripts/agents-check.mjs",
    "agents:check:strict": "node scripts/agents-check.mjs --strict",
    "agents:pathless:check": "node scripts/pathless-config-check.mjs",
    "audit:high:strict": "bun audit --audit-level=high",
    "audit:high": "bun audit --audit-level=high --ignore=GHSA-35jh-r3h4-6jhm --ignore=GHSA-3ppc-4f35-3m26 --ignore=GHSA-8r9q-7v3j-jr4g --ignore=GHSA-w48q-cv73-mx4w --ignore=GHSA-3vhc-576x-3qv4 --ignore=GHSA-f67f-6cw9-8mq4 --ignore=GHSA-m732-5p4w-x69g",
    "audit:high:ci": "bun run audit:high",
    "release": "bun run build && bun run test && bun run lint && changeset publish",
    "nuke": "docker compose down && docker system prune -a -f && docker volume prune -a -f",
    "services:up": "bun run dotenvx -- docker compose up -d",
    "graphiti:proxy": "bun run scripts/graphiti-mcp-queue-proxy.mjs",
    "graphiti:proxy:ensure": "bash scripts/graphiti-proxy-ensure.sh",
    "graphiti:proxy:service:install": "bash scripts/graphiti-proxy-service-install.sh",
    "kg:proxy": "bash scripts/kg-with-proxy.sh",
    "kg:graphiti-recover:dry-run": "bash scripts/graphiti-recover.sh --dry-run --skip-republish",
    "dotenvx": "bunx @dotenvx/dotenvx run -f .env --",
    "deps:update": "bunx syncpack update --target=latest --dependency-types=catalog",
    "prepare": "effect-language-service patch",
    "postinstall": "lefthook install"
  },
  "resolutions#": {
    "@beep/*": "Needed to force PNPM to install local packages"
  },
