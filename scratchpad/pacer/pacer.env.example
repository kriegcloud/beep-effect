# PACER live-run secret mapping for `op run --env-file`.
#
#   cp scratchpad/pacer/pacer.env.example scratchpad/pacer/pacer.env
#   op run --env-file scratchpad/pacer/pacer.env -- bun scratchpad/pacer/run-live.ts --otp 123456
#
# These are 1Password secret *references* (op://), not secret values; `op run`
# resolves them into the process environment, where effect/Config reads them.
#
# NOTE the QA login id: only LEGAL_PACER_USERNAME (no QA prefix) is stored. PACER
# QA requires a SEPARATE QA account — if its username differs, point this at a
# LEGAL_QA_PACER_USERNAME ref instead.
LEGAL_QA_PACER_USERNAME=op://BEEP_SECRETS/BEEP_SECRETS/LEGAL_PACER_USERNAME

# MUST be added to 1Password — no password ref exists yet.
LEGAL_QA_PACER_PASSWORD=op://BEEP_SECRETS/BEEP_SECRETS/LEGAL_QA_PACER_PASSWORD

# Optional billing/matter attribution code (sent as clientCode + X-CLIENT-CODE).
LEGAL_QA_PACER_CLIENT_CODE=op://BEEP_SECRETS/BEEP_SECRETS/LEGAL_QA_PACER_CLIENT_CODE
