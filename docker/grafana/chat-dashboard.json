{
  "uid": "professional-desktop-chat",
  "title": "Professional Desktop Chat",
  "tags": ["effect", "chat", "professional-desktop"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "logsDatasource",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Assistant turns / min by kind",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "opm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(agents_chat_turns_total[5m])) * 60",
          "legendFormat": "{{kind}}"
        },
        {
          "refId": "B",
          "expr": "sum by (kind) (rate(agents_chat_turn_failures_total[5m])) * 60",
          "legendFormat": "{{kind}} failures"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Turn duration (server, p50 / p95)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(agents_chat_turn_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agents_chat_turn_duration_milliseconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Perceived latency to first block (web, p50 / p95)",
      "description": "Emitted by @beep/agents-client ClientObservabilityLive as service professional-desktop-web; Vite proxies /otlp to the collector in local dev.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(ui_turn_perceived_latency_milliseconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ui_turn_perceived_latency_milliseconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Blocks streamed / min",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "opm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(agents_chat_blocks_streamed_total[5m])) * 60",
          "legendFormat": "{{kind}} blocks"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Composer decode failures (1h)",
      "description": "Emitted by @beep/agents-client reportDecodeFailureAtom through the browser OTLP layer.",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ui_editor_decode_failures_total[1h])) or vector(0)",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Errors (web + sidecar)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 9 },
      "datasource": { "type": "loki", "uid": "${logsDatasource}" },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"professional-desktop-(sidecar|web)\"} | detected_level=~\"error|warn\""
        }
      ]
    }
  ]
}
