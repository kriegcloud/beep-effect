{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp", "--cwd", "apps/editor-app"]
    },
    "mui-mcp": {
      "command": "npx",
      "args": ["-y", "@mui/mcp@latest"]
    },
    "graphiti-memory": {
      "type": "http",
      "url": "http://localhost:8000/mcp"
    },
    "trustgraph": {
      "type": "http",
      "url": "https://dankserver.tailc7c348.ts.net:8444/mcp"
    },
    "greptile": {
      "type": "http",
      "url": "https://api.greptile.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GREPTILE_API_KEY}"
      }
    }
  }
}
