{
  "mcpServers": {
    "shadcn": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "shadcn@latest", "mcp"]
    },
    "next-devtools": {
      "type": "stdio",
      "command": "bunx",
      "args": ["next-devtools-mcp@latest"]
    },
    "graphiti-memory": {
      "type": "http",
      "url": "http://localhost:8123/mcp"
    },
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--language-backend",
        "JetBrains",
        "--project-from-cwd"
      ]
    },
    "nlp": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "./packages/drivers/nlp-mcp/src/bin.ts"]
    },
    "webstorm": {
      "url": "http://127.0.0.1:64542/stream",
      "type": "http",
      "headers": {
        "IJ_MCP_SERVER_PROJECT_PATH": "/home/elpresidank/YeeBois/projects/beep-effect"
      }
    }
  }
}
