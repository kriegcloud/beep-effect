{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": ["core/**/*.ts"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-types",
    "types": ["node", "bun"],
    "noEmit": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "transform": "@effect/language-service/transform",
        "namespaceImportPackages": ["effect", "@effect/*", "@beep/*"],
        "importAliases": {
          "Array": "A",
          "Option": "O",
          "Predicate": "P",
          "Record": "R",
          "Schema": "S",
          "Equal": "Eq"
        },
        "ignoreEffectSuggestionsInTscExitCode": false
      }
    ],
    "paths": {
      "@beep/codex/*": ["./*.ts", "./core/*.ts", "./*"]
    }
  },
  "references": [
    {
      "path": "../packages/common/identity/tsconfig.json"
    },
    {
      "path": "../packages/common/schema/tsconfig.json"
    },
    {
      "path": "../packages/common/utils/tsconfig.json"
    }
  ]
}
