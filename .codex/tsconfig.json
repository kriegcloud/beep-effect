{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": ["Domain/**/*.ts", "test/**/*.ts"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-types",
    "types": ["node", "bun"],
    "noEmit": true,
    "paths": {
      "@beep/codex/*": ["./*.ts", "./core/*.ts", "./*"]
    }
  },
  "references": [
    {
      "path": "../packages/common/schema/tsconfig.json"
    },
    {
      "path": "../packages/common/utils/tsconfig.json"
    },
    {
      "path": "../packages/foundation/modeling/identity/tsconfig.json"
    }
  ]
}
