{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Professional Desktop",
  "version": "0.0.3",
  "identifier": "cloud.beep.professional-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:sidecar && bun run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Professional Desktop",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1421 http://localhost:1421 http://127.0.0.1:3939"
    }
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMEVEMzExMTFFMTE5QjQKUldTMEdlRVJFZE1PaTFoMEdidkRlWVAvNU9ycVEzdklRR3VZeUhIT2w4UXJzN0xLZ05IZ242NncK",
      "endpoints": [
        "https://github.com/kriegcloud/beep-effect/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/sidecar"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
