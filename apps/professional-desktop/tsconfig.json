{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    "src",
    "server",
    "test",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts",
    "../../vitest.shared.ts"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node", "bun", "vite/client"],
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@beep/agents-client": ["../../packages/agents/client/src/index.ts"],
      "@beep/agents-client/Chat.atoms": [
        "../../packages/agents/client/src/Chat.atoms.ts"
      ],
      "@beep/agents-domain": ["../../packages/agents/domain/src/index.ts"],
      "@beep/agents-server/AnthropicTurnKernel": [
        "../../packages/agents/server/src/AssistantTurn/AnthropicTurnKernel.ts"
      ],
      "@beep/agents-use-cases/public": [
        "../../packages/agents/use-cases/src/public.ts"
      ],
      "@beep/agents-use-cases/proof": [
        "../../packages/agents/use-cases/src/proof.ts"
      ],
      "@beep/editor": [
        "../../packages/foundation/ui-system/editor/src/index.ts"
      ],
      "@beep/epistemic-domain": [
        "../../packages/epistemic/domain/src/index.ts"
      ],
      "@beep/epistemic-tables/entities/UsageRecord": [
        "../../packages/epistemic/tables/src/entities/UsageRecord/index.ts"
      ],
      "@beep/postgres": ["../../packages/drivers/postgres/src/index.ts"],
      "@beep/identity": [
        "../../packages/foundation/modeling/identity/src/index.ts"
      ],
      "@beep/identity/*": ["../../packages/foundation/modeling/identity/src/*"],
      "@beep/lexical-schema": [
        "../../packages/foundation/modeling/lexical/src/index.ts"
      ],
      "@beep/lexical-schema/*": [
        "../../packages/foundation/modeling/lexical/src/*"
      ],
      "@beep/md/Md.model": [
        "../../packages/foundation/modeling/md/src/Md.model.ts"
      ],
      "@beep/shared-domain/identity/Workspace": [
        "../../packages/shared/domain/src/identity/Workspace.ts"
      ],
      "@beep/test-utils": [
        "../../packages/tooling/test-kit/test-utils/src/index.ts"
      ],
      "@beep/test-utils/*": [
        "../../packages/tooling/test-kit/test-utils/src/*"
      ],
      "@beep/ui": ["../../packages/foundation/ui-system/ui/src/index.ts"],
      "@beep/ui/*": ["../../packages/foundation/ui-system/ui/src/*"],
      "@beep/utils": ["../../packages/foundation/modeling/utils/src/index.ts"],
      "@beep/utils/*": ["../../packages/foundation/modeling/utils/src/*"],
      "@beep/workspace-domain": [
        "../../packages/workspace/domain/src/index.ts"
      ],
      "@beep/workspace-server": [
        "../../packages/workspace/server/src/index.ts"
      ],
      "@beep/workspace-server/aggregates/Thread": [
        "../../packages/workspace/server/src/aggregates/Thread/index.ts"
      ],
      "@beep/workspace-use-cases/public": [
        "../../packages/workspace/use-cases/src/public.ts"
      ],
      "@beep/workspace-use-cases/server": [
        "../../packages/workspace/use-cases/src/server.ts"
      ]
    },
    "outDir": "dist",
    "rootDir": "../.."
  },
  "references": [
    {
      "path": "../../packages/agents/client/tsconfig.json"
    },
    {
      "path": "../../packages/agents/domain/tsconfig.json"
    },
    {
      "path": "../../packages/agents/server/tsconfig.json"
    },
    {
      "path": "../../packages/agents/use-cases/tsconfig.json"
    },
    {
      "path": "../../packages/drivers/pglite/tsconfig.json"
    },
    {
      "path": "../../packages/drivers/postgres/tsconfig.json"
    },
    {
      "path": "../../packages/epistemic/domain/tsconfig.json"
    },
    {
      "path": "../../packages/epistemic/tables/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/identity/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/lexical/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/md/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/utils/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/ui-system/editor/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/ui-system/ui/tsconfig.json"
    },
    {
      "path": "../../packages/shared/domain/tsconfig.json"
    },
    {
      "path": "../../packages/tooling/test-kit/test-utils/tsconfig.json"
    },
    {
      "path": "../../packages/workspace/domain/tsconfig.json"
    },
    {
      "path": "../../packages/workspace/server/tsconfig.json"
    },
    {
      "path": "../../packages/workspace/use-cases/tsconfig.json"
    },
    {
      "path": "../../packages/drivers/anthropic/tsconfig.json"
    }
  ]
}
