{
  "name": "@beep/professional-desktop",
  "version": "0.0.3",
  "description": "Minimal Tauri and React shell for the Agentic Professional Runtime desktop app.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/apps/professional-desktop",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "apps/professional-desktop"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "codegen": "bun run scripts/sync-migration-bundle.ts --write",
    "codegen:check": "bun run scripts/sync-migration-bundle.ts --check",
    "dev": "vite --host 127.0.0.1",
    "dev:sidecar": "CHAT_AGENT=fixture bun run server/main.ts",
    "sidecar": "bun run server/main.ts",
    "build:sidecar": "bun run scripts/build-sidecar.ts",
    "dev:tauri": "tauri dev",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "vite build",
    "beep:check": "tsgo -b tsconfig.json && bun run codegen:check",
    "beep:lint": "biome check package.json postcss.config.mjs tsconfig.json vite.config.ts vitest.config.ts vitest.integration.config.ts index.html public src server scripts test src-tauri/tauri.conf.json src-tauri/capabilities/default.json",
    "beep:lint:fix": "biome check package.json postcss.config.mjs tsconfig.json vite.config.ts vitest.config.ts vitest.integration.config.ts index.html public src server scripts test src-tauri/tauri.conf.json src-tauri/capabilities/default.json --write",
    "beep:test": "bunx --bun vitest run --exclude=test/integration/**",
    "beep:test:integration": "bunx --bun vitest run --config vitest.integration.config.ts --passWithNoTests",
    "beep:test:integration:ipc": "bun run build:sidecar && BEEP_TEST_SIDECAR_IPC=1 bunx --bun vitest run --config vitest.integration.config.ts test/integration/sidecar-ipc-stdio.test.ts",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage --exclude=test/integration/**",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "test:integration": "bun run beep:test:integration"
  },
  "dependencies": {
    "@beep/agents-client": "workspace:^",
    "@beep/agents-domain": "workspace:^",
    "@beep/agents-server": "workspace:^",
    "@beep/agents-use-cases": "workspace:^",
    "@beep/editor": "workspace:^",
    "@beep/epistemic-domain": "workspace:^",
    "@beep/epistemic-tables": "workspace:^",
    "@beep/identity": "workspace:^",
    "@beep/lexical-schema": "workspace:^",
    "@beep/md": "workspace:^",
    "@beep/pglite": "workspace:^",
    "@beep/postgres": "workspace:^",
    "@beep/shared-domain": "workspace:^",
    "@beep/ui": "workspace:^",
    "@beep/utils": "workspace:^",
    "@beep/workspace-domain": "workspace:^",
    "@beep/workspace-server": "workspace:^",
    "@beep/workspace-use-cases": "workspace:^",
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@tauri-apps/api": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@beep/test-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@electric-sql/pglite": "0.4.6",
    "@tauri-apps/cli": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
