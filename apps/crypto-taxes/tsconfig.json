{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "references": [
    {
      "path": "../../packages/common/data/tsconfig.json"
    },
    {
      "path": "../../packages/common/identity/tsconfig.json"
    },
    {
      "path": "../../packages/common/messages/tsconfig.json"
    },
    {
      "path": "../../packages/common/schema/tsconfig.json"
    },
    {
      "path": "../../packages/common/types/tsconfig.json"
    },
    {
      "path": "../../packages/common/ui/tsconfig.json"
    },
    {
      "path": "../../packages/common/utils/tsconfig.json"
    }
  ],
  "exclude": ["node_modules"]
}
