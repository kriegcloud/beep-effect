{
  "name": "@beep/op-ip-web",
  "version": "0.0.0",
  "description": "Next.js canary app wired to shared @beep/ui styling and portless dev URLs",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/kriegcloud/beep-effect/tree/main/apps/op-ip-web",
  "repository": {
    "type": "git",
    "url": "git@github.com:kriegcloud/beep-effect.git",
    "directory": "apps/op-ip-web"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "codegen": "echo 'no codegen needed'",
    "dev": "PORTLESS_HTTPS=1 NEXT_DISABLE_PWA=1 portless op-ip-web next dev --turbopack",
    "dev:raw": "NEXT_DISABLE_PWA=1 next dev --turbopack",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run type-test && bun run beep:test && bun run beep:lint",
    "beep:build": "NEXT_DISABLE_PWA=1 next build --turbopack",
    "build:pwa": "NEXT_DISABLE_PWA=0 next build --webpack",
    "start": "next start",
    "beep:check": "tsgo -b tsconfig.json",
    "dtslint": "bunx tstyche dtslint/op-ip-web.tst.ts",
    "type-test": "bun run dtslint",
    "beep:lint": "biome check .",
    "beep:lint:fix": "biome check . --write",
    "beep:test": "bunx --bun vitest run",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "coverage": "bunx --bun vitest run --coverage",
    "docgen": "bun run ../../packages/tooling/tool/docgen/src/bin.ts",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@beep/identity": "workspace:^",
    "@beep/repo-configs": "workspace:^",
    "@beep/schema": "workspace:^",
    "@beep/ui": "workspace:^",
    "@beep/utils": "workspace:^",
    "@mdx-js/react": "catalog:",
    "@next/bundle-analyzer": "catalog:",
    "@next/mdx": "catalog:",
    "next": "catalog:",
    "next-pwa": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@beep/repo-utils": "workspace:^",
    "@effect/vitest": "catalog:",
    "@mdx-js/loader": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/mdx": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
