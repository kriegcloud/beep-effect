      "@beep/installer-workspace-use-cases": [
        "../../packages/installer-workspace/use-cases/src/index.ts"
      ],
      "@beep/installer-workspace-use-cases/public": [
        "../../packages/installer-workspace/use-cases/src/public.ts"
      ],
      "@beep/installer-workspace-use-cases/server": [
        "../../packages/installer-workspace/use-cases/src/server.ts"
      ],
      "@beep/schema": [
        "../../packages/foundation/modeling/schema/src/index.ts"
      ],
      "@beep/schema/*": ["../../packages/foundation/modeling/schema/src/*.ts"],
      "@beep/ui": ["../../packages/foundation/ui-system/ui/src/index.ts"],
