      ],
      "@beep/installer-dependencies-use-cases": [
        "../../packages/installer-dependencies/use-cases/src/index.ts"
      ],
      "@beep/installer-dependencies-use-cases/public": [
        "../../packages/installer-dependencies/use-cases/src/public.ts"
      ],
      "@beep/installer-dependencies-use-cases/server": [
        "../../packages/installer-dependencies/use-cases/src/server.ts"
      ],
      "@beep/installer-providers-use-cases": [
        "../../packages/installer-providers/use-cases/src/index.ts"
      ],
      "@beep/installer-providers-use-cases/public": [
        "../../packages/installer-providers/use-cases/src/public.ts"
      ],
      "@beep/installer-providers-use-cases/server": [
        "../../packages/installer-providers/use-cases/src/server.ts"
      ],
      "@beep/installer-security-use-cases": [
        "../../packages/installer-security/use-cases/src/index.ts"
