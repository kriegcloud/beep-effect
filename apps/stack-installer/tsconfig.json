{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": ["src", "test", "vite.config.ts"],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node", "vite/client"],
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@beep/ui": ["../../packages/foundation/ui-system/ui/src/index.ts"],
      "@beep/ui/*": ["../../packages/foundation/ui-system/ui/src/*"]
    },
    "outDir": "dist",
    "rootDir": "../.."
  },
  "references": [
    {
      "path": "../../packages/drivers/ai-provider-cli/tsconfig.json"
    },
    {
      "path": "../../packages/drivers/discord/tsconfig.json"
    },
    {
      "path": "../../packages/drivers/onepassword-cli/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/schema/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/ui-system/ui/tsconfig.json"
    },
    {
      "path": "../../packages/installer/server/tsconfig.json"
    },
    {
      "path": "../../packages/installer/use-cases/tsconfig.json"
    },
    {
      "path": "../../packages/shared/domain/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/identity/tsconfig.json"
    },
    {
      "path": "../../packages/installer/domain/tsconfig.json"
    }
  ]
}
