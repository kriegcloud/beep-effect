{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    "next-env.d.ts",
    "src",
    "test",
    "dtslint",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "next.config.ts"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["node"],
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@beep/ui": ["../../packages/common/ui/src/index.ts"],
      "@beep/ui/*": ["../../packages/common/ui/src/*"]
    },
    "outDir": "dist",
    "rootDir": "../.."
  },
  "references": [
    {
      "path": "../../packages/common/identity/tsconfig.json"
    },
    {
      "path": "../../packages/common/schema/tsconfig.json"
    },
    {
      "path": "../../packages/common/ui/tsconfig.json"
    },
    {
      "path": "../../packages/common/utils/tsconfig.json"
    }
  ]
}
