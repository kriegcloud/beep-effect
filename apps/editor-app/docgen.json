{
  "$schema": "../../tooling/docgen/schema.json",
  "exclude": ["src/internal/**/*.ts"],
  "srcLink": "https://github.com/kriegcloud/beep-effect/tree/main/apps/editor-app/src/",
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "stripInternal": false,
    "noErrorTruncation": true,
    "types": [],
    "jsx": "react-jsx",
    "paths": {
      "@beep/editor-app": ["../../apps/editor-app/src/index.ts"],
      "@beep/editor-app/*": ["../../apps/editor-app/src/*.ts"],
      "@beep/editor-client": ["../../packages/editor/client/src/index.ts"],
      "@beep/editor-client/*": ["../../packages/editor/client/src/*.ts"],
      "@beep/editor-lexical": ["../../packages/editor/lexical/src/index.ts"],
      "@beep/editor-lexical/*": ["../../packages/editor/lexical/src/*.ts"],
      "@beep/editor-protocol": ["../../packages/editor/protocol/src/index.ts"],
      "@beep/editor-protocol/*": ["../../packages/editor/protocol/src/*.ts"],
      "@beep/identity": ["../../packages/common/identity/src/index.ts"],
      "@beep/identity/*": ["../../packages/common/identity/src/*.ts"],
      "@beep/identity/packages": [
        "../../packages/common/identity/src/packages.ts"
      ],
      "@beep/schema": ["../../packages/common/schema/src/index.ts"],
      "@beep/schema/*": ["../../packages/common/schema/src/*.ts"],
      "@beep/types": ["../../packages/common/types/src/index.ts"],
      "@beep/types/*": ["../../packages/common/types/src/*.ts"],
      "@beep/ui": ["../../packages/common/ui/src/index.ts"],
      "@beep/ui/*": ["../../packages/common/ui/src/*.ts"],
      "@beep/ui/themes": ["../../packages/common/ui/src/themes/index.ts"],
      "@beep/ui/styles/globals.css": [
        "../../packages/common/ui/src/styles/globals.css"
      ],
      "@beep/ui/postcss.config": [
        "../../packages/common/ui/postcss.config.mjs"
      ],
      "@beep/ui/components/blocks/editor-00/editor": [
        "../../packages/common/ui/src/components/blocks/editor-00/editor.tsx"
      ],
      "@beep/ui/components/editor/editor-ui/content-editable": [
        "../../packages/common/ui/src/components/editor/editor-ui/content-editable.tsx"
      ],
      "@beep/ui/components/editor/themes/editor-theme": [
        "../../packages/common/ui/src/components/editor/themes/editor-theme.ts"
      ],
      "@beep/utils": ["../../packages/common/utils/src/index.ts"],
      "@beep/utils/*": ["../../packages/common/utils/src/*.ts"]
    }
  }
}
