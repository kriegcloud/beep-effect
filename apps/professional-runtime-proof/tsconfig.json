{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": ["src", "test"],
  "compilerOptions": {
    "types": ["bun", "node"],
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "@beep/agent-capability-domain": [
        "../../packages/agent-capability/domain/src/index.ts"
      ],
      "@beep/agent-capability-domain/*": [
        "../../packages/agent-capability/domain/src/*"
      ],
      "@beep/agent-capability-use-cases": [
        "../../packages/agent-capability/use-cases/src/index.ts"
      ],
      "@beep/agent-capability-use-cases/*": [
        "../../packages/agent-capability/use-cases/src/*"
      ],
      "@beep/agent-capability-use-cases/public": [
        "../../packages/agent-capability/use-cases/src/public.ts"
      ],
      "@beep/agent-capability-use-cases/server": [
        "../../packages/agent-capability/use-cases/src/server.ts"
      ],
      "@beep/agent-capability-use-cases/test": [
        "../../packages/agent-capability/use-cases/src/test.ts"
      ],
      "@beep/epistemic-domain": [
        "../../packages/epistemic/domain/src/index.ts"
      ],
      "@beep/epistemic-domain/*": ["../../packages/epistemic/domain/src/*"],
      "@beep/law-practice-domain": [
        "../../packages/law-practice/domain/src/index.ts"
      ],
      "@beep/law-practice-domain/*": [
        "../../packages/law-practice/domain/src/*"
      ],
      "@beep/tenancy-domain": ["../../packages/tenancy/domain/src/index.ts"],
      "@beep/tenancy-domain/*": ["../../packages/tenancy/domain/src/*"],
      "@beep/wealth-management-domain": [
        "../../packages/wealth-management/domain/src/index.ts"
      ],
      "@beep/wealth-management-domain/*": [
        "../../packages/wealth-management/domain/src/*"
      ],
      "@beep/workspace-domain": [
        "../../packages/workspace/domain/src/index.ts"
      ],
      "@beep/workspace-domain/*": ["../../packages/workspace/domain/src/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/agent-capability/domain/tsconfig.json"
    },
    {
      "path": "../../packages/agent-capability/use-cases/tsconfig.json"
    },
    {
      "path": "../../packages/epistemic/domain/tsconfig.json"
    },
    {
      "path": "../../packages/law-practice/domain/tsconfig.json"
    },
    {
      "path": "../../packages/tenancy/domain/tsconfig.json"
    },
    {
      "path": "../../packages/wealth-management/domain/tsconfig.json"
    },
    {
      "path": "../../packages/workspace/domain/tsconfig.json"
    }
  ]
}
