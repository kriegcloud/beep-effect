{
  "name": "@beep/desktop",
  "version": "0.0.0",
  "description": "Thin React shell for the local-first repo-memory desktop prototype",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev-with-portless.ts",
    "dev:desktop": "PORTLESS_HTTPS=1 portless desktop vite",
    "dev:raw": "vite",
    "dev:native": "tauri dev",
    "build": "vite build",
    "build:native": "tauri build",
    "build:sidecar": "bun run scripts/build-sidecar.ts",
    "check": "tsgo -b tsconfig.json && tsgo -p tsconfig.test.json --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "test": "bunx --bun vitest run"
  },
  "dependencies": {
    "@beep/repo-memory-client": "workspace:^",
    "@beep/runtime-protocol": "workspace:^",
    "@beep/schema": "workspace:^",
    "@effect/platform-bun": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tauri-apps/api": "catalog:",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tauri-apps/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
