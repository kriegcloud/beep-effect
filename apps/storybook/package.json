{
  "name": "@beep/storybook",
  "version": "0.0.0",
  "description": "Executable Storybook host for foundation UI-system package stories.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/apps/storybook",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "apps/storybook"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "codegen": "echo 'no codegen needed'",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "storybook": "portless storybook.beep sh -c 'storybook dev -p \"${PORT:-6006}\"'",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:start": "portless storybook.beep sh -c 'vite preview --host 0.0.0.0 --port \"${PORT:-6006}\" --outDir storybook-static'",
    "test:storybook": "sh -c 'if [ \"${CI:-}\" != \"true\" ]; then playwright install --only-shell chromium; fi; bun run test:storybook:ui && bun run test:storybook:editor && bun run test:storybook:form'",
    "test:storybook:editor": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/editor/stories",
    "test:storybook:form": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/form/stories",
    "test:storybook:ui": "bun run test:storybook:ui:1 && bun run test:storybook:ui:2 && bun run test:storybook:ui:3 && bun run test:storybook:ui:4",
    "test:storybook:ui:1": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/ui/stories/components/accordion.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/alert-dialog.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/alert.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/aspect-ratio.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/avatar.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/badge.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/banner.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/breadcrumb.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/button-group.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/button.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/calendar-event-card.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/calendar.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/card.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/carousel.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/chart.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/checkbox.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/collapsible.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/combobox.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/command.stories.tsx",
    "test:storybook:ui:2": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/ui/stories/components/context-menu.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/conversation.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/date-picker.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/dialog.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/direction.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/drawer.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/dropdown-menu.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/empty.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/field.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/hover-card.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/input-group.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/input-otp.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/input.stories.tsx",
    "test:storybook:ui:3": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/ui/stories/components/item.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/kbd.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/knowledge-graph.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/label.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/link-preview.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/menubar.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/mui-theme.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/native-select.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/navigation-menu.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/notification-card.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/orb-background.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/orb.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/pagination.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/popover.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/progress.stories.tsx",
    "test:storybook:ui:4": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/ui/stories/components/radio-group.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/resizable.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/scroll-area.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/select.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/separator.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/sheet.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/sidebar.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/skeleton.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/slider.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/sonner.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/spinner.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/switch.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/table.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/tabs.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/textarea.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/toast.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/toaster.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/todo-item.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/toggle-group.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/toggle.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/toolbar.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/tooltip.stories.tsx ../../packages/foundation/ui-system/ui/stories/components/tour.stories.tsx",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "bun run storybook:build",
    "beep:check": "tsgo -b tsconfig.json && tsc -p tsconfig.stories.json --noEmit",
    "beep:test": "bunx --bun vitest run --passWithNoTests",
    "beep:lint": "biome check package.json postcss.config.mjs tsconfig.json tsconfig.stories.json vitest.config.ts vitest.storybook.config.ts vitest.storybook.setup.ts .storybook/ ../../packages/foundation/ui-system/*/stories/",
    "beep:lint:fix": "biome check package.json postcss.config.mjs tsconfig.json tsconfig.stories.json vitest.config.ts vitest.storybook.config.ts vitest.storybook.setup.ts .storybook/ ../../packages/foundation/ui-system/*/stories/ --write"
  },
  "dependencies": {
    "@beep/form": "workspace:^",
    "@beep/ui": "workspace:^",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "emojibase-data": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
