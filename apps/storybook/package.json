{
  "name": "@beep/storybook",
  "version": "0.0.0",
  "description": "Executable Storybook host for foundation UI-system package stories.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/beep-effect/beep-effect/tree/main/apps/storybook",
  "repository": {
    "type": "git",
    "url": "git@github.com:beep-effect/beep-effect.git",
    "directory": "apps/storybook"
  },
  "scripts": {
    "audit": "bun run --if-present beep:audit",
    "codegen": "echo 'no codegen needed'",
    "build": "bun run beep:build",
    "check": "bun run beep:check",
    "lint": "bun run beep:lint",
    "lint:fix": "bun run beep:lint:fix",
    "test": "bun run beep:test",
    "storybook": "portless storybook.beep sh -c 'storybook dev -p \"${PORT:-6006}\"'",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:start": "portless storybook.beep sh -c 'vite preview --host 0.0.0.0 --port \"${PORT:-6006}\" --outDir storybook-static'",
    "test:storybook": "sh -c 'if [ \"${CI:-}\" != \"true\" ]; then playwright install --only-shell chromium; fi; bun run test:storybook:ui && bun run test:storybook:editor && bun run test:storybook:form'",
    "test:storybook:editor": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/editor/stories",
    "test:storybook:form": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/form/stories",
    "test:storybook:ui": "vitest run --config vitest.storybook.config.ts ../../packages/foundation/ui-system/ui/stories",
    "beep:audit": "bun run beep:build && bun run beep:check && bun run beep:test && bun run beep:lint",
    "beep:build": "bun run storybook:build",
    "beep:check": "tsgo -b tsconfig.json && tsc -p tsconfig.stories.json --noEmit",
    "beep:test": "bunx --bun vitest run --passWithNoTests",
    "beep:lint": "biome check package.json postcss.config.mjs tsconfig.json tsconfig.stories.json vitest.config.ts vitest.storybook.config.ts vitest.storybook.setup.ts .storybook/ ../../packages/foundation/ui-system/*/stories/",
    "beep:lint:fix": "biome check package.json postcss.config.mjs tsconfig.json tsconfig.stories.json vitest.config.ts vitest.storybook.config.ts vitest.storybook.setup.ts .storybook/ ../../packages/foundation/ui-system/*/stories/ --write"
  },
  "dependencies": {
    "@beep/form": "workspace:^",
    "@beep/ui": "workspace:^",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-themes": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "emojibase-data": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
