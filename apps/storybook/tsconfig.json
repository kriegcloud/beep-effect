{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "vitest.config.ts",
    "vitest.storybook.config.ts",
    "vitest.storybook.setup.ts"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@beep/ui": ["../../packages/foundation/ui-system/ui/src/index.ts"],
      "@beep/ui/*": ["../../packages/foundation/ui-system/ui/src/*"]
    },
    "outDir": "dist",
    "rootDir": "../.."
  },
  "references": [
    {
      "path": "../../packages/foundation/ui-system/form/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/ui-system/ui/tsconfig.json"
    }
  ]
}
