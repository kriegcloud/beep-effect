{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    "src",
    "test",
    "vite.config.ts",
    "vitest.config.ts",
    "../../vitest.shared.ts"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist",
    "rootDir": "../.."
  },
  "references": [
    {
      "path": "../../packages/canvas/domain/tsconfig.json"
    },
    {
      "path": "../../packages/canvas/server/tsconfig.json"
    },
    {
      "path": "../../packages/canvas/use-cases/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/identity/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/modeling/schema/tsconfig.json"
    },
    {
      "path": "../../packages/foundation/ui-system/ui/tsconfig.json"
    }
  ]
}
