{
  "name": "gotham-api-explorer-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:remote": "vite --mode code-workspaces",
    "build": "tsc && vite build && node copyright-manager.js check",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview",
    "copyright:add": "node copyright-manager.js add",
    "copyright:check": "node copyright-manager.js check"
  },
  "dependencies": {
    "@blueprintjs/core": "^5.16.4",
    "@gotham-api-explorer-app/sdk": "^0.1.0",
    "@osdk/client": "^2.4.2",
    "@osdk/foundry": "^2.35.0",
    "@osdk/oauth": "^1.4.0",
    "@reduxjs/toolkit": "2.6.1",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.23.1",
    "redux-saga": "^1.3.0",
    "rehype-react": "^8.0.0",
    "remark-directive": "^3.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.12",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "sass": "^1.85.1",
    "sass-embedded": "^1.83.4",
    "typescript": "~5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
