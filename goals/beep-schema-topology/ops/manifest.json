{
  "schemaVersion": "initiative-manifest/v1",
  "initiative": {
    "id": "beep-schema-topology",
    "title": "@beep/schema Topology",
    "status": "completed",
    "created": "2026-05-22",
    "updated": "2026-05-22",
    "packetAnchorDocument": "SPEC.md"
  },
  "mission": "Canonize and migrate @beep/schema to namespace-first concept modules with small role files, exact PascalCase public subpaths, and lint-enforced topology closure.",
  "currentSourceOfTruth": "SPEC.md",
  "currentTargetPhase": "complete",
  "package": {
    "name": "@beep/schema",
    "path": "packages/foundation/modeling/schema",
    "family": "foundation",
    "kind": "modeling"
  },
  "canonicalImport": "import * as Duration from \"@beep/schema/Duration\"",
  "pilotConcepts": ["Duration", "Glob"],
  "migratedTopicalConcepts": [
    "Age",
    "Blockchain",
    "CardinalDirection",
    "Color",
    "CryptoTxnHash",
    "CryptoWalletAddress",
    "Csv",
    "CsvCodecOptions",
    "CsvError",
    "CsvFormatter",
    "CsvParser",
    "Csp",
    "CrossOriginEmbedderPolicy",
    "CrossOriginOpenerPolicy",
    "CrossOriginResourcePolicy",
    "Dom",
    "DomCssProperties",
    "DomDragEvent",
    "DomEvent",
    "DomHtmlElement",
    "DomMouseEvent",
    "DomReactNode",
    "EthAmount",
    "EthereumValidatorPublicKey",
    "EvmAddress",
    "ExpectCt",
    "ForceHttpsRedirect",
    "FrameGuard",
    "Http",
    "HttpHeaders",
    "HttpMethod",
    "HttpProtocol",
    "HttpStatus",
    "Location",
    "NoOpen",
    "NoSniff",
    "ParserOptions",
    "PermissionsPolicy",
    "PermittedCrossDomainPolicies",
    "Person",
    "ReferrerPolicy",
    "SecureHeader",
    "SecureHeaderError",
    "SecureHeaderOptions",
    "Sex",
    "XssProtection"
  ],
  "migratedHighContextConcepts": [
    "CauseTaggedError",
    "DateTimeUtcFromValid",
    "EntitySchema",
    "FilePath",
    "Fn",
    "Glob",
    "Graph",
    "LiteralKit",
    "LocalDate",
    "MappedLiteralKit",
    "Model",
    "Record",
    "StatusCauseTaggedErrorClass",
    "TaggedErrorClass",
    "Timestamp",
    "VariantSchema"
  ],
  "explicitHighContextConcepts": [
    "EntitySchema",
    "FilePath",
    "Fn",
    "Graph",
    "LiteralKit",
    "MappedLiteralKit",
    "Model",
    "Record",
    "VariantSchema"
  ],
  "phases": [
    {
      "id": "P0",
      "name": "Doctrine and goal packet",
      "status": "completed",
      "exitCriteriaSummary": "Architecture docs, package README, and goal packet agree on canonical topology."
    },
    {
      "id": "P1",
      "name": "Pilot concept modules",
      "status": "completed",
      "exitCriteriaSummary": "Duration and Glob expose canonical concept indexes while old imports remain compatible."
    },
    {
      "id": "P2",
      "name": "Simple concept migration",
      "status": "completed",
      "exitCriteriaSummary": "Targeted topical concepts expose canonical exact subpaths from PascalCase source directories; Sql and sqlite remain deleted."
    },
    {
      "id": "P3",
      "name": "Large concept family migration",
      "status": "completed",
      "exitCriteriaSummary": "Remaining high-context modules are split into role files without changing behavior."
    },
    {
      "id": "P4",
      "name": "Consumer and export hardening",
      "status": "completed",
      "exitCriteriaSummary": "Package-local consumers and type tests prefer concept imports, handwritten lowercase topical imports are gone, and root-facade cleanup continues on touch."
    },
    {
      "id": "P5",
      "name": "Exact export closure",
      "status": "completed",
      "exitCriteriaSummary": "Every public schema subpath is explicit; SchemaUtils helper leaves remain public; the broad package wildcard is removed."
    },
    {
      "id": "P6",
      "name": "Remaining source topology cleanup",
      "status": "completed",
      "exitCriteriaSummary": "Lowercase suite directories are removed; remaining high-context concepts have canonical folders and only future value-adding splits remain."
    },
    {
      "id": "P7",
      "name": "Enforcement automation",
      "status": "completed",
      "exitCriteriaSummary": "bun run beep lint schema-topology prevents lowercase topology, public role-file exports, retired casing aliases, and root alias drift."
    }
  ],
  "verification": [
    "bun run --cwd packages/foundation/modeling/schema check",
    "bun run --cwd packages/foundation/modeling/schema test",
    "bunx tstyche packages/foundation/modeling/schema/dtslint/Topology.tst.ts packages/foundation/modeling/schema/dtslint/Duration.tst.ts packages/foundation/modeling/schema/dtslint/Glob.tst.ts",
    "bun run beep lint schema-topology",
    "bun run --cwd packages/tooling/tool/cli check",
    "bun run --cwd packages/tooling/tool/cli test -- test/schema-topology.test.ts",
    "bun run --cwd packages/foundation/modeling/schema docgen",
    "bun run docgen:local",
    "bun run repo-exports:catalog",
    "bun run repo-exports:catalog:check"
  ],
  "exportClosure": {
    "broadPackageWildcardRemoved": true,
    "generatedWildcardAliasRemoved": true,
    "schemaUtilsHelperLeavesRemainPublic": true,
    "conceptRoleFilesPrivate": true,
    "legacyTopicalSubpathsRemoved": true,
    "legacyAcronymCasingAliasesRemoved": true,
    "schemaTopologyLint": true
  },
  "sourceTopologyCleanup": {
    "httpStatusSplit": true,
    "colorSplit": true,
    "lowercaseSuiteDirectoriesPreserved": false,
    "roleFilesPrivate": true,
    "pendingEvaluationCandidates": [],
    "lowercaseSuiteDirectoriesRemoved": true
  }
}
