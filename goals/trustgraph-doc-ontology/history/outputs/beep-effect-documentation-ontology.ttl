@prefix doc: <urn:beep-effect:doc-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

doc:ontology a owl:Ontology ;
  rdfs:label "beep-effect Documentation Ontology" ;
  rdfs:comment "Documentation-memory ontology for beep-effect. Native TrustGraph TBox only; companion rule instances and semantic-web seed data live in separate outputs." ;
  owl:versionInfo "0.1.0" .

doc:documentation-concept a owl:Class ;
  rdfs:label "documentation concept"@en ;
  rdfs:comment "Base documentation-domain concept used by the beep-effect documentation ontology." .

doc:documentation-standard a owl:Class ;
  rdfs:label "documentation standard"@en ;
  rdfs:comment "Canonical documentation standard or specification that defines a tag or policy surface." ;
  rdfs:subClassOf doc:documentation-concept .

doc:documentation-tag a owl:Class ;
  rdfs:label "documentation tag"@en ;
  rdfs:comment "Documentation tag definition such as @param or @returns." ;
  rdfs:subClassOf doc:documentation-concept .

doc:documentation-rule a owl:Class ;
  rdfs:label "documentation rule"@en ;
  rdfs:comment "Normative documentation rule or policy statement." ;
  rdfs:subClassOf doc:documentation-concept .

doc:documentation-requirement a owl:Class ;
  rdfs:label "documentation requirement"@en ;
  rdfs:comment "Documentation rule that requires a behavior or artifact." ;
  rdfs:subClassOf doc:documentation-rule .

doc:documentation-prohibition a owl:Class ;
  rdfs:label "documentation prohibition"@en ;
  rdfs:comment "Documentation rule that forbids a behavior or artifact." ;
  rdfs:subClassOf doc:documentation-rule .

doc:documentation-artifact a owl:Class ;
  rdfs:label "documentation artifact"@en ;
  rdfs:comment "Documentation artifact or output kind used by generation or validation flows." ;
  rdfs:subClassOf doc:documentation-concept .

doc:documentation-symbol-kind a owl:Class ;
  rdfs:label "documentation symbol kind"@en ;
  rdfs:comment "Normalized bridge kind that connects AST applicability surfaces, docgen entity kinds, and repo symbol kinds." ;
  rdfs:subClassOf doc:documentation-concept .

doc:ast-applicable-kind a owl:Class ;
  rdfs:label "AST applicable kind"@en ;
  rdfs:comment "Raw AST-level documentation attachment kind from the JSDoc models." ;
  rdfs:subClassOf doc:documentation-concept .

doc:docgen-entity-kind a owl:Class ;
  rdfs:label "docgen entity kind"@en ;
  rdfs:comment "Docgen-facing export or entity kind surfaced by repo tooling." ;
  rdfs:subClassOf doc:documentation-concept .

doc:repo-symbol-kind a owl:Class ;
  rdfs:label "repo symbol kind"@en ;
  rdfs:comment "Deterministic TypeScript symbol kind surfaced by repo-utils indexing." ;
  rdfs:subClassOf doc:documentation-concept .

doc:ast-derivability-level a owl:Class ;
  rdfs:label "AST derivability level"@en ;
  rdfs:comment "How much of a documentation tag can be derived mechanically from the AST." ;
  rdfs:subClassOf doc:documentation-concept .

doc:tag-parameter-shape a owl:Class ;
  rdfs:label "tag parameter shape"@en ;
  rdfs:comment "Structured syntax and boolean acceptance metadata for tag parameters." ;
  rdfs:subClassOf doc:documentation-concept .

doc:source-authority a owl:Class ;
  rdfs:label "source authority"@en ;
  rdfs:comment "Source-of-truth authority used to justify seeded facts, mappings, or rules." ;
  rdfs:subClassOf doc:documentation-concept .

doc:validation-tool a owl:Class ;
  rdfs:label "validation tool"@en ;
  rdfs:comment "Validator or analysis tool that enforces or reports on documentation behavior." ;
  rdfs:subClassOf doc:documentation-concept .

doc:validation-support-status a owl:Class ;
  rdfs:label "validation support status"@en ;
  rdfs:comment "Classification of whether a rule is supported today, possible with glue, or not realistic today." ;
  rdfs:subClassOf doc:documentation-concept .

doc:defined-by-standard a owl:ObjectProperty ;
  rdfs:label "defined by standard"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:documentation-standard .

doc:applies-to-kind a owl:ObjectProperty ;
  rdfs:label "applies to kind"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:ast-applicable-kind .

doc:normalizes-to-symbol-kind a owl:ObjectProperty ;
  rdfs:label "normalizes to symbol kind"@en ;
  rdfs:domain doc:ast-applicable-kind ;
  rdfs:range doc:documentation-symbol-kind .

doc:docgen-normalizes-to-symbol-kind a owl:ObjectProperty ;
  rdfs:label "docgen normalizes to symbol kind"@en ;
  rdfs:domain doc:docgen-entity-kind ;
  rdfs:range doc:documentation-symbol-kind .

doc:repo-normalizes-to-symbol-kind a owl:ObjectProperty ;
  rdfs:label "repo normalizes to symbol kind"@en ;
  rdfs:domain doc:repo-symbol-kind ;
  rdfs:range doc:documentation-symbol-kind .

doc:has-ast-derivability a owl:ObjectProperty ;
  rdfs:label "has AST derivability"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:ast-derivability-level .

doc:has-parameter-shape a owl:ObjectProperty ;
  rdfs:label "has parameter shape"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:tag-parameter-shape .

doc:related-tag a owl:ObjectProperty ;
  rdfs:label "related tag"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:documentation-tag .

doc:governed-by-rule a owl:ObjectProperty ;
  rdfs:label "governed by rule"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range doc:documentation-rule .

doc:derived-from-source a owl:ObjectProperty ;
  rdfs:label "derived from source"@en ;
  rdfs:domain doc:documentation-concept ;
  rdfs:range doc:source-authority .

doc:validated-by-tool a owl:ObjectProperty ;
  rdfs:label "validated by tool"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range doc:validation-tool .

doc:produces-artifact-kind a owl:ObjectProperty ;
  rdfs:label "produces artifact kind"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range doc:documentation-artifact .

doc:targets-tag a owl:ObjectProperty ;
  rdfs:label "targets tag"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range doc:documentation-tag .

doc:targets-symbol-kind a owl:ObjectProperty ;
  rdfs:label "targets symbol kind"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range doc:documentation-symbol-kind .

doc:has-support-status a owl:ObjectProperty ;
  rdfs:label "has support status"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range doc:validation-support-status .

doc:canonical-tag-name a owl:DatatypeProperty ;
  rdfs:label "canonical tag name"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range xsd:string .

doc:syntax-template a owl:DatatypeProperty ;
  rdfs:label "syntax template"@en ;
  rdfs:domain doc:tag-parameter-shape ;
  rdfs:range xsd:string .

doc:accepts-type a owl:DatatypeProperty ;
  rdfs:label "accepts type"@en ;
  rdfs:domain doc:tag-parameter-shape ;
  rdfs:range xsd:boolean .

doc:accepts-name a owl:DatatypeProperty ;
  rdfs:label "accepts name"@en ;
  rdfs:domain doc:tag-parameter-shape ;
  rdfs:range xsd:boolean .

doc:accepts-description a owl:DatatypeProperty ;
  rdfs:label "accepts description"@en ;
  rdfs:domain doc:tag-parameter-shape ;
  rdfs:range xsd:boolean .

doc:deprecation-state a owl:DatatypeProperty ;
  rdfs:label "deprecation state"@en ;
  rdfs:domain doc:documentation-tag ;
  rdfs:range xsd:string .

doc:descriptive-notes a owl:DatatypeProperty ;
  rdfs:label "descriptive notes"@en ;
  rdfs:domain doc:documentation-concept ;
  rdfs:range xsd:string .

doc:stable-provenance-id a owl:DatatypeProperty ;
  rdfs:label "stable provenance id"@en ;
  rdfs:domain doc:documentation-concept ;
  rdfs:range xsd:string .

doc:enforcement-notes a owl:DatatypeProperty ;
  rdfs:label "enforcement notes"@en ;
  rdfs:domain doc:documentation-rule ;
  rdfs:range xsd:string .

doc:source-location a owl:DatatypeProperty ;
  rdfs:label "source location"@en ;
  rdfs:domain doc:source-authority ;
  rdfs:range xsd:string .
