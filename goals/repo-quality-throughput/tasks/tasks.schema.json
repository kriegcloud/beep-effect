{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/repo-quality-throughput/tasks.schema.json",
  "title": "Repo Quality Throughput Task Inventory",
  "type": "object",
  "required": ["schemaVersion", "updated", "rankingMethod", "tasks"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "rankingMethod": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "rank",
        "status",
        "lane",
        "title",
        "commandsOrChecks",
        "baseline",
        "expectedImpact",
        "benefitGate",
        "expectedDelta",
        "frequency",
        "correctnessRisk",
        "resourceRisk",
        "implementationCost",
        "proofBurden",
        "confidence",
        "selectionRationale",
        "implementationScope",
        "proofCommands",
        "acceptanceCommands",
        "rollbackPlan",
        "rollbackCommands",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^rqt-[0-9]{3}$"
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "seeded-hypothesis",
            "candidate",
            "selected",
            "in-progress",
            "done",
            "deferred",
            "rejected"
          ]
        },
        "lane": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "commandsOrChecks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "baseline": {
          "type": "object",
          "required": ["status", "evidence"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending",
                "measured",
                "already-fast",
                "not-measurable-yet",
                "not-applicable"
              ]
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "expectedImpact": {
          "type": "string"
        },
        "correctnessRisk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "resourceRisk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "benefitGate": {
          "type": "string"
        },
        "expectedDelta": {
          "type": "object",
          "required": ["status", "summary"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pending-measurement",
                "direct-speedup",
                "measurement-unlocking",
                "safety-resource",
                "regression-guard",
                "not-applicable"
              ]
            },
            "summary": {
              "type": "string"
            },
            "seconds": {
              "type": ["number", "null"]
            },
            "percent": {
              "type": ["number", "null"]
            }
          }
        },
        "frequency": {
          "type": "string",
          "enum": [
            "every-edit",
            "every-commit",
            "every-push",
            "every-pr",
            "push-main",
            "scheduled-or-release",
            "unknown"
          ]
        },
        "implementationCost": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "proofBurden": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "selectionRationale": {
          "type": "string"
        },
        "implementationScope": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "proofCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "acceptanceCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "rollbackPlan": {
          "type": "string"
        },
        "rollbackCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "notes": {
          "type": "string"
        },
        "selected": {
          "$ref": "#/$defs/selected"
        },
        "done": {
          "$ref": "#/$defs/done"
        },
        "deferred": {
          "$ref": "#/$defs/deferred"
        },
        "rejected": {
          "$ref": "#/$defs/rejected"
        },
        "waiverRecord": {
          "$ref": "#/$defs/waiverRecord"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "selected"
              }
            }
          },
          "then": {
            "required": ["selected"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "in-progress"
              }
            }
          },
          "then": {
            "required": ["selected"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "done"
              }
            }
          },
          "then": {
            "required": ["selected", "done"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "deferred"
              }
            }
          },
          "then": {
            "required": ["deferred"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "rejected"
              }
            }
          },
          "then": {
            "required": ["rejected"]
          }
        }
      ]
    },
    "selected": {
      "type": "object",
      "required": [
        "selectionEvidence",
        "substantialBenefitGate",
        "currentPrCandidate",
        "fallbackProof"
      ],
      "additionalProperties": false,
      "properties": {
        "selectionEvidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "substantialBenefitGate": {
          "type": "string"
        },
        "currentPrCandidate": {
          "type": "boolean"
        },
        "fallbackProof": {
          "type": "string"
        }
      }
    },
    "done": {
      "type": "object",
      "required": [
        "beforeAfterRows",
        "proofEvidence",
        "finalProofCommands",
        "commitOrRunId",
        "confidence",
        "qualityReviewStatus"
      ],
      "additionalProperties": false,
      "properties": {
        "beforeAfterRows": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "proofEvidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "finalProofCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "commitOrRunId": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "qualityReviewStatus": {
          "type": "string"
        }
      }
    },
    "deferred": {
      "type": "object",
      "required": ["reason", "ownerOrSurface", "residualRisk", "nextProofStep"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "ownerOrSurface": {
          "type": "string"
        },
        "residualRisk": {
          "type": "string"
        },
        "nextProofStep": {
          "type": "string"
        },
        "followUpTrigger": {
          "type": "string"
        }
      }
    },
    "rejected": {
      "type": "object",
      "required": ["reason", "evidence"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "waiverRecord": {
      "type": "object",
      "required": [
        "sourceStandard",
        "reason",
        "owner",
        "expiryOrFollowUp",
        "residualRisk",
        "acceptanceEvidence"
      ],
      "additionalProperties": false,
      "properties": {
        "sourceStandard": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "expiryOrFollowUp": {
          "type": "string"
        },
        "residualRisk": {
          "type": "string"
        },
        "acceptanceEvidence": {
          "type": "string"
        }
      }
    }
  }
}
