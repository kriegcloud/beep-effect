{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/fallow-quality-enforcement/report-envelope-fixtures.schema.json",
  "title": "Fallow Report Envelope Fixtures",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "fixtures",
    "yeetIssueFixtures"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/report-fixtures/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "schemaVersion",
          "toolVersion",
          "command",
          "subcommand",
          "baseRef",
          "generatedAt",
          "advisory",
          "dirtyWorktree",
          "reportPath",
          "rawOutputRef",
          "attributionKinds",
          "findingAttributionSummary",
          "status",
          "exitStatus"
        ],
        "properties": {
          "schemaVersion": {
            "const": "fallow-report-envelope/v1"
          },
          "toolVersion": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "subcommand": {
            "enum": [
              "audit",
              "dead-code",
              "dupes",
              "health",
              "boundaries",
              "flags",
              "security",
              "fix-preview",
              "runtime-coverage",
              "editor-mcp-hooks"
            ]
          },
          "baseRef": {
            "type": "string",
            "minLength": 1
          },
          "generatedAt": {
            "type": "string",
            "minLength": 1
          },
          "advisory": {
            "type": "boolean"
          },
          "dirtyWorktree": {
            "type": "boolean"
          },
          "reportPath": {
            "type": "string",
            "pattern": "^\\.beep/fallow/"
          },
          "rawOutputRef": {
            "type": "string",
            "minLength": 1
          },
          "attributionKinds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["introduced", "inherited-adjacent", "not-applicable"]
            }
          },
          "findingAttributionSummary": {
            "type": "object",
            "required": ["introduced", "inheritedAdjacent", "notApplicable"],
            "properties": {
              "introduced": {
                "type": "integer",
                "minimum": 0
              },
              "inheritedAdjacent": {
                "type": "integer",
                "minimum": 0
              },
              "notApplicable": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "status": {
            "enum": [
              "ok",
              "tool-failed",
              "invalid-json",
              "invalid-report",
              "base-resolution-failed"
            ]
          },
          "exitStatus": {
            "type": "integer",
            "minimum": 0
          },
          "report": {
            "type": "object",
            "required": ["findingCount", "findings"],
            "properties": {
              "findingCount": {
                "type": "integer",
                "minimum": 0
              },
              "findings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "featureFamily",
                    "attribution",
                    "parser",
                    "subCategory",
                    "blocking",
                    "sourceRef"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "featureFamily": {
                      "enum": [
                        "audit",
                        "dead-code",
                        "dupes",
                        "health",
                        "boundaries",
                        "flags",
                        "security",
                        "fix-preview",
                        "runtime-coverage",
                        "editor-mcp-hooks"
                      ]
                    },
                    "attribution": {
                      "enum": [
                        "introduced",
                        "inherited-adjacent",
                        "not-applicable"
                      ]
                    },
                    "parser": {
                      "type": "string",
                      "pattern": "^fallow/"
                    },
                    "subCategory": {
                      "type": "string",
                      "pattern": "^fallow:"
                    },
                    "blocking": {
                      "const": false
                    },
                    "sourceRef": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "stderrExcerpt": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false,
        "oneOf": [
          {
            "required": ["status", "report"],
            "properties": {
              "status": {
                "const": "ok"
              }
            },
            "not": {
              "required": ["stderrExcerpt"]
            }
          },
          {
            "required": ["status", "stderrExcerpt"],
            "properties": {
              "status": {
                "const": "tool-failed"
              },
              "attributionKinds": {
                "const": ["not-applicable"]
              },
              "findingAttributionSummary": {
                "const": {
                  "introduced": 0,
                  "inheritedAdjacent": 0,
                  "notApplicable": 0
                }
              },
              "exitStatus": {
                "type": "integer",
                "minimum": 1
              }
            },
            "not": {
              "required": ["report"]
            }
          },
          {
            "required": ["status", "stderrExcerpt"],
            "properties": {
              "status": {
                "const": "invalid-json"
              },
              "attributionKinds": {
                "const": ["not-applicable"]
              },
              "findingAttributionSummary": {
                "const": {
                  "introduced": 0,
                  "inheritedAdjacent": 0,
                  "notApplicable": 0
                }
              }
            },
            "not": {
              "required": ["report"]
            }
          },
          {
            "required": ["status", "stderrExcerpt"],
            "properties": {
              "status": {
                "const": "invalid-report"
              },
              "attributionKinds": {
                "const": ["not-applicable"]
              },
              "findingAttributionSummary": {
                "const": {
                  "introduced": 0,
                  "inheritedAdjacent": 0,
                  "notApplicable": 0
                }
              }
            },
            "not": {
              "required": ["report"]
            }
          },
          {
            "required": ["status", "stderrExcerpt"],
            "properties": {
              "status": {
                "const": "base-resolution-failed"
              },
              "attributionKinds": {
                "const": ["not-applicable"]
              },
              "findingAttributionSummary": {
                "const": {
                  "introduced": 0,
                  "inheritedAdjacent": 0,
                  "notApplicable": 0
                }
              },
              "exitStatus": {
                "type": "integer",
                "minimum": 1
              }
            },
            "not": {
              "required": ["report"]
            }
          }
        ]
      }
    },
    "yeetIssueFixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "sourceFeature",
          "sourceEnvelopeRef",
          "sourceFindingId",
          "tool",
          "parser",
          "subCategory",
          "blocking",
          "attribution"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "sourceFeature": {
            "enum": [
              "audit",
              "dead-code",
              "dupes",
              "health",
              "boundaries",
              "flags",
              "security",
              "fix-preview",
              "runtime-coverage",
              "editor-mcp-hooks"
            ]
          },
          "sourceEnvelopeRef": {
            "type": "string",
            "pattern": "^\\.beep/fallow/"
          },
          "sourceFindingId": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "const": "fallow"
          },
          "parser": {
            "type": "string",
            "pattern": "^fallow/"
          },
          "subCategory": {
            "type": "string",
            "pattern": "^fallow:"
          },
          "blocking": {
            "const": false
          },
          "attribution": {
            "enum": ["introduced", "inherited-adjacent", "not-applicable"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "fixtures",
    "yeetIssueFixtures"
  ],
  "x-rowRequiredFields": [
    "schemaVersion",
    "toolVersion",
    "command",
    "subcommand",
    "baseRef",
    "generatedAt",
    "advisory",
    "dirtyWorktree",
    "reportPath",
    "rawOutputRef",
    "attributionKinds",
    "findingAttributionSummary",
    "status",
    "exitStatus"
  ],
  "x-enumValues": {
    "fallowEnvelopeStatus": [
      "ok",
      "tool-failed",
      "invalid-json",
      "invalid-report",
      "base-resolution-failed"
    ],
    "featureFamily": [
      "audit",
      "dead-code",
      "dupes",
      "health",
      "boundaries",
      "flags",
      "security",
      "fix-preview",
      "runtime-coverage",
      "editor-mcp-hooks"
    ],
    "findingAttributionKind": [
      "introduced",
      "inherited-adjacent",
      "not-applicable"
    ]
  }
}
