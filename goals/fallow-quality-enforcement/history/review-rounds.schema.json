{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/fallow-quality-enforcement/review-rounds.schema.json",
  "title": "Fallow Quality Enforcement Review Rounds",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "rounds"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/review-rounds/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "roundId",
          "criticId",
          "criticRole",
          "requiredFindingCount",
          "openRequiredFindingCount",
          "findings",
          "acceptanceCommands"
        ],
        "properties": {
          "roundId": {
            "type": "string",
            "minLength": 1
          },
          "criticId": {
            "type": "string",
            "minLength": 1
          },
          "criticRole": {
            "type": "string",
            "minLength": 1
          },
          "requiredFindingCount": {
            "type": "integer",
            "minimum": 0
          },
          "openRequiredFindingCount": {
            "type": "integer",
            "minimum": 0
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "severity",
                "title",
                "sourceRefs",
                "concreteFix",
                "closureStatus",
                "closureEvidenceRefs"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "severity": {
                  "enum": ["required", "nice-to-have"]
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "sourceRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "concreteFix": {
                  "type": "string",
                  "minLength": 1
                },
                "closureStatus": {
                  "enum": ["open", "fixed", "waived"]
                },
                "closureEvidenceRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "waiver": {
                  "type": "object",
                  "required": [
                    "owner",
                    "sourceStandardRefs",
                    "rationale",
                    "expiresOrReviewBy",
                    "residualRisk",
                    "approver",
                    "acceptanceEvidenceRefs"
                  ],
                  "properties": {
                    "owner": {
                      "type": "string",
                      "pattern": "^@"
                    },
                    "sourceStandardRefs": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "rationale": {
                      "type": "string",
                      "minLength": 1
                    },
                    "expiresOrReviewBy": {
                      "type": "string",
                      "minLength": 1
                    },
                    "residualRisk": {
                      "enum": ["low", "medium", "high"]
                    },
                    "approver": {
                      "type": "string",
                      "pattern": "^@"
                    },
                    "acceptanceEvidenceRefs": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "acceptanceCommands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "rounds"
  ],
  "x-rowRequiredFields": [
    "roundId",
    "criticId",
    "criticRole",
    "requiredFindingCount",
    "openRequiredFindingCount",
    "findings",
    "acceptanceCommands"
  ],
  "x-enumValues": {
    "reviewFindingSeverity": ["required", "nice-to-have"],
    "reviewClosureStatus": ["open", "fixed", "waived"],
    "residualRiskLevel": ["low", "medium", "high"]
  }
}
