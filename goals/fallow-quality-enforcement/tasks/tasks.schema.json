{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/fallow-quality-enforcement/tasks.schema.json",
  "title": "Fallow Quality Enforcement Task Inventory",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "tasks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/tasks/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "rank",
          "status",
          "phase",
          "title",
          "summary",
          "implementationScope",
          "proofCommands",
          "acceptanceCommands",
          "dependencies",
          "rollbackPlan",
          "evidenceRefs",
          "owner",
          "riskLevel",
          "decisionGate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "enum": [
              "seeded",
              "selected",
              "in-progress",
              "done",
              "deferred",
              "rejected",
              "blocked"
            ]
          },
          "phase": {
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "implementationScope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "proofCommands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptanceCommands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rollbackPlan": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "owner": {
            "type": "string",
            "pattern": "^@\\S+$"
          },
          "riskLevel": {
            "enum": ["low", "medium", "high"]
          },
          "decisionGate": {
            "type": "object",
            "required": ["kind", "status", "evidence"],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "enum": ["open", "blocked", "passed", "failed"]
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "tasks"
  ],
  "x-rowRequiredFields": [
    "id",
    "rank",
    "status",
    "phase",
    "title",
    "summary",
    "implementationScope",
    "proofCommands",
    "acceptanceCommands",
    "dependencies",
    "rollbackPlan",
    "evidenceRefs",
    "owner",
    "riskLevel",
    "decisionGate"
  ],
  "x-enumValues": {
    "status": [
      "seeded",
      "selected",
      "in-progress",
      "done",
      "deferred",
      "rejected",
      "blocked"
    ],
    "riskLevel": ["low", "medium", "high"],
    "phase": ["P0", "P1", "P2", "P3"]
  }
}
