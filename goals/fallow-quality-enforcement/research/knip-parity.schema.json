{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/fallow-quality-enforcement/knip-parity.schema.json",
  "title": "Fallow Quality Enforcement Knip Parity Matrix",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "knipRemovalRecommendation",
    "rows"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/knip-parity/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "knipRemovalRecommendation": {
      "enum": ["keep-knip", "eligible-to-retire", "undecided"]
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "knipConfigSurface",
          "currentKnipBehavior",
          "fallowEquivalent",
          "gapStatus",
          "localKnipBaseline",
          "localFallowBaseline",
          "falsePositiveOwner",
          "promotionStatus",
          "retirementDecision",
          "retirementRationale",
          "acceptanceCommands",
          "evidenceRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "knipConfigSurface": {
            "type": "string",
            "minLength": 1
          },
          "currentKnipBehavior": {
            "type": "string",
            "minLength": 1
          },
          "fallowEquivalent": {
            "type": "string",
            "minLength": 1
          },
          "gapStatus": {
            "enum": [
              "parity",
              "fallow-gap",
              "knip-only",
              "repo-policy-gap",
              "unknown"
            ]
          },
          "localKnipBaseline": {
            "type": "string",
            "minLength": 1
          },
          "localFallowBaseline": {
            "type": "string",
            "minLength": 1
          },
          "falsePositiveOwner": {
            "type": "string",
            "pattern": "^@"
          },
          "promotionStatus": {
            "enum": [
              "research",
              "advisory",
              "candidate-blocking",
              "blocking",
              "deferred",
              "rejected"
            ]
          },
          "retirementDecision": {
            "enum": ["research-pending", "keep-knip", "ready-to-retire-knip"]
          },
          "retirementRationale": {
            "type": "string",
            "minLength": 1
          },
          "acceptanceCommands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "knipRemovalRecommendation",
    "rows"
  ],
  "x-rowRequiredFields": [
    "id",
    "knipConfigSurface",
    "currentKnipBehavior",
    "fallowEquivalent",
    "gapStatus",
    "localKnipBaseline",
    "localFallowBaseline",
    "falsePositiveOwner",
    "promotionStatus",
    "retirementDecision",
    "retirementRationale",
    "acceptanceCommands",
    "evidenceRefs"
  ],
  "x-enumValues": {
    "knipRemovalRecommendation": [
      "keep-knip",
      "eligible-to-retire",
      "undecided"
    ],
    "gapStatus": [
      "parity",
      "fallow-gap",
      "knip-only",
      "repo-policy-gap",
      "unknown"
    ],
    "promotionStatus": [
      "research",
      "advisory",
      "candidate-blocking",
      "blocking",
      "deferred",
      "rejected"
    ],
    "retirementDecision": [
      "research-pending",
      "keep-knip",
      "ready-to-retire-knip"
    ]
  }
}
