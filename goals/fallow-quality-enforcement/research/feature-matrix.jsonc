          "ownership-doc",
          "config-or-layer-surface",
          "architecture-example"
        ],
        "adjacentFindingPolicy": "review-inherited-adjacent",
        "reviewArtifactRefs": ["research/dead-code.md"]
      },
      "baselineStatus": "measured",
      "baselineArtifact": "standards/fallow.dead-code.regression-baseline.jsonc",
      "baselineSummary": {
        "status": "measured",
        "counts": "Configured Fallow reports 63 issues: 6 unused files, 25 unused exports, 4 unused types, 21 unused dependencies, 7 unlisted dependencies, and 0 unresolved imports. Knip reports 31 issue containers with nested totals of 9 files, 13 exports, 4 dependencies, 4 devDependencies, 1 unlisted dependency, and 9 unresolved references.",
        "notes": "Knip remains the reference analyzer because migration reports unmapped Knip surfaces."
      },
      "falsePositiveStatus": "config-gap",
      "falsePositiveOwner": "@beep-team",
      "falsePositiveEvidence": ["research/knip-parity.jsonc"],
      "suppressionPolicy": {
        "recordRequired": true,
        "allowedClasses": [
          "intentional-public-api",
          "transitional-compatibility",
          "generated-code"
        ],
        "inlineAllowed": false,
        "expiryRequired": true
      },
      "yeetMapping": {
        "category": "repo-law",
        "parser": "fallow/dead-code/v1",
        "subCategoryPrefix": "fallow:dead-code",
        "blockingDefault": false,
        "routingSkills": ["repo-symbol-discovery", "quality-review-fix-loop"]
      },
      "ciMode": "advisory-artifact",
      "promotionStatus": "research",
      "promotionCriteria": {
        "requiredCommands": [
          "bun goals/fallow-quality-enforcement/ops/validate-knip-parity-baselines.ts",
          "bun run fallow:migrate:dry-run -- --from knip.jsonc"
        ],
        "requiredEvidenceRefs": [
          "research/dead-code.md",
          "research/knip-parity.jsonc"
        ],
        "requiredReviewerRoles": [
          "Quality Gate Reviewer",
          "Reuse And Duplication Reviewer"
        ],
        "minimumCleanRuns": 3
      },
      "runtimeScope": "static-only",
      "owner": "@beep-team",
      "acceptanceCommands": [
        "bun goals/fallow-quality-enforcement/ops/validate-knip-parity-baselines.ts"
      ],
      "rollbackNotes": "Keep Knip as the reference analyzer and parity gate; remove dead-code from Fallow advisory packets.",
      "evidenceRefs": [
        "standards/fallow.dead-code.regression-baseline.jsonc",
        "research/dead-code.md",
        "standards/fallow.pilot.inventory.jsonc"
      ]
    },
