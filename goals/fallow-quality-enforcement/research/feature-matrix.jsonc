{
  "$schema": "./feature-matrix.schema.json",
  "schemaVersion": "fallow-quality-enforcement/feature-matrix/v1",
  "updated": "2026-06-08",
  "validatorVersion": "fallow-quality-enforcement-validator/v1",
  "features": [
    {
      "id": "fqe-feature-audit",
      "featureFamily": "audit",
      "fallowDocsUrls": ["https://docs.fallow.tools/cli/audit"],
      "fallowCommand": "bun run fallow:audit -- --base origin/main --gate new-only",
      "repoCommandTarget": {
        "command": "beep quality fallow audit",
        "phase": "P1",
        "implementationStatus": "implemented",
        "defaultOutputPath": ".beep/fallow/audit.json"
      },
      "configSurfaces": [
        ".fallowrc.jsonc",
        "standards/fallow.dead-code.regression-baseline.jsonc"
      ],
      "doctrineTargetRefs": [
        "standards/ARCHITECTURE.md#enforcement-and-migration-posture"
      ],
      "ruleSourceClass": "tool-native",
      "boundaryRuleSources": [],
      "attributionPolicy": {
        "modes": ["diff-introduced", "cleanup-on-touch"],
        "basePolicy": "origin-main-default",
        "cleanupOnTouchTriggers": [
          "package-manifest",
          "export-map",
          "boundary-sensitive-import",
          "ownership-doc",
          "config-or-layer-surface",
          "architecture-example"
        ],
        "adjacentFindingPolicy": "review-inherited-adjacent",
        "reviewArtifactRefs": ["research/audit.md"]
      },
      "baselineStatus": "measured",
      "baselineArtifact": "standards/fallow.pilot.inventory.jsonc",
      "baselineSummary": {
        "status": "measured",
        "counts": "Live audit saw at least 90 changed files in the current dirty worktree, 30 changed-scope dead-code issues, 41 complexity findings, and 155 clone groups; introduced counts were 3 dead-code, 10 complexity, and 10 duplication.",
        "notes": "Changed-file count is worktree-volatile while this packet is edited. The baseline helper enforces a minimum changed-file snapshot plus exact finding and attribution counts."
      },
      "falsePositiveStatus": "unknown",
      "falsePositiveOwner": "@beep-team",
      "falsePositiveEvidence": [
        "research/audit.md",
        "standards/fallow.pilot.inventory.jsonc"
      ],
      "suppressionPolicy": {
        "recordRequired": true,
        "allowedClasses": [
          "false-positive",
          "transitional-compatibility",
          "generated-code"
        ],
        "inlineAllowed": false,
        "expiryRequired": true
      },
      "yeetMapping": {
        "category": "repo-law",
        "parser": "fallow/audit/v1",
        "subCategoryPrefix": "fallow:audit",
        "blockingDefault": false,
        "routingSkills": ["quality-review-fix-loop"]
      },
      "ciMode": "advisory-artifact",
      "promotionStatus": "advisory",
      "promotionCriteria": {
        "requiredCommands": [
          "bun goals/fallow-quality-enforcement/ops/validate-fallow-audit-baseline.ts"
        ],
        "requiredEvidenceRefs": ["research/audit.md"],
        "requiredReviewerRoles": [
          "Quality Gate Reviewer",
          "Architecture Boundary Reviewer"
        ],
        "minimumCleanRuns": 3
      },
      "runtimeScope": "static-only",
      "owner": "@beep-team",
      "acceptanceCommands": [
        "bun goals/fallow-quality-enforcement/ops/validate-fallow-audit-baseline.ts"
      ],
      "rollbackNotes": "Disable advisory packet parsing and keep CI artifact-only output.",
      "evidenceRefs": [
        "research/audit.md",
        "standards/fallow.pilot.inventory.jsonc"
      ]
    },
    {
      "id": "fqe-feature-dead-code",
      "featureFamily": "dead-code",
      "fallowDocsUrls": ["https://docs.fallow.tools/cli/dead-code"],
