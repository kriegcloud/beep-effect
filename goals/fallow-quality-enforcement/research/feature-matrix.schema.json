{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/goals/fallow-quality-enforcement/feature-matrix.schema.json",
  "title": "Fallow Quality Enforcement Feature Matrix",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "features"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/feature-matrix/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "featureFamily",
          "fallowDocsUrls",
          "fallowCommand",
          "repoCommandTarget",
          "configSurfaces",
          "doctrineTargetRefs",
          "ruleSourceClass",
          "boundaryRuleSources",
          "attributionPolicy",
          "baselineStatus",
          "baselineArtifact",
          "baselineSummary",
          "falsePositiveStatus",
          "falsePositiveOwner",
          "falsePositiveEvidence",
          "suppressionPolicy",
          "yeetMapping",
          "ciMode",
          "promotionStatus",
          "promotionCriteria",
          "runtimeScope",
          "owner",
          "acceptanceCommands",
          "rollbackNotes",
          "evidenceRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "featureFamily": {
            "enum": [
              "audit",
              "dead-code",
              "health",
              "boundaries",
              "flags",
              "security",
              "fix-preview",
              "runtime-coverage",
              "editor-mcp-hooks"
            ]
          },
          "fallowDocsUrls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^https?://"
            }
          },
          "fallowCommand": {
            "type": "string",
            "minLength": 1
          },
          "repoCommandTarget": {
            "type": "object",
            "required": [
              "command",
              "phase",
              "implementationStatus",
              "defaultOutputPath"
            ],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "phase": {
                "enum": ["P1", "P2", "P3", "none"]
              },
              "implementationStatus": {
                "enum": [
                  "target-contract",
                  "implemented",
                  "compatibility-alias",
                  "research-only"
                ]
              },
              "defaultOutputPath": {
                "type": "string",
                "pattern": "^\\.beep/fallow/"
              }
            },
            "additionalProperties": false
          },
          "configSurfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "doctrineTargetRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "ruleSourceClass": {
            "enum": [
              "manifest-derived",
              "architecture-derived-hard-check",
              "review-gate-only",
              "tool-native",
              "external-service"
            ]
          },
          "boundaryRuleSources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "ruleId",
                "sourceClass",
                "enforcementScope",
                "sourceRefs",
                "doctrineRefs",
                "catalogRefs",
                "promotionEligible"
              ],
              "properties": {
                "ruleId": {
                  "type": "string",
                  "minLength": 1
                },
                "sourceClass": {
                  "enum": [
                    "manifest-derived",
                    "architecture-derived-hard-check",
                    "review-gate-only",
                    "tool-native",
                    "external-service"
                  ]
                },
                "enforcementScope": {
                  "enum": [
                    "declared-dependency-consistency",
                    "architecture-legal-edge",
                    "review-only"
                  ]
                },
                "sourceRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "doctrineRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "catalogRefs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "promotionEligible": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "attributionPolicy": {
            "type": "object",
            "required": [
              "modes",
              "basePolicy",
              "cleanupOnTouchTriggers",
              "adjacentFindingPolicy",
              "reviewArtifactRefs"
            ],
            "properties": {
              "modes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "enum": [
                    "diff-introduced",
                    "cleanup-on-touch",
                    "research-only"
                  ]
                }
              },
              "basePolicy": {
                "enum": [
                  "origin-main-default",
                  "github-pr-base",
                  "github-push-before",
                  "not-applicable"
                ]
              },
              "cleanupOnTouchTriggers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "adjacentFindingPolicy": {
                "enum": [
                  "review-inherited-adjacent",
                  "ignore-inherited",
                  "not-applicable"
                ]
              },
              "reviewArtifactRefs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "baselineStatus": {
            "enum": ["pending", "measured", "not-applicable", "blocked"]
          },
          "baselineArtifact": {
            "type": "string",
            "minLength": 1
          },
          "baselineSummary": {
            "type": "object",
            "required": ["status", "counts", "notes"],
            "properties": {
              "status": {
                "type": "string",
                "minLength": 1
              },
              "counts": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "falsePositiveStatus": {
            "enum": [
              "none-known",
              "waived-with-expiry",
              "config-gap",
              "tool-bug",
              "doctrine-gap",
              "unknown"
            ]
          },
          "falsePositiveOwner": {
            "type": "string",
            "pattern": "^@"
          },
          "falsePositiveEvidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "suppressionPolicy": {
            "type": "object",
            "required": [
              "recordRequired",
              "allowedClasses",
              "inlineAllowed",
              "expiryRequired"
            ],
            "properties": {
              "recordRequired": {
                "type": "boolean"
              },
              "allowedClasses": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "inlineAllowed": {
                "type": "boolean"
              },
              "expiryRequired": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "yeetMapping": {
            "type": "object",
            "required": [
              "category",
              "parser",
              "subCategoryPrefix",
              "blockingDefault",
              "routingSkills"
            ],
            "properties": {
              "category": {
                "enum": [
                  "repo-law",
                  "security-audit",
                  "parser-error",
                  "command-failure"
                ]
              },
              "parser": {
                "type": "string",
                "pattern": "^fallow/"
              },
              "subCategoryPrefix": {
                "type": "string",
                "pattern": "^fallow:"
              },
              "blockingDefault": {
                "type": "boolean"
              },
              "routingSkills": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "ciMode": {
            "enum": [
              "none",
              "advisory-artifact",
              "warning-check",
              "blocking-check"
            ]
          },
          "promotionStatus": {
            "enum": [
              "research",
              "advisory",
              "candidate-blocking",
              "blocking",
              "deferred",
              "rejected"
            ]
          },
          "promotionCriteria": {
            "type": "object",
            "required": [
              "requiredCommands",
              "requiredEvidenceRefs",
              "requiredReviewerRoles",
              "minimumCleanRuns"
            ],
            "properties": {
              "requiredCommands": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "requiredEvidenceRefs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "requiredReviewerRoles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "minimumCleanRuns": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "runtimeScope": {
            "enum": ["static-only", "research-only", "pilot", "out-of-scope"]
          },
          "owner": {
            "type": "string",
            "pattern": "^@"
          },
          "acceptanceCommands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rollbackNotes": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "features"
  ],
  "x-rowRequiredFields": [
    "id",
    "featureFamily",
    "fallowDocsUrls",
    "fallowCommand",
    "repoCommandTarget",
    "configSurfaces",
    "doctrineTargetRefs",
    "ruleSourceClass",
    "boundaryRuleSources",
    "attributionPolicy",
    "baselineStatus",
    "baselineArtifact",
    "baselineSummary",
    "falsePositiveStatus",
    "falsePositiveOwner",
    "falsePositiveEvidence",
    "suppressionPolicy",
    "yeetMapping",
    "ciMode",
    "promotionStatus",
    "promotionCriteria",
    "runtimeScope",
    "owner",
    "acceptanceCommands",
    "rollbackNotes",
    "evidenceRefs"
  ],
  "x-enumValues": {
    "featureFamily": [
      "audit",
      "dead-code",
      "health",
      "boundaries",
      "flags",
      "security",
      "fix-preview",
      "runtime-coverage",
      "editor-mcp-hooks"
    ],
    "ruleSourceClass": [
      "manifest-derived",
      "architecture-derived-hard-check",
      "review-gate-only",
      "tool-native",
      "external-service"
    ],
    "boundaryEnforcementScope": [
      "declared-dependency-consistency",
      "architecture-legal-edge",
      "review-only"
    ],
    "baselineStatus": ["pending", "measured", "not-applicable", "blocked"],
    "falsePositiveStatus": [
      "none-known",
      "waived-with-expiry",
      "config-gap",
      "tool-bug",
      "doctrine-gap",
      "unknown"
    ],
    "ciMode": ["none", "advisory-artifact", "warning-check", "blocking-check"],
    "promotionStatus": [
      "research",
      "advisory",
      "candidate-blocking",
      "blocking",
      "deferred",
      "rejected"
    ],
    "runtimeScope": ["static-only", "research-only", "pilot", "out-of-scope"],
    "repoCommandPhase": ["P1", "P2", "P3", "none"],
    "commandImplementationStatus": [
      "target-contract",
      "implemented",
      "compatibility-alias",
      "research-only"
    ],
    "attributionMode": ["diff-introduced", "cleanup-on-touch", "research-only"],
    "basePolicy": [
      "origin-main-default",
      "github-pr-base",
      "github-push-before",
      "not-applicable"
    ],
    "adjacentFindingPolicy": [
      "review-inherited-adjacent",
      "ignore-inherited",
      "not-applicable"
    ]
  }
}
