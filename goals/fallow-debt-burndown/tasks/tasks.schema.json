{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "beep/fallow-debt-burndown/tasks.schema.json",
  "title": "Fallow Debt Burn-Down Tasks",
  "description": "Task inventory for the fallow-debt-burndown goal. The validator in goals/fallow-debt-burndown/ops/validate-packet.ts is authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "tasks"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "fallow-debt-burndown/tasks/v1" },
    "updated": { "type": "string" },
    "validatorVersion": { "const": "fallow-debt-burndown-validator/v1" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "rank",
          "status",
          "phase",
          "title",
          "summary",
          "implementationScope",
          "proofCommands",
          "acceptanceCommands",
          "dependencies",
          "rollbackPlan",
          "evidenceRefs",
          "owner",
          "riskLevel",
          "decisionGate"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^fdb-[0-9]{3}$" },
          "rank": { "type": "integer", "minimum": 1 },
          "status": {
            "enum": [
              "seeded",
              "selected",
              "in-progress",
              "done",
              "deferred",
              "rejected",
              "blocked"
            ]
          },
          "phase": { "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "implementationScope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "proofCommands": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptanceCommands": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "pattern": "^fdb-[0-9]{3}$" }
          },
          "rollbackPlan": { "type": "string", "minLength": 1 },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "owner": { "type": "string", "pattern": "^@" },
          "riskLevel": { "enum": ["low", "medium", "high"] },
          "decisionGate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "status", "evidence"],
            "properties": {
              "kind": {
                "enum": [
                  "packet-authored",
                  "policy-inventory",
                  "debt-burndown",
                  "promotion-readiness",
                  "deferred",
                  "none"
                ]
              },
              "status": { "enum": ["open", "blocked", "passed", "failed"] },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  },
  "x-validatorAuthority": "goals/fallow-debt-burndown/ops/validate-packet.ts"
}
