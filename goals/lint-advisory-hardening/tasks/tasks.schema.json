{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lint-advisory-hardening/tasks.schema.json",
  "type": "object",
  "required": ["schemaVersion", "updated", "tasks"],
  "properties": {
    "schemaVersion": {
      "const": "lint-advisory-hardening/tasks/v1"
    },
    "updated": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "lane", "status", "proof"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "lane": {
            "type": "string"
          },
          "status": {
            "enum": ["pending", "selected", "in-progress", "done", "blocked"]
          },
          "proof": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
