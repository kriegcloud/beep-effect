{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": [
    "hooks/**/*.ts",
    "scripts/**/*.ts",
    "patterns/**/*.ts",
    "test/**/*.ts"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist-types",
    "types": ["node", "bun"],
    "noEmit": true,
    "paths": {
      "@beep/claude/*": ["./*.ts", "./*"]
    }
  }
}
