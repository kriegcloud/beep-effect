{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "language": "en",
  "useGitignore": true,
  "ignoreRandomStrings": true,
  "allowCompoundWords": true,
  "dictionaryDefinitions": [
    {
      "name": "company-names",
      "path": "./.cspell/company-names.txt",
      "addWords": true
    },
    {
      "name": "third-party",
      "path": "./.cspell/third-party.txt",
      "addWords": true
    },
    {
      "name": "tech-terminology",
      "path": "./.cspell/tech-terms.txt",
      "addWords": true
    },
    {
      "name": "effect-terminology",
      "path": "./.cspell/effect-terms.txt",
      "addWords": true
    },
    {
      "name": "custom-words",
      "path": "./.cspell/custom-words.txt",
      "addWords": true
    },
    {
      "name": "names",
      "path": "./.cspell/names.txt",
      "addWords": true
    },
    {
      "name": "alt-languages",
      "path": "./.cspell/alt-languages.txt",
      "addWords": true
    },
    {
      "name": "misspelled",
      "path": "./.cspell/misspelled.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "company-names",
    "third-party",
    "tech-terminology",
    "effect-terminology",
    "custom-words",
    "names",
    "alt-languages",
    "misspelled"
  ],
  "ignorePaths": [
    "bun.lock",
    "patches/**",
    "_typos.toml",
    "node_modules",
    ".repos",
    "graphify-out/**",
    "*.snap",
    "build",
    "tmp",
    "dist",
    "coverage",
    "outputs",
    ".next",
    "storybook-static",
    "**/public/sw.js",
    "**/public/workbox-*.js",
    ".beep/**",
    ".aiassistant/**",
    "scratchpad/**",
    "goals/**",
    ".turbo",
    "*.tsbuildinfo",
    ".agents",
    "**/docs/**",
    "**/build/**",
    "tmp/**",
    "specs",
    "**/AGENTS.md",
    "infra/oip-web/Pulumi.*.yaml",
    "packages/drivers/runpod/openapi.json",
    "packages/drivers/venice-ai/swagger.yaml",
    "packages/foundation/modeling/schema/src/Timezone.ts",
    "**/internal/data/**",
    "**/dtslint/**",
    "**/test/**",
    "patches/**",
    "**/src-tauri/gen/**",
    "**/src-tauri/target/**",
    "standards/jsdoc-documentation.inventory.jsonc",
    "standards/jsdoc-documentation.inventory.md",
    "standards/repo-exports.catalog.jsonc",
    "standards/repo-exports.catalog.md"
  ]
}
