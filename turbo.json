{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.packages.json",
    "package.json",
    "tstyche.config.json",
    "vitest.shared.ts",
    "vitest.shared.ts"
  ],
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "globalPassThroughEnv": ["NODE_TLS_REJECT_UNAUTHORIZED", "AWS_*", "SST_*"],
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!.beep/**"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/.tsbuildinfo/**",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "lint:fix": {
      "cache": true,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "check": {
      "dependsOn": ["^build", "^check"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"],
      "outputs": ["docs/**", "dtslint/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["^build"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    },
    "test:visual": {
      "dependsOn": ["build-storybook"],
      "cache": false
    },

    "//#lint:jsdoc": {
      "cache": true,
      "inputs": ["tooling/*/src/**/*.ts", "eslint.config.mjs"]
    },
    "//#lint:typos": {
      "cache": false
    },
    "//#lint:spell": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "cspell.json", "!.beep/**"]
    },
    "//#lint:markdown": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", ".markdownlint-cli2.jsonc", "!.beep/**"]
    },
    "//#lint:circular": {
      "cache": true,
      "inputs": [
        "tooling/*/src/**/*.ts",
        "packages/*/src/**/*.ts",
        "scripts/circular.mjs"
      ]
    },
    "//#lint:repo": {
      "cache": false
    },
    "//#lint:ox": {
      "cache": false
    },
    "//#lint:versions": {
      "cache": false
    }
  }
}
