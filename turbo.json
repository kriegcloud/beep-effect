{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [
    ".bun-version",
    ".nvmrc",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.packages.json",
    "package.json",
    "tstyche.json",
    "vitest.shared.ts"
  ],
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "globalPassThroughEnv": [
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "PORTLESS_*",
    "AWS_*",
    "SST_*"
  ],
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/.env*", "!.beep/**"],
      "env": [
        "APP_ADMINS_EMAILS",
        "ALLOWED_EMAILS",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "EMAIL_*",
        "AUTH_*",
        "BETTER_AUTH_*",
        "OPENAI_*",
        "GRAPHITI_*",
        "SECURITY_*",
        "OAUTH_*",
        "NEXT_PUBLIC_*",
        "LIVEBLOCKS_*",
        "RESEND_*"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/node_modules/.tmp/*.tsbuildinfo",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "check": {
      "dependsOn": ["^check"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"],
      "outputs": [
        "dist/**",
        "**/node_modules/.tmp/*.tsbuildinfo",
        "!**/.turbo/**"
      ]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["BEEP_TEST_*"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "type-test": {
      "cache": true,
      "dependsOn": ["^type-test"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "coverage": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["VITEST_COVERAGE_REPORT_ONLY"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"],
      "outputs": ["coverage/**"]
    },
    "audit": {
      "cache": false,
      "dependsOn": ["^audit"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"],
      "outputs": ["docs/**", "dtslint/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["^build"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    }
  }
}
