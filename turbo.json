{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.packages.json",
    "package.json",
    "tstyche.config.json",
    "vitest.shared.ts",
    "vitest.shared.ts"
  ],
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "globalPassThroughEnv": [
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "AWS_*",
    "SST_*",
    "APP_ADMINS_EMAILS",
    "ALLOWED_EMAILS",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "EMAIL_*",
    "AUTH_*",
    "BETTER_AUTH_*",
    "OPENAI_*",
    "GRAPHITI_*",
    "SECURITY_*",
    "OAUTH_*",
    "NEXT_PUBLIC_*",
    "LIVEBLOCKS_*",
    "RESEND_*"
  ],
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!.beep/**"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/.tsbuildinfo/**",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "lint:fix": {
      "cache": true,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "check": {
      "dependsOn": ["^build", "^check"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"]
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": ["$TURBO_DEFAULT$", "!.beep/**"],
      "outputs": ["docs/**", "dtslint/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["^build"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    },
    "test:visual": {
      "dependsOn": ["build-storybook"],
      "cache": false
    },

    "//#check:infra": {
      "cache": true,
      "inputs": [
        "sst.config.ts",
        "sst-env.d.ts",
        "infra/**/*.ts",
        "infra/tsconfig.json"
      ]
    },
    "//#lint:jsdoc": {
      "cache": true,
      "inputs": [
        "apps/**/*.{ts,tsx}",
        "packages/**/*.{ts,tsx}",
        "tooling/**/*.{ts,tsx}",
        "infra/**/*.ts",
        ".claude/hooks/**/*.ts",
        "eslint.config.mjs"
      ]
    },
    "//#lint:typos": {
      "cache": false
    },
    "//#lint:spell": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "cspell.json", "!.beep/**"]
    },
    "//#lint:markdown": {
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", ".markdownlint-cli2.jsonc", "!.beep/**"]
    },
    "//#lint:circular": {
      "cache": true,
      "inputs": [
        "tooling/*/src/**/*.ts",
        "packages/*/src/**/*.ts",
        "tooling/cli/src/commands/Lint/index.ts"
      ]
    },
    "//#lint:repo": {
      "cache": false
    },
    "//#lint:ox": {
      "cache": false
    },
    "//#lint:versions": {
      "cache": false
    }
  }
}
