{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "futureFlags": {
    "affectedUsingTaskInputs": true,
    "filterUsingTasks": true,
    "globalConfiguration": true
  },
  "global": {
    "ui": "tui",
    "inputs": [".bun-version", ".nvmrc", "package.json"],
    "passThroughEnv": [
      "TURBO_TOKEN",
      "TURBO_TEAM",
      "NODE_TLS_REJECT_UNAUTHORIZED",
      "PORTLESS_*",
      "AWS_*",
      "SST_*"
    ]
  },
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/.env*",
        "!.beep/**"
      ],
      "env": [
        "APP_ADMINS_EMAILS",
        "ALLOWED_EMAILS",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "EMAIL_*",
        "AUTH_*",
        "BETTER_AUTH_*",
        "OPENAI_*",
        "GRAPHITI_*",
        "SECURITY_*",
        "OAUTH_*",
        "NEXT_PUBLIC_*",
        "LIVEBLOCKS_*",
        "RESEND_*"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/node_modules/.tmp/*.tsbuildinfo",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/biome.jsonc",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/stories/**",
        "!.beep/**"
      ]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.jsonc", "!.beep/**"]
    },
    "check": {
      "dependsOn": ["^check"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/stories/**",
        "!.beep/**"
      ],
      "outputs": [
        "dist/**",
        "**/node_modules/.tmp/*.tsbuildinfo",
        "!**/.turbo/**"
      ]
    },
    "test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/vitest.shared.ts",
        "!.beep/**"
      ]
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["BEEP_TEST_*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/vitest.shared.ts",
        "!.beep/**"
      ]
    },
    "type-test": {
      "cache": true,
      "dependsOn": ["^type-test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/tstyche.json",
        "!.beep/**"
      ]
    },
    "coverage": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["VITEST_COVERAGE_REPORT_ONLY"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/vitest.shared.ts",
        "!.beep/**"
      ],
      "outputs": ["coverage/**"]
    },
    "codegen": {
      "cache": false,
      "dependsOn": ["^codegen"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "!.beep/**"
      ]
    },
    "audit": {
      "cache": true,
      "dependsOn": ["^audit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/biome.jsonc",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "$TURBO_ROOT$/tstyche.json",
        "$TURBO_ROOT$/vitest.shared.ts",
        "$TURBO_ROOT$/.env*",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/stories/**",
        "!.beep/**"
      ],
      "env": [
        "APP_ADMINS_EMAILS",
        "ALLOWED_EMAILS",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "EMAIL_*",
        "AUTH_*",
        "BETTER_AUTH_*",
        "OPENAI_*",
        "GRAPHITI_*",
        "SECURITY_*",
        "OAUTH_*",
        "NEXT_PUBLIC_*",
        "LIVEBLOCKS_*",
        "RESEND_*",
        "BEEP_TEST_*",
        "CI"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "docs/**",
        "dtslint/**",
        "**/node_modules/.tmp/*.tsbuildinfo",
        "!**/.turbo/**",
        "!.next/cache/**"
      ],
      "outputLogs": "new-only"
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.packages.json",
        "!.beep/**"
      ],
      "outputs": ["docs/**", "dtslint/**", ".beep/docgen/**"]
    },
    "repo-exports:shard": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.beep/**",
        "!docs/**",
        "$TURBO_ROOT$/packages/tooling/tool/cli/src/commands/Quality/internal/RepoExportsCatalog.ts",
        "$TURBO_ROOT$/packages/tooling/tool/cli/src/commands/Quality/internal/QualityArtifactSupport.ts",
        "$TURBO_ROOT$/packages/tooling/tool/cli/src/commands/Quality/Quality.command.ts",
        "$TURBO_ROOT$/packages/tooling/library/repo-codegraph/src/RepoExportsCatalog.model.ts"
      ],
      "outputs": [".beep/repo-exports/**"],
      "outputLogs": "new-only"
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["^build"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/storybook/.storybook/**",
        "$TURBO_ROOT$/apps/storybook/vitest.storybook.config.ts",
        "$TURBO_ROOT$/apps/storybook/vitest.storybook.setup.ts",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/src/**",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/stories/**"
      ],
      "outputs": ["storybook-static/**"]
    },
    "storybook:start": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["storybook:build"]
    },
    "test:storybook": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/storybook/.storybook/**",
        "$TURBO_ROOT$/apps/storybook/vitest.storybook.config.ts",
        "$TURBO_ROOT$/apps/storybook/vitest.storybook.setup.ts",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/src/**",
        "$TURBO_ROOT$/packages/foundation/ui-system/*/stories/**"
      ]
    }
  }
}
