{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.packages.json"
  ],
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "globalPassThroughEnv": ["NODE_TLS_REJECT_UNAUTHORIZED", "AWS_*", "SST_*"],
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/.tsbuildinfo/**",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint:fix": {
      "cache": true,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "check": {
      "dependsOn": ["^build", "^check"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["docs/**", "dtslint/**"]
    }
  }
}
