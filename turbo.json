{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env",
    "**/.env.*",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.packages.json"
  ],
  "globalEnv": ["TURBO_TOKEN", "TURBO_TEAM"],
  "globalPassThroughEnv": ["NODE_TLS_REJECT_UNAUTHORIZED", "AWS_*", "SST_*"],
  "tasks": {
    "build": {
      "persistent": false,
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "next-env.d.ts",
        ".expo/**",
        "_next/**",
        ".output/**",
        ".vercel/output/**",
        "**/.tsbuildinfo/**",
        "!**/.turbo/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "cache": true,
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint:fix": {
      "cache": true,
      "dependsOn": ["^lint:fix"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "check": {
      "dependsOn": ["^build", "^check"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "docgen": {
      "cache": true,
      "dependsOn": ["^docgen"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["docs/**", "dtslint/**"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    },
    "test:visual": {
      "dependsOn": ["build-storybook"],
      "cache": false
    },

    "//#lint:jsdoc": {
      "cache": true,
      "inputs": ["tooling/*/src/**/*.ts", "eslint.config.mjs"]
    },
    "//#lint:typos": {
      "cache": true,
      "inputs": ["**/*.{ts,tsx,js,jsx,md,json}", "_typos.toml"]
    },
    "//#lint:spell": {
      "cache": true,
      "inputs": ["**/*.{ts,tsx,md}", "cspell.json"]
    },
    "//#lint:markdown": {
      "cache": true,
      "inputs": ["**/*.md", ".markdownlint-cli2.jsonc"]
    },
    "//#lint:circular": {
      "cache": true,
      "inputs": [
        "tooling/*/src/**/*.ts",
        "packages/*/src/**/*.ts",
        "scripts/circular.mjs"
      ]
    },
    "//#lint:repo": {
      "cache": true,
      "inputs": ["**/package.json"]
    },
    "//#lint:ox": {
      "cache": true,
      "inputs": ["**/*.{ts,tsx,js,jsx}"]
    },
    "//#lint:versions": {
      "cache": false
    }
  }
}
