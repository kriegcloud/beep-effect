{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beep-effect.local/standards/fallow.boundaries.provenance.schema.json",
  "title": "Fallow Boundary Rule Provenance",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "generatedConfigRef",
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "fallow-quality-enforcement/boundary-provenance/v1"
    },
    "updated": {
      "type": "string"
    },
    "validatorVersion": {
      "const": "fallow-quality-enforcement-validator/v1"
    },
    "generatedConfigRef": {
      "const": "standards/fallow.boundaries.generated.jsonc"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ruleId",
          "generatedRuleFrom",
          "sourceClass",
          "enforcementScope",
          "sourceRefs",
          "doctrineRefs",
          "catalogRefs",
          "promotionEligible"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "minLength": 1
          },
          "generatedRuleFrom": {
            "type": "string",
            "minLength": 1
          },
          "sourceClass": {
            "enum": ["manifest-derived"]
          },
          "enforcementScope": {
            "const": "declared-dependency-consistency"
          },
          "sourceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "contains": {
              "const": "package.json"
            }
          },
          "doctrineRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^standards/(ARCHITECTURE\\.md|architecture/[0-9]{2}-[A-Za-z0-9._-]+\\.md)"
            }
          },
          "catalogRefs": {
            "type": "array",
            "minItems": 1,
            "contains": {
              "const": "standards/repo-exports.catalog.jsonc"
            },
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "promotionEligible": {
            "const": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "x-effectSchemaAuthority": "goals/fallow-quality-enforcement/ops/validate-packet.ts",
  "x-requiredFields": [
    "$schema",
    "schemaVersion",
    "updated",
    "validatorVersion",
    "generatedConfigRef",
    "rules"
  ],
  "x-rowRequiredFields": [
    "ruleId",
    "generatedRuleFrom",
    "sourceClass",
    "enforcementScope",
    "sourceRefs",
    "doctrineRefs",
    "catalogRefs",
    "promotionEligible"
  ],
  "x-enumValues": {
    "ruleSourceClass": [
      "manifest-derived",
      "architecture-derived-hard-check",
      "review-gate-only",
      "tool-native",
      "external-service"
    ],
    "boundaryEnforcementScope": [
      "declared-dependency-consistency",
      "architecture-legal-edge",
      "review-only"
    ]
  }
}
