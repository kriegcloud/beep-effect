      "owner": "@beep/repo-utils",
      "issue": "REUSE-ANALYSIS-NATIVE-COLLECTIONS"
    },
    {
      "rule": "beep-laws/no-native-runtime",
      "file": "packages/tooling/library/repo-utils/src/Reuse/TokenSimilarity.ts",
