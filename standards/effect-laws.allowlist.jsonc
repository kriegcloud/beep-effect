      "owner": "@beep/repo-cli",
      "issue": "REPO-CLI-CORPUS-RECYCLEBIN-PAIRING-INDEXES"
    },
    {
      "rule": "beep-laws/no-native-runtime",
      "file": "packages/tooling/tool/cli/src/commands/Corpus/Corpus.service.ts",
      "kind": "new-map-set",
      "reason": "Corpus CLI catalog, organize, and enrich flows use native Map and Set indexes for JSONL restoration joins, duplicate suppression, version grouping, and identifier candidate aggregation at tooling boundaries.",
      "owner": "@beep/repo-cli",
      "issue": "REPO-CLI-CORPUS-NATIVE-COLLECTION-INDEXES"
    },
