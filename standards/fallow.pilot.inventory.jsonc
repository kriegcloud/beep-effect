  "decision": {
    "addToRepo": true,
    "mode": "advisory-pilot",
    "replaceKnipNow": false,
    "keepKnipAsBlockingGate": false,
    "knipRole": "reference-analyzer-parity-gate",
    "summary": "Fallow is valuable enough to add as an advisory quality signal, especially for PR attribution, duplication, complexity, SARIF/PR output, and architecture-boundary experiments. It is not ready to replace Knip as the reference analyzer and parity gate in this repo until its dead-code noise, catalog behavior, workspace ignore parity, and boundary-model parity are tuned."
  },
