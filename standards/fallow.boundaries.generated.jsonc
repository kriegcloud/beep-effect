    "rules": [
      {
        "from": "@beep/acp",
        "allow": [
          "@beep/acp",
          "@beep/identity",
          "@beep/schema",
          "@beep/utils"
        ],
        "allowTypeOnly": [
          "@beep/acp",
          "@beep/identity",
          "@beep/schema",
          "@beep/utils"
        ]
      },
      {
        "from": "@beep/agents-client",
        "allow": [
          "@beep/agents-client",
          "@beep/agents-domain",
          "@beep/agents-use-cases",
          "@beep/md",
          "@beep/utils"
        ],
        "allowTypeOnly": [
          "@beep/agents-client",
          "@beep/agents-domain",
          "@beep/agents-use-cases",
          "@beep/md",
          "@beep/utils"
        ]
      },
