    "rules": [
      {
        "from": "@beep/acp",
        "allow": [
          "@beep/acp",
          "@beep/identity",
          "@beep/schema",
          "@beep/utils"
        ],
        "allowTypeOnly": [
          "@beep/acp",
          "@beep/identity",
          "@beep/schema",
          "@beep/utils"
        ]
      },
      {
        "from": "@beep/agent-capability-domain",
        "allow": [
          "@beep/agent-capability-domain",
          "@beep/identity",
          "@beep/schema",
          "@beep/shared-domain"
        ],
        "allowTypeOnly": [
          "@beep/agent-capability-domain",
          "@beep/identity",
          "@beep/schema",
          "@beep/shared-domain"
        ]
      },
      {
