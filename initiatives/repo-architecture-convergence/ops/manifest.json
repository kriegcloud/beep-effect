  "searchAuditFamilies": [
    {
      "id": "legacy-topology-references",
      "purpose": "prove that legacy roots for the batch are removed or explicitly governed"
    },
    {
      "id": "consumer-importer-counts",
      "purpose": "prove which consumers moved and which remain, with counts"
    },
    {
      "id": "hard-coded-entrypoints",
      "purpose": "prove apps, scripts, filters, and launch surfaces point at canonical homes"
    },
    {
      "id": "canonical-subpaths-and-exports",
      "purpose": "prove canonical subpaths and export surfaces are in use"
    },
    {
      "id": "compatibility-aliases-and-shims",
      "purpose": "prove temporary bridges are governed, shrinking, or deleted"
    },
    {
      "id": "family-and-kind-metadata",
      "purpose": "prove touched packages still satisfy family and kind metadata rules"
    }
  ],
  "blockerTaxonomy": [
    {
      "id": "missing-source-artifact",
      "description": "A required source artifact, design doc, prior output, or ledger is missing."
    },
    {
      "id": "missing-route-or-owner",
      "description": "A live surface has no owner, destination, or migration batch."
    },
    {
      "id": "unowned-consumer-importer",
      "description": "A consumer or importer count is missing, inferred, or ownerless."
    },
    {
      "id": "architecture-invalid-route",
      "description": "A route conflicts with the architecture standard and is not governed as an amendment candidate."
    },
    {
      "id": "ungoverned-temporary-exception",
      "description": "A temporary alias, shim, allowlist entry, or route exception lacks full governance data."
    },
    {
      "id": "required-command-failed",
      "description": "A mandatory command gate failed."
    },
    {
      "id": "required-search-audit-missing",
      "description": "An exact search audit is missing, stale, or not replayable."
    },
    {
      "id": "graphiti-obligation-unmet",
      "description": "Graphiti bootstrap or writeback was required but neither succeeded nor was explicitly skipped."
    },
    {
      "id": "stale-evidence",
      "description": "The recorded evidence predates the last material repo change."
    },
    {
      "id": "narrative-only-output",
      "description": "The phase reports intent without landed repo changes."
    }
  ],
