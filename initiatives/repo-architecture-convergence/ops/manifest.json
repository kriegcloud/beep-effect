        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase exit",
      "blocksClosureWhen": "command fails or new allowlist debt is undocumented"
    },
    {
      "id": "test",
      "command": "bun run test",
      "appliesTo": [
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase exit",
      "blocksClosureWhen": "command fails"
    },
    {
      "id": "docgen",
      "command": "bun run docgen",
      "appliesTo": [
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase exit",
      "blocksClosureWhen": "command fails"
    },
    {
      "id": "audit-full",
