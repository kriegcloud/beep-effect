  "statusModel": {
    "phaseStatuses": {
      "pending": "Prerequisites or execution have not started.",
      "ready": "Prerequisites are satisfied and the phase can start.",
      "in_progress": "Repo changes or evidence refresh are underway.",
      "blocked": "A taxonomy-classified blocker prevents trustworthy closure.",
      "awaiting_review": "The artifact bundle exists and needs critique.",
      "remediation_required": "Critique found issues that must be remediated.",
      "awaiting_rereview": "Remediation landed and final review is pending.",
      "completed": "Repo changes, commands, audits, ledgers, and review loop are all closed."
    },
    "artifactStatuses": {
      "expected": "The path is defined but current execution content is missing.",
      "templated": "The authoritative file exists as a control-plane template but phase content is not populated.",
      "in_progress": "The artifact is being updated for the active phase.",
      "current": "The artifact was refreshed for the current state but is not yet review-cleared.",
      "approved": "The artifact is accepted for the current state.",
      "blocked": "The artifact cannot be completed credibly yet."
    },
    "evidenceStatuses": {
      "missing": "No current execution proof is recorded.",
      "partial": "Some proof exists, but gaps remain.",
      "verified": "Required proof for the current state is recorded.",
      "stale": "The proof predates the last material repo change."
    },
    "reviewLoopStages": [
      "not-started",
      "critique",
      "remediation",
      "re-review",
      "cleared"
    ]
  },
  "graphitiContract": {
    "bootstrapCommand": "bun run graphiti:proxy:ensure",
    "startupDuty": "Bootstrap Graphiti at phase start when the environment exposes it, or record a skipped reason.",
    "recallDuty": "Consult Graphiti memory for relevant repo context when the service responds.",
    "writebackDuty": "Record the phase summary, key decisions, and unresolved blockers before handoff when available."
  },
  "commandGates": [
    {
      "id": "graphiti-bootstrap",
      "command": "bun run graphiti:proxy:ensure",
      "appliesTo": [
        "P0",
        "P1",
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase start when Graphiti is available in the operator environment",
      "blocksClosureWhen": "bootstrap is required but neither succeeded nor was explicitly skipped"
    },
    {
      "id": "config-sync",
      "command": "bun run config-sync:check",
      "appliesTo": [
        "P0",
        "P1",
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase exit",
      "blocksClosureWhen": "command fails"
    },
    {
      "id": "check",
      "command": "bun run check",
      "appliesTo": [
        "P2",
        "P3",
        "P4",
        "P5",
        "P6",
        "P7"
      ],
      "timing": "phase exit",
      "blocksClosureWhen": "command fails"
    },
