      "command": "cd packages/tooling/tool/cli && bun run check && bun run test && bun run lint"
    },
    {
      "id": "infra-package",
      "command": "cd infra && bun run check && bun run test && bun run lint"
    },
    {
      "id": "dankserver-preview",
      "command": "cd infra && pulumi preview --stack beep-ai-metrics-dankserver"
    },
    {
      "id": "dankserver-apply",
      "command": "cd infra && pulumi up --stack beep-ai-metrics-dankserver"
    }
